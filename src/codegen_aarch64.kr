            // Use: AND x0, x0, #1 (immediate)
            // AND (bitmask imm): 0x92400000 | (N:immr:imms << 10) | (Rn << 5) | Rd
            // For #1: N=1, immr=0, imms=0 → 0x92400000
            emit_a64(0x92400000 | (0 << 5) | 0)
            return
        }
        if tok_matches(wct, "bit_set", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(temp_slot_0) // val
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            emit_a64_mov(9, 0) // x9 = bit
            emit_a64_mov_imm(10, 1) // x10 = 1
            emit_a64_lsl(10, 10, 9) // x10 = 1 << bit
            emit_a64_load_x0(temp_slot_0) // x0 = val
            emit_a64_orr(0, 0, 10) // x0 = val | (1 << bit)
            return
        }
        if tok_matches(wct, "bit_clear", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            emit_a64_mov(9, 0) // bit
            emit_a64_mov_imm(10, 1)
            emit_a64_lsl(10, 10, 9) // 1 << bit
            emit_a64_mvn(10, 10) // ~(1 << bit)
            emit_a64_load_x0(temp_slot_0)
            emit_a64_and(0, 0, 10) // val & ~(1 << bit)
            return
        }
        if tok_matches(wct, "bit_range", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(temp_slot_0) // val
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            emit_a64_store_x0(temp_slot_1) // start
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr_a64(wa3)
            // x0 = width, compute mask = (1 << width) - 1
            emit_a64_mov(9, 0) // x9 = width
            emit_a64_mov_imm(10, 1)
            emit_a64_lsl(10, 10, 9) // 1 << width
            emit_a64(0xD1000400 | (10 << 5) | 10) // sub x10, x10, #1 → mask
            // shift val right by start
            emit_a64_load_x0(temp_slot_1) // start
            emit_a64_mov(9, 0)
            emit_a64_load_x0(temp_slot_0) // val
            emit_a64_lsr(0, 0, 9) // val >> start
            emit_a64_and(0, 0, 10) // & mask
            return
        }
        if tok_matches(wct, "bit_insert", 10) != 0 {
            uint64 bi_extra = var_count * 8
            var_count = var_count + 4
            var_frame_size = var_count * 8
            uint64 birem = var_frame_size & 15
            if birem != 0 { var_frame_size = var_frame_size + 16 - birem }
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(bi_extra) // val
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            emit_a64_store_x0(bi_extra + 8) // start
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr_a64(wa3)
            emit_a64_store_x0(bi_extra + 16) // width
            uint32 arg4 = ast_next(wa3)
            uint64 wa4 = arg4
            gen_expr_a64(wa4)
            emit_a64_store_x0(bi_extra + 24) // bits
            // mask = (1 << width) - 1
            emit_a64_load_x0(bi_extra + 16)
            emit_a64_mov(9, 0)
            emit_a64_mov_imm(10, 1)
            emit_a64_lsl(10, 10, 9)
            emit_a64(0xD1000400 | (10 << 5) | 10) // sub x10, x10, #1 → mask
            // (bits & mask) << start
            emit_a64_load_x0(bi_extra + 24)
            emit_a64_and(0, 0, 10) // bits & mask
            emit_a64_load_x0(bi_extra + 8) // start
            emit_a64_mov(9, 0)
            emit_a64_lsl(0, 0, 9) // shifted bits
            emit_a64_store_x0(bi_extra + 24) // save shifted bits
            // ~(mask << start)
            emit_a64_lsl(10, 10, 9) // mask << start
            emit_a64_mvn(10, 10) // ~(mask << start)
            // val & ~(mask << start)
            emit_a64_load_x0(bi_extra)
            emit_a64_and(0, 0, 10) // cleared val
            // | shifted bits
            emit_a64_load_x0(bi_extra + 24)
            emit_a64_orr(0, 0, 0) // need to load cleared val
            // Actually: x0 = cleared val, save it, then OR
            emit_a64_store_x0(bi_extra) // cleared val in slot0
            emit_a64_load_x0(bi_extra + 24) // shifted bits
            emit_a64_mov(9, 0)
            emit_a64_load_x0(bi_extra) // cleared val
            emit_a64_orr(0, 0, 9) // result
            return
        }

        // Built-in: get_module_path(buf, size) → exe path length (Windows only, returns 0 on Linux)
        if tok_matches(wct, "get_module_path", 15) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            if target_os == 2 {
                // Windows: GetModuleFileNameA(NULL, buf, size)
                emit_a64_mov(2, 0)
                emit_a64_load_x0(temp_slot_0)
                emit_a64_mov(1, 0)
                emit_a64_mov_imm(0, 0)
                emit_a64_win_call_iat(12)
            } else {
                emit_a64_mov_imm(0, 0)
            }
            return
        }

        // Built-in: exec_process(path) → on Windows: CreateProcessA+Wait+Exit; on Linux: execve
        if tok_matches(wct, "exec_process", 12) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr_a64(wfa)
            if target_os == 2 {
                // ARM64 Windows: save path in x19 (callee-saved)
                emit_a64_store_x0(temp_slot_0)
                // Allocate stack for STARTUPINFOA(104) + PROCESS_INFORMATION(24) + args
                // sub sp, sp, #0xE0 (224 bytes, 16-aligned)
                emit_a64(0xD10380FF)
                // Zero out the STARTUPINFOA and PI area at sp+0x60
                // x0 = sp+0x60, fill 128 bytes with zero
                emit_a64(0x910180E0)  // add x0, sp, #0x60
                emit_a64_mov_imm(1, 0)
                emit_a64_mov_imm(2, 128)
                // Simple byte-zero loop
                // stp xzr, xzr, [x0], #16 (8 times = 128 bytes)
                emit_a64(0xA8C17C1F)  // stp xzr, xzr, [x0], #16
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                emit_a64(0xA8C17C1F)
                // Set STARTUPINFOA.cb = 104 at [sp+0x60]
                emit_a64_mov_imm(9, 104)
                emit_a64(0xB9006FE9)  // str w9, [sp, #0x6C] -- wait, offset 0x60
                // Actually: str w9, [sp, #0x60]
                emit_a64(0xB90060E9)  // str w9, [sp, #0x60]
                // CreateProcessA(NULL, path, NULL, NULL, 0, 0, NULL, NULL, &si, &pi)
                // x0 = NULL (lpApplicationName)
                emit_a64_mov_imm(0, 0)
                // x1 = path (lpCommandLine)
                emit_a64_load_x0(temp_slot_0)
                emit_a64_mov(1, 0)
                emit_a64_mov_imm(0, 0)
                // x2 = NULL, x3 = NULL, x4 = 0, x5 = 0, x6 = NULL, x7 = NULL
                emit_a64_mov_imm(2, 0)
                emit_a64_mov_imm(3, 0)
                emit_a64_mov_imm(4, 0)
                emit_a64_mov_imm(5, 0)
                emit_a64_mov_imm(6, 0)
                emit_a64_mov_imm(7, 0)
                // Stack args: [sp+0] = &si, [sp+8] = &pi
                emit_a64(0x910180E9)  // add x9, sp, #0x60 (&si)
                emit_a64(0xF90003E9)  // str x9, [sp, #0]
                emit_a64(0x9102E0E9)  // add x9, sp, #0xB8 (&pi = sp + 0x60 + 104 = sp + 0xC8... actually 0x60+0x68=0xC8)
                emit_a64(0xF90007E9)  // str x9, [sp, #8]
                // call CreateProcessA via IAT (slot 9)
                emit_a64_win_call_iat(9)
                // WaitForSingleObject(hProcess, INFINITE)
                emit_a64(0xF940C4E0)  // ldr x0, [sp, #0xC8+0] -- hProcess at PI offset = sp+0xC8
                // Actually the PI is after STARTUPINFOA. SI at sp+0x60, size 104=0x68, so PI at sp+0xC8
                emit_a64_mov_imm(1, 0xFFFFFFFF)
                emit_a64_win_call_iat(10)
                // GetExitCodeProcess(hProcess, &exitCode)
                emit_a64(0xF940C4E0)  // ldr x0, [sp, #0xC8]
                emit_a64(0x910000E1)  // add x1, sp, #0 (use sp+0 for exit code)
                emit_a64_win_call_iat(11)
                // Load exit code
                emit_a64(0xB94003E0)  // ldr w0, [sp, #0]
                // add sp, sp, #0xE0
                emit_a64(0x910380FF)
                // ExitProcess(w0 already in x0)
                emit_a64_win_call_iat(0)
            } else {
                // Linux: execve(x0=path, x1=NULL, x2=NULL)
                emit_a64_mov(0, 0)
                emit_a64_mov_imm(1, 0)
                emit_a64_mov_imm(2, 0)
                if target_os == 1 { emit_a64_syscall_nr(59) } else { emit_a64_syscall_nr(221) }
                emit_a64(0xD4000001) // svc #0
            }
            return
        }

        // Built-in: get_target_os() → compile-time OS constant (0=Linux, 1=macOS, 2=Windows)
        if tok_matches(wct, "get_target_os", 13) != 0 {
            emit_a64_mov_imm(0, target_os)
            return
        }

        // Built-in: get_arch_id() → compile-time arch ID
        if tok_matches(wct, "get_arch_id", 11) != 0 {
            if target_os == 2 {
                emit_a64_mov_imm(0, 4)
            } else if target_os == 1 {
                emit_a64_mov_imm(0, 6)
            } else {
                emit_a64_mov_imm(0, 2)
            }
            return
        }

        // User-defined function call
        uint32 arg = ast_child(node)
        uint64 warg = arg
        uint64 arg_count = 0
        uint64 wtmp = arg
        while wtmp != 0 {
            arg_count = arg_count + 1
            uint32 nt2 = ast_next(wtmp)
            wtmp = nt2
        }

        // Allocate temp slots for args
        uint64 arg_slots_base = var_count * 8
        uint64 ac = 0
        while ac < arg_count {
            var_count = var_count + 1
            ac = ac + 1
        }
        var_frame_size = var_count * 8
        uint64 acrem = var_frame_size & 15
        if acrem != 0 { var_frame_size = var_frame_size + 16 - acrem }

        // Evaluate and store all args
        uint64 weval = warg
        uint64 ai = 0
        while weval != 0 {
            gen_expr_a64(weval)
            emit_a64_store_x0(arg_slots_base + ai * 8)
            ai = ai + 1
            uint32 anxt = ast_next(weval)
            weval = anxt
        }

        // Load args into x0-x7
        if arg_count >= 8 { emit_a64_load_x0(arg_slots_base + 56); emit_a64_mov(7, 0) }
        if arg_count >= 7 { emit_a64_load_x0(arg_slots_base + 48); emit_a64_mov(6, 0) }
        if arg_count >= 6 { emit_a64_load_x0(arg_slots_base + 40); emit_a64_mov(5, 0) }
        if arg_count >= 5 { emit_a64_load_x0(arg_slots_base + 32); emit_a64_mov(4, 0) }
        if arg_count >= 4 { emit_a64_load_x0(arg_slots_base + 24); emit_a64_mov(3, 0) }
        if arg_count >= 3 { emit_a64_load_x0(arg_slots_base + 16); emit_a64_mov(2, 0) }
        if arg_count >= 2 { emit_a64_load_x0(arg_slots_base + 8); emit_a64_mov(1, 0) }
        if arg_count >= 1 { emit_a64_load_x0(arg_slots_base) }

        // BL rel26 (placeholder, fixup needed)
        uint64 fixup_off = out_len
        emit_a64_bl(0)
        // Record fixup (same table as x86_64 — resolve_fixups handles both)
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = fixup_off
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = callee_tok
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1
        return
    }
}

// ---------------------------------------------------------------------------
// AArch64 statement codegen
// ---------------------------------------------------------------------------

fn gen_stmt_a64(uint64 node) {
    uint32 kind = ast_kind(node)

    // Variable declaration
    if kind == 10 {
        uint32 name_tok = ast_data2(node)
        uint32 arr_size_tok = ast_data3(node)
        uint64 was = arr_size_tok
        if was != 0 {
            uint64 arr_size = parse_int_token(was)
            uint64 n_slots = (arr_size + 7) / 8
            uint64 arr_offset = var_count * 8
            uint64 si = 0
            while si < n_slots { var_count = var_count + 1; si = si + 1 }
            var_frame_size = var_count * 8
            uint64 arem2 = var_frame_size & 15
            if arem2 != 0 { var_frame_size = var_frame_size + 16 - arem2 }
            uint64 ptr_offset = var_declare(name_tok)
            emit_a64_add_imm(0, 31, a64_var_base + arr_offset)
            emit_a64_store_x0(ptr_offset)
            return
        }
        uint32 struct_marker = ast_data4(node)
        uint64 wsm = struct_marker
        if wsm != 0 {
            uint64 sidx = wsm - 1
            uint64 ssize = struct_total_size(sidx)
            uint64 n_slots = (ssize + 7) / 8
            uint64 struct_off = var_count * 8
            uint64 ssi = 0
            while ssi < n_slots { var_count = var_count + 1; ssi = ssi + 1 }
            var_frame_size = var_count * 8
            uint64 srem = var_frame_size & 15
            if srem != 0 { var_frame_size = var_frame_size + 16 - srem }
            uint64 ptr_off = var_declare(name_tok)
            emit_a64_add_imm(0, 31, a64_var_base + struct_off)
            emit_a64_store_x0(ptr_off)
            struct_var_register(name_tok, sidx)
            return
        }
        uint64 offset = var_declare(name_tok)
        uint32 init_child = ast_child(node)
        uint64 wic = init_child
        if wic != 0 {
            gen_expr_a64(wic)
            emit_a64_store_x0(offset)
        }
        return
    }

    // Assignment
    if kind == 11 {
        uint32 name_tok = ast_data1(node)
        uint32 val_child = ast_child(node)
        uint64 wvc = val_child
        gen_expr_a64(wvc)
        uint64 offset = var_lookup(name_tok)
        if offset != 0xFFFFFFFF {
            emit_a64_store_x0(offset)
        } else {
            uint64 soff = static_lookup(name_tok)
            if soff != 0xFFFFFFFF {
                emit_a64_static_store(soff)
            }
        }
        return
    }

    // Return
    if kind == 12 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        if wec != 0 {
            gen_expr_a64(wec)
        }
        // Jump to epilogue
        emit_a64_b(0)
        uint64 ret_patch = out_len - 4
        uint64 rentry = ret_fixups + ret_fixup_count * 4
        uint32 rp32 = ret_patch
        unsafe { *(rentry as uint32) = rp32 }
        ret_fixup_count = ret_fixup_count + 1
        return
    }

    // If/else
    if kind == 13 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        // cbz x0, else_target (placeholder)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        // Then body
        uint32 then_idx = ast_data1(node)
        uint64 wthen = then_idx
        gen_block_a64(wthen)
        // b endif (placeholder)
        uint64 b_patch = out_len
        emit_a64_b(0)
        // Patch cbz to here
        uint64 else_target = out_len
        uint64 cbz_disp = else_target - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((cbz_disp / 4) & 0x7FFFF) << 5) | 0)
        // Else body
        uint32 else_idx = ast_data2(node)
        uint64 welse = else_idx
        if welse != 0 {
            uint32 else_kind = ast_kind(welse)
            if else_kind == 13 {
                gen_stmt_a64(welse)
            } else {
                gen_block_a64(welse)
            }
        }
        // Patch b to here
        uint64 endif_target = out_len
        uint64 b_disp = endif_target - b_patch
        patch_u32(b_patch, 0x14000000 | ((b_disp / 4) & 0x3FFFFFF))
        return
    }

    // While
    if kind == 14 {
        uint64 loop_start = out_len
        uint64 lentry = loop_stack + loop_depth * 16
        unsafe { *(lentry as uint64) = loop_start }
        uint64 lentry8 = lentry + 8
        unsafe { *(lentry8 as uint64) = break_fixup_count }
        loop_depth = loop_depth + 1

        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        uint32 body_idx = ast_data1(node)
        uint64 wbody = body_idx
        gen_block_a64(wbody)
        // b loop_start
        uint64 back_disp = loop_start - out_len
        emit_a64_b(back_disp & 0xFFFFFFFF)
        // Patch cbz to here
        uint64 loop_end = out_len
        uint64 fwd_disp = loop_end - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((fwd_disp / 4) & 0x7FFFF) << 5) | 0)
        // Patch break fixups
        loop_depth = loop_depth - 1
        uint64 lentry2 = loop_stack + loop_depth * 16 + 8
        uint64 saved_break_start = 0
        unsafe { *(lentry2 as uint64) -> saved_break_start }
        uint64 bi = saved_break_start
        while bi < break_fixup_count {
            uint64 bentry = break_fixups + bi * 4
            uint32 bpatch = 0
            unsafe { *(bentry as uint32) -> bpatch }
            uint64 wbp = bpatch
            uint64 bdisp = loop_end - wbp
            patch_u32(wbp, 0x14000000 | ((bdisp / 4) & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break_start
        return
    }

    // Break
    if kind == 17 {
        uint64 brk_off = out_len
        emit_a64_b(0)
        uint64 brk_entry = break_fixups + break_fixup_count * 4
        uint32 brk32 = brk_off
        unsafe { *(brk_entry as uint32) = brk32 }
        break_fixup_count = break_fixup_count + 1
        return
    }

    // Continue
    if kind == 18 {
        uint64 lentry3 = loop_stack + (loop_depth - 1) * 16
        uint64 cont_target = 0
        unsafe { *(lentry3 as uint64) -> cont_target }
        uint64 cont_disp = cont_target - out_len
        emit_a64_b(cont_disp & 0xFFFFFFFF)
        return
    }

    // Match statement
    if kind == 19 {
        uint32 scrutinee = ast_child(node)
        uint64 wscr = scrutinee
        gen_expr_a64(wscr)
        uint64 match_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 mrem = var_frame_size & 15
        if mrem != 0 { var_frame_size = var_frame_size + 16 - mrem }
        emit_a64_store_x0(match_temp)
        uint64 saved_break = break_fixup_count
        uint32 arm_idx = ast_data1(node)
        uint64 warm = arm_idx
        while warm != 0 {
            uint32 val_idx = ast_data1(warm)
            uint64 wval = val_idx
            gen_expr_a64(wval)
            emit_a64_mov(9, 0)
            emit_a64_load_x0(match_temp)
            emit_a64_cmp(0, 9)
            // B.NE skip_arm (placeholder)
            uint64 bne_patch = out_len
            emit_a64(0x54000001)  // B.NE +0 (patched)
            // Execute body
            uint32 body_idx = ast_data2(warm)
            uint64 wbody = body_idx
            gen_block_a64(wbody)
            // B end_match (stored in break_fixups)
            uint64 end_patch = out_len
            emit_a64(0x14000000)  // B +0 (patched)
            uint64 bf = break_fixups + break_fixup_count * 4
            uint32 ep32 = end_patch
            unsafe { *(bf as uint32) = ep32 }
            break_fixup_count = break_fixup_count + 1
            // Patch B.NE to here
            uint64 skip_off = (out_len - bne_patch) >> 2
            patch_u32(bne_patch, 0x54000001 | (skip_off << 5))
            uint32 next_arm = ast_next(warm)
            warm = next_arm
        }
        // Patch end-match jumps
        uint64 end_addr = out_len
        uint64 bi = saved_break
        while bi < break_fixup_count {
            uint64 bfe = break_fixups + bi * 4
            uint32 bp32 = 0
            unsafe { *(bfe as uint32) -> bp32 }
            uint64 wbp = bp32
            uint64 b_off = (end_addr - wbp) >> 2
            patch_u32(wbp, 0x14000000 | (b_off & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break
        return
    }

    // PtrLoad
    if kind == 41 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        if wts == 1 { emit_a64_ldrb(0, 0, 0) }
        else if wts == 4 { emit_a64_ldr32(0, 0, 0) }
        else { emit_a64_ldr(0, 0, 0) }
        uint32 dest_tok = ast_data2(node)
        uint64 doff = var_lookup(dest_tok)
        if doff != 0xFFFFFFFF {
            emit_a64_store_x0(doff)
        } else {
            uint64 soff = static_lookup(dest_tok)
            if soff != 0xFFFFFFFF { emit_a64_static_store(soff) }
        }
        return
    }

    // PtrStore
    if kind == 42 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 val_child = ast_data2(node)
        uint64 wv = val_child
        gen_expr_a64(wv)
        emit_a64_store_x0(temp_slot_0)
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        emit_a64_mov(10, 0)
        emit_a64_load_x0(temp_slot_0)
        if wts == 1 { emit_a64_strb(0, 10, 0) }
        else if wts == 4 { emit_a64_str32(0, 10, 0) }
        else { emit_a64_str(0, 10, 0) }
        return
    }

    // Indexed assignment (arr[i] = val)
    if kind == 37 {
        uint32 idx_d3 = ast_data3(node)
        uint64 wd3 = idx_d3
        if wd3 == 1 {
            uint32 rhs_child = ast_data2(node)
            uint64 wrhs = rhs_child
            gen_expr_a64(wrhs)
            emit_a64_store_x0(temp_slot_0)
            uint32 idx_child = ast_child(node)
            uint64 wi = idx_child
            gen_expr_a64(wi)
            emit_a64_store_x0(temp_slot_1)
            uint32 arr_tok = ast_data1(node)
            uint64 arr_offset = var_lookup(arr_tok)
            if arr_offset == 0xFFFFFFFF { arr_offset = 0 }
            emit_a64_load_x0(arr_offset)
            emit_a64_mov(10, 0)
            emit_a64_load_x0(temp_slot_1)
            emit_a64_add(10, 10, 0)
            emit_a64_load_x0(temp_slot_0)
            emit_a64_strb(0, 10, 0)
            return
        }
    }

    // Field assignment (var.field = val)
    if kind == 36 {
        uint32 fa_d4 = ast_data4(node)
        uint64 wfad4 = fa_d4
        if wfad4 == 1 {
            uint32 fa_child = ast_child(node)
            uint64 wfachild = fa_child
            uint32 obj_tok = 0
            if wfachild != 0 {
                uint32 fack = ast_kind(wfachild)
                uint64 wfack = fack
                if wfack == 32 {
                    obj_tok = ast_data1(wfachild)
                }
            }
            uint32 field_tok = ast_data2(node)
            uint32 val_node = ast_data3(node)
            uint64 wval = val_node
            gen_expr_a64(wval)
            emit_a64_store_x0(temp_slot_0)
            uint64 si = struct_var_lookup(obj_tok)
            if si != 0xFFFFFFFF {
                uint64 var_off = var_lookup(obj_tok)
                if var_off == 0xFFFFFFFF { var_off = 0 }
                uint64 foff = struct_field_offset(si, field_tok)
                uint64 fsz = struct_field_size(si, field_tok)
                emit_a64_load_x0(var_off)
                if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                emit_a64_mov(10, 0)
                emit_a64_load_x0(temp_slot_0)
                if fsz == 1 { emit_a64_strb(0, 10, 0) }
                else if fsz == 4 { emit_a64_str32(0, 10, 0) }
                else { emit_a64_str(0, 10, 0) }
            }
            return
        }
    }

    // Inline assembly
    if kind == 43 {
        uint32 single_tok = ast_data1(node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_a64(ws)
        }
        uint32 child_str = ast_child(node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_a64(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }
        return
    }

    // Expression statement
    if kind == 16 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        gen_expr_a64(wec)
        return
    }
}

fn gen_block_a64(uint64 block_node) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        gen_stmt_a64(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// AArch64 ELF header emission
// ---------------------------------------------------------------------------

fn emit_elf_header_a64() {
    emit_byte(0x7F); emit_byte(69); emit_byte(76); emit_byte(70)
    emit_byte(2); emit_byte(1); emit_byte(1); emit_byte(0)
    uint64 i = 0
    while i < 8 { emit_byte(0); i = i + 1 }
    emit_u16_le(2)
    emit_u16_le(0xB7)
    emit_u32_le(1)
    emit_u64_le(0)
    emit_u64_le(64)
    emit_u64_le(0)
    emit_u32_le(0)
    emit_u16_le(64)
    emit_u16_le(56)
    emit_u16_le(1)
    emit_u16_le(64)
    emit_u16_le(0)
    emit_u16_le(0)
}

fn emit_program_header_a64(uint64 text_size) {
    uint64 total = 120 + text_size
    emit_u32_le(1)
    emit_u32_le(7)
    emit_u64_le(0)
    emit_u64_le(0x400000)
    emit_u64_le(0x400000)
    emit_u64_le(total)
    emit_u64_le(total)
    emit_u64_le(0x10000)
}

// ---------------------------------------------------------------------------
// AArch64 function codegen (prologue + body + epilogue)
// ---------------------------------------------------------------------------

@export
fn gen_function_a64(uint64 fn_node) {
    uint32 name_tok = ast_data1(fn_node)

    // Check annotation flags: bit 0 = noreturn, bit 1 = naked
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2
    uint64 is_noreturn = ann_flags & 1

    var_reset()
    temp_slot_0 = var_count * 8
    var_count = var_count + 1
    temp_slot_1 = var_count * 8
    var_count = var_count + 1
    var_frame_size = var_count * 8
    uint64 rem0 = var_frame_size & 15
    if rem0 != 0 { var_frame_size = var_frame_size + 16 - rem0 }

    fn_register(name_tok, out_len)

    // For main: platform-specific _start trampoline
    uint64 wnt_a64 = name_tok
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os == 2 && freestanding == 0 {
        // All 13 IAT entries are loader-resolved. Call GetCommandLineA directly.
        emit_a64_win_call_iat(7)       // GetCommandLineA → x0 = cmdline
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_w)
        }
        // Set cli_argc = 0xFFFFFFFF as "needs parsing" sentinel
        emit_a64_mov_imm(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_w)
        }
    }
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os == 0 && freestanding == 0 {
        // ldr x0, [sp]        ; x0 = argc
        emit_a64_ldr(0, 31, 0)
        // Store to cli_argc static
        uint64 argc_off_a64 = static_lookup_by_name("cli_argc", 8)
        if argc_off_a64 != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_a64)
        }
        // add x0, sp, #8      ; x0 = &argv[0]
        emit_a64_add_imm(0, 31, 8)
        uint64 argv_off_a64 = static_lookup_by_name("cli_argv", 8)
        if argv_off_a64 != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_a64)
        }
    }

    // Parse params
    uint32 first_param = ast_child(fn_node)
    uint64 wparam = first_param
    while wparam != 0 {
        uint32 pk = ast_kind(wparam)
        if pk == 3 {
            uint32 param_name = ast_data2(wparam)
            var_declare(param_name)
        }
        uint32 pnxt = ast_next(wparam)
        wparam = pnxt
    }

    // Prologue — for large frames (>4080) we split: pre_sub + prologue_sub
    uint64 pre_sub_patch = out_len
    if is_naked == 0 {
        emit_a64(0xD503201F)  // NOP (patched to SUB SP if frame > 4080)
    }
    uint64 prologue_start = out_len
    if is_naked == 0 {
        emit_a64(0xD1000000)  // SUB SP, SP, #imm (patched)
        // stp x29, x30, [sp] (no pre-index, frame already allocated)
        emit_a64(0xA9007BFD)
        // mov x29, sp
        emit_a64_add_imm(29, 31, 0)
        // stp x19, x20, [sp, #16]
        emit_a64(0xA90153F3)
    }

    // Spill params to stack (x0-x7)
    uint64 pidx = 0
    uint64 wp2 = first_param
    while wp2 != 0 {
        uint32 pk2 = ast_kind(wp2)
        if pk2 == 3 {
            uint32 pn2 = ast_data2(wp2)
            uint64 poff = var_lookup(pn2)
            if poff != 0xFFFFFFFF {
                // str xN, [sp, #(a64_var_base + poff)]
                uint64 reg = pidx
                if reg <= 7 {
                    emit_a64_str(reg, 31, a64_var_base + poff)
                }
                pidx = pidx + 1
            }
        }
        uint32 pn3 = ast_next(wp2)
        wp2 = pn3
    }

    ret_fixup_count = 0

    // Generate body
    uint32 body_idx = ast_data3(fn_node)
    uint64 wbody = body_idx
    if wbody != 0 {
        gen_block_a64(wbody)
    }

    // Epilogue — patch return jumps here
    uint64 epilogue_start = out_len
    uint64 ri = 0
    while ri < ret_fixup_count {
        uint64 rentry = ret_fixups + ri * 4
        uint32 rpatch = 0
        unsafe { *(rentry as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 disp = epilogue_start - wrp
        // Patch B instruction
        patch_u32(wrp, 0x14000000 | ((disp / 4) & 0x3FFFFFF))
        ri = ri + 1
    }

    // For @naked functions, skip epilogue entirely
    if is_naked != 0 {
        return
    }

    // For main: auto-insert exit(0) so programs don't segfault on return
    // Skip when in freestanding mode
    uint64 wnt_ep = name_tok
    if tok_matches(wnt_ep, "main", 4) != 0 && freestanding == 0 {
        emit_a64_mov_imm(0, 0)
        if target_os == 2 {
            emit_a64_win_call_iat(0)
        } else {
            if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
            emit_a64_svc()
        }
    }

    // ldp x19, x20, [sp, #16]
    emit_a64(0xA94153F3)
    // ldp x29, x30, [sp] (no post-index)
    emit_a64(0xA9407BFD)
    // add sp, sp, #FRAME (placeholder, patched)
    uint64 epilogue_add = out_len
    emit_a64(0x91000000)
    uint64 post_add_patch = out_len
    emit_a64(0xD503201F)  // NOP (patched to ADD SP if frame > 4080)
    // ret
    emit_a64_ret()

    // Patch prologue and epilogue frame sizes
    uint64 frame = a64_var_base + var_frame_size
    uint64 fmod = frame & 15
    if fmod != 0 { frame = frame + 16 - fmod }

    if frame > 4080 {
        // Split: pre_sub does (frame>>12)*4096 via LSL#12, prologue_sub does remainder
        uint64 hi = frame >> 12
        uint64 lo = frame & 0xFFF
        // Ensure lo is 16-aligned
        uint64 lmod = lo & 15
        if lmod != 0 { lo = lo + 16 - lmod; hi = (frame - lo) >> 12 }
        // pre_sub: SUB SP, SP, #hi, LSL #12 (0xD1400000)
        patch_u32(pre_sub_patch, 0xD1400000 | (hi << 10) | (31 << 5) | 31)
        // prologue: SUB SP, SP, #lo
        patch_u32(prologue_start, 0xD1000000 | (lo << 10) | (31 << 5) | 31)
        // Epilogue: ADD SP, SP, #lo then ADD SP, SP, #hi, LSL #12 (0x91400000)
        patch_u32(epilogue_add, 0x91000000 | (lo << 10) | (31 << 5) | 31)
        patch_u32(post_add_patch, 0x91400000 | (hi << 10) | (31 << 5) | 31)
    } else {
        // pre_sub stays NOP, prologue does the full frame
        patch_u32(prologue_start, 0xD1000000 | (frame << 10) | (31 << 5) | 31)
        // epilogue does the full frame, post_add stays NOP
        patch_u32(epilogue_add, 0x91000000 | (frame << 10) | (31 << 5) | 31)
    }
}

// ---------------------------------------------------------------------------
// AArch64 fixup resolution
// ---------------------------------------------------------------------------

@export
fn resolve_fixups_a64() {
    uint64 i = 0
    while i < fixup_count {
        uint64 fentry = fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 target_tok = 0
        unsafe { *(fe4 as uint32) -> target_tok }

        uint64 wtt = target_tok
        uint64 target_off = fn_lookup(wtt)
        if target_off != 0xFFFFFFFF {
            uint64 wpo = patch_off
            uint64 disp = target_off - wpo
            // Patch BL instruction: BL rel26
            patch_u32(wpo, 0x94000000 | ((disp / 4) & 0x3FFFFFF))
        }
        i = i + 1
    }
}

// Resolve fn_addr fixups for ARM64: ADRP+ADD → patch to function address
fn resolve_fnaddr_fixups_a64() {
    uint64 i = 0
    while i < fnaddr_fixup_count {
        uint64 fentry = fnaddr_fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 str_tok = 0
        unsafe { *(fe4 as uint32) -> str_tok }

        uint64 wst = str_tok
        uint64 sstart = tok_text_start(wst)
        uint64 slen = tok_text_len(wst)
        uint64 name_start = sstart + 1
        uint64 name_len = slen - 2

        // Search function table
        uint64 found = 0
        uint64 target_off = 0
        uint64 fi = 0
        while fi < fn_count {
            uint64 fentry2 = fn_table + fi * 8
            uint32 fn_name_tok = 0
            unsafe { *(fentry2 as uint32) -> fn_name_tok }
            uint64 wfn = fn_name_tok
            uint64 fn_start = tok_text_start(wfn)
            uint64 fn_len = tok_text_len(wfn)
            if fn_len == name_len {
                uint64 eq = 1
                uint64 ci = 0
                while ci < name_len {
                    uint64 ca = cg_source + name_start + ci
                    uint64 cb = cg_source + fn_start + ci
                    uint64 va = 0
                    uint64 vb = 0
                    unsafe { *(ca as uint8) -> va }
                    unsafe { *(cb as uint8) -> vb }
                    if va != vb { eq = 0 }
                    ci = ci + 1
                }
                if eq != 0 {
                    uint64 fe4_2 = fentry2 + 4
                    uint32 foff = 0
                    unsafe { *(fe4_2 as uint32) -> foff }
                    target_off = foff
                    found = 1
                }
            }
            fi = fi + 1
        }

        if found != 0 {
            uint64 wpo = patch_off
            // For ARM64, ADRP+ADD is PC-relative
            // ADRP uses page-aligned PC-relative addressing
            // For simplicity in flat binary: use ADR x0, target (if within ±1MB)
            // ADR: bits [31]=0, [30:29]=immlo, [28:24]=10000, [23:5]=immhi, [4:0]=Rd
            uint64 disp = target_off - wpo
            uint64 immlo = (disp >> 0) & 3
            uint64 immhi = (disp >> 2) & 0x7FFFF
            // ADR x0, disp
            uint32 adr_instr = 0x10000000 | (immlo << 29) | (immhi << 5) | 0
            patch_u32(wpo, adr_instr)
            // NOP the second instruction (ADD)
            patch_u32(wpo + 4, 0xD503201F)
        } else {
            write(2, "error: fn_addr: undefined function '", 36)
            write(2, cg_source + name_start, name_len)
            write(2, "'\n", 2)
            exit(1)
        }
        i = i + 1
    }
}

// AArch64 static access uses absolute addresses loaded via MOV immediate sequence
// The fixup patches the MOV sequence to point to the correct address
//
// VA computation depends on target format:
//   ELF:    VA = 0x400000 + file_offset
//   Mach-O: VA = 0x100000000 + file_offset
//   PE:     VA = 0x140000000 + 0x1000 + (file_offset - 0x200)
//                = 0x140000E00 + file_offset

// Compute VA from a raw file offset based on target_os
fn a64_compute_va(uint64 file_offset) -> uint64 {
    if target_os == 2 {
        // PE: image_base(0x140000000) + text_rva(0x1000) + (file_off - header_size(0x200))
        return 0x140000E00 + file_offset
    }
    if target_os == 1 {
        // Mach-O: vmaddr(0x100000000) + file_offset
        return 0x100000000 + file_offset
    }
    // ELF: load at 0x400000
    return 0x400000 + file_offset
}

@export
fn resolve_static_fixups_a64(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        uint64 wdo = data_off
        uint64 wco = code_off
        if target_os == 2 {
            // PE: patch ADRP + LDR/STR with PC-relative offsets
            // Code at file offset wco has RVA = 0x1000 + (wco - text_start_global)
            // But we don't have text_start here. Use data_start to compute:
            // target RVA = data_start was passed as data_rva - 0xE00 for compat,
            // OR as data_va_base. The actual target RVA = data_start + 0xE00 + wdo
            // Actually: a64_compute_va(data_start + wdo) gives the correct VA.
            // For ADRP: page delta from code to target
            // ADRP at wco: its RVA = a64_compute_va(wco) - 0x140000000
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(data_start + wdo)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            // Patch ADRP X16
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            // Patch LDR/STR X?, [X16, #offset]
            // The second instruction is either LDR X0 or STR X9
            // Read existing instruction to determine which
            uint64 insn_off = wco + 4
            uint64 insn_ptr = out_buf + insn_off
            uint32 existing = 0
            unsafe { *(insn_ptr as uint32) -> existing }
            uint64 wex = existing
            uint64 imm12 = (page_off >> 3) & 0xFFF
            // Preserve the opcode and registers, just update the offset
            uint64 base_insn = wex & 0xFFC003FF
            patch_u32(insn_off, base_insn | (imm12 << 10))
        } else {
            // ELF/Mach-O: patch MOVZ/MOVK with absolute VA
            uint64 target_va = a64_compute_va(data_start + wdo)
            uint64 lo16 = target_va & 0xFFFF
            uint64 hi16 = (target_va >> 16) & 0xFFFF
            uint64 hi32 = (target_va >> 32) & 0xFFFF
            patch_u32(wco, 0xD280000A | (lo16 << 5))
            patch_u32(wco + 4, 0xF2A0000A | (hi16 << 5))
            patch_u32(wco + 8, 0xF2C0000A | (hi32 << 5))
        }
        i = i + 1
    }
}

@export
fn resolve_string_fixups_a64(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 wso = str_off
        uint64 wco = code_off
        if target_os == 2 {
            // PE: patch ADRP + ADD with PC-relative offsets
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            // ADD Xd, X16, #page_off (preserve Rd from original instruction)
            uint32 existing_add = 0
            uint64 add_addr = out_buf + wco + 4
            unsafe { *(add_addr as uint32) -> existing_add }
            uint64 rd = existing_add & 0x1F
            patch_u32(wco + 4, 0x91000200 | (page_off << 10) | rd)
        } else {
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 lo16 = target_va & 0xFFFF
            uint64 hi16 = (target_va >> 16) & 0xFFFF
            uint64 hi32 = (target_va >> 32) & 0xFFFF
            patch_u32(wco, 0xD2800000 | (lo16 << 5))
            patch_u32(wco + 4, 0xF2A00000 | (hi16 << 5))
            patch_u32(wco + 8, 0xF2C00000 | (hi32 << 5))
        }
        i = i + 1
    }
}
