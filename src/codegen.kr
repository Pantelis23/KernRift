// KernRift self-hosted compiler — Code Generator (x86_64 ELF)
//
// Strategy: register-based codegen. Expressions evaluate into %rax.
// Variables live on the stack. Function calls use SysV ABI.
//
// Stack frame layout (per function):
//   [rsp + 0]          local variable 0
//   [rsp + 8]          local variable 1
//   ...
//   Frame size = n_locals * 8 (aligned to 16)

// Output buffer
static uint64 out_buf = 0
static uint64 out_len = 0
static uint64 out_cap = 0

// Source + token buffer (for reading token text)
static uint64 cg_source = 0
static uint64 cg_tokens = 0

// Variable table: maps variable name token → stack offset
// Simple flat array: [name_tok_idx(4), stack_offset(4)] × 256
static uint64 var_table = 0
static uint64 var_count = 0
static uint64 var_frame_size = 0

// Temp slot offset within frame (for expression evaluation)
// Reserved at function start, used by BinOp and function call arg staging
static uint64 temp_slot_0 = 0
static uint64 temp_slot_1 = 0

// Function table: maps function name → code offset in output
// [name_tok_idx(4), code_offset(4)] × 256
static uint64 fn_table = 0
static uint64 fn_count = 0

// Extern function table — functions declared with `extern fn name(params)`
// that are resolved at link time by the system linker. Each entry is
// 8 bytes: [name_tok(4), pad(4)]. Max 256 externs.
static uint64 extern_fn_table = 0
static uint64 extern_fn_count = 0

// Extern call sites — per-call-site record of where to emit a linker
// relocation. Each entry is 16 bytes:
//   [code_off(4), extern_idx(4), pad(8)]
// code_off is the byte offset of the instruction (ARM64) or of the
// 4-byte displacement (x86_64) inside the .text section.
static uint64 extern_call_sites = 0
static uint64 extern_call_count = 0

// Return fixup table: jmp offsets that need patching to epilogue
// [patch_offset(4)] × 64
static uint64 ret_fixups = 0
static uint64 ret_fixup_count = 0

// Loop context for break/continue
// [loop_start_offset(8), break_fixup_start(8)] × 16 deep
static uint64 loop_stack = 0
static uint64 loop_depth = 0
// Break fixup list: [patch_offset(4)] × 256
static uint64 break_fixups = 0
static uint64 break_fixup_count = 0

// Fixup table: call sites that need patching after all functions emitted
// [patch_offset(4), target_name_tok(4)] × 1024
static uint64 fixup_table = 0
static uint64 fixup_count = 0

// fn_addr fixup table: LEA instructions that need patching to function addresses
// [patch_offset(4), str_tok(4)] × 256
static uint64 fnaddr_fixup_table = 0
static uint64 fnaddr_fixup_count = 0

// Static variable table: maps name token → data offset in data section
// [name_tok_idx(4), data_offset(4)] × 256
static uint64 static_table = 0
static uint64 static_count = 0
static uint64 static_data_size = 0
// Parallel byte array: 0 = scalar static, >0 = array static (byte size)
static uint64 static_array_sizes = 0

// Struct metadata table
// For each struct: [name_tok(4), field_count(4), total_size(4), pad(4)]
// Followed by field entries: [field_name_tok(4), field_offset(4), field_size(4), pad(4)]
// Max 64 structs, each with max 16 fields
static uint64 struct_table = 0
static uint64 struct_count = 0

// Struct variable type tracking: maps var name_tok → struct index
// [var_name_tok(4), struct_idx(4)] × 1024
static uint64 struct_var_table = 0
static uint64 struct_var_count = 0

// Enum value table: maps (enum_name_tok, field_name_tok) → value
// [enum_name_tok(4), field_name_tok(4), value(8)] × 512
static uint64 enum_table = 0
static uint64 enum_count = 0

// Static access fixup table: RIP-relative displacements to patch
// [code_patch_offset(4), static_data_offset(4)] × 2048
static uint64 static_fixups = 0
static uint64 static_fixup_count = 0

// String literal table: raw string bytes stored contiguously
static uint64 str_buf = 0
static uint64 str_len = 0
// String fixup table: [code_patch_offset(4), str_data_offset(4)] × 1024
static uint64 str_fixups = 0
static uint64 str_fixup_count = 0

// Target OS: 0=linux, 1=macos, 2=windows
static uint64 target_os = 0

// Windows IAT call fixups: [patch_offset(4), iat_slot(4)] × 1024
static uint64 win_iat_fixups = 0
static uint64 win_iat_fixup_count = 0
// ARM64 Windows IAT fixups (same format)
static uint64 a64_win_iat_fixups = 0
static uint64 a64_win_iat_fixup_count = 0
// PE IAT RVA (set during PE header emission)
static uint64 pe_iat_rva = 0

// Per-scalar-static initial values (u64 each) — parallel to static_table.
// Written by static_set_init_last, read by emit_static_data.
static uint64 static_init_values = 0

// Local array element size table — records the per-element size of each
// local `TYPE[N] name` declaration so that index reads/writes can scale the
// index and use the right load/store width. Without this, u64[N]/u32[N]/
// u16[N] arrays silently miscompile (byte indexing with byte load/store).
// Keyed by variable name token; [name_tok(4), elem_size(4)] × 512.
static uint64 arr_elem_table = 0
static uint64 arr_elem_count = 0

// Type alias table: [alias_name_tok(4), target_size(4)] × 64
static uint64 type_alias_table = 0
static uint64 type_alias_count = 0

// Parameter pinning: read-only params pinned to callee-saved registers
// pin_param0_offset = stack offset of pinned param 0 (rbx), 0xFFFFFFFF = not pinned
// pin_param1_offset = stack offset of pinned param 1 (r12), 0xFFFFFFFF = not pinned
static uint64 pin_param0_offset = 0xFFFFFFFF
static uint64 pin_param1_offset = 0xFFFFFFFF
static uint64 pin_param0_tok = 0
static uint64 pin_param1_tok = 0

// Slice parameter length slot table
// Maps a slice param's ptr-slot offset → its len-slot offset.
// Used by FieldAccess to resolve `slice.len` to a load from the len slot.
// Max 32 slice params per function (way more than needed).
// Format: [ptr_off(4), len_off(4)] × 32
static uint64 slice_len_table = 0
static uint64 slice_len_count = 0

// Device block table (MMIO registers)
// Format: [name_tok(4), pad(4), base_addr(8)] × 64  (16 bytes each)
static uint64 device_table = 0
static uint64 device_count = 0
// Device field table
// Format: [dev_idx(4), field_tok(4), offset(4), size(4)] × 256  (16 bytes each)
static uint64 device_field_table = 0
static uint64 device_field_count = 0
// Binary op register spill: use r12 instead of stack for outermost binary op
static uint64 r12_in_use = 0
static uint64 r12_save_slot = 0

@export
fn codegen_init(uint64 capacity, uint64 source, uint64 tokens) {
    out_buf = alloc(capacity)
    out_len = 0
    out_cap = capacity
    cg_source = source
    cg_tokens = tokens
    var_table = alloc(4096 * 8)
    var_count = 0
    fn_table = alloc(1024 * 8)
    fn_count = 0
    fixup_table = alloc(32768 * 8)
    fixup_count = 0
    ret_fixups = alloc(256 * 4)
    ret_fixup_count = 0
    struct_table = alloc(64 * 272)
    struct_count = 0
    struct_var_table = alloc(1024 * 8)
    struct_var_count = 0
    loop_stack = alloc(16 * 16)
    loop_depth = 0
    break_fixups = alloc(256 * 4)
    break_fixup_count = 0
    enum_table = alloc(512 * 16)
    enum_count = 0
    static_table = alloc(1024 * 8)
    static_array_sizes = alloc(1024 * 4)
    static_init_values = alloc(1024 * 8)
    slice_len_table = alloc(32 * 8)
    device_table = alloc(64 * 16)
    device_field_table = alloc(256 * 16)
    extern_fn_table = alloc(256 * 8)
    extern_fn_count = 0
    extern_call_sites = alloc(1024 * 16)
    extern_call_count = 0
    static_count = 0
    static_data_size = 0
    static_fixups = alloc(8192 * 8)
    static_fixup_count = 0
    str_buf = alloc(65536)
    str_len = 0
    str_fixups = alloc(4096 * 8)
    str_fixup_count = 0
    a64_var_base = 32
    win_iat_fixups = alloc(4096 * 8)
    win_iat_fixup_count = 0
    a64_win_iat_fixups = alloc(4096 * 8)
    a64_win_iat_fixup_count = 0
    a64_digit_buf = alloc(32)
    type_alias_table = alloc(64 * 8)
    type_alias_count = 0
    arr_elem_table = alloc(512 * 8)
    arr_elem_count = 0
    fnaddr_fixup_table = alloc(1024 * 8)
    fnaddr_fixup_count = 0
    pin_param0_offset = 0xFFFFFFFF
    pin_param1_offset = 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Emit helpers
// ---------------------------------------------------------------------------

fn emit_byte(uint8 b) {
    if out_len >= out_cap { return }
    uint64 p = out_buf + out_len
    unsafe { *(p as uint8) = b }
    out_len = out_len + 1
}

fn emit_u32_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
    emit_byte(b2)
    emit_byte(b3)
}

fn emit_u64_le(uint64 val) {
    uint64 lo = val & 0xFFFFFFFF
    uint64 hi = (val >> 32) & 0xFFFFFFFF
    emit_u32_le(lo)
    emit_u32_le(hi)
}

fn emit_u16_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
}

fn patch_u32(uint64 offset, uint64 val) {
    uint64 p = out_buf + offset
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = p + 2
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = p + 3
    unsafe { *(p3 as uint8) = b3 }
}

// ---------------------------------------------------------------------------
// Token text helpers
// ---------------------------------------------------------------------------

fn tok_text_start(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_text_len(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_source_byte(uint64 tok_idx, uint64 offset) -> uint64 {
    uint64 start = tok_text_start(tok_idx)
    uint64 p = cg_source + start + offset
    uint64 val = 0
    unsafe { *(p as uint8) -> val }
    return val & 0xFF
}

// Parse integer or char literal from token text
fn parse_int_token(uint64 tok_idx) -> uint64 {
    uint64 len = tok_text_len(tok_idx)
    // Check for boolean keywords: true → 1, false → 0
    if len == 4 && tok_source_byte(tok_idx, 0) == 116 { return 1 }
    if len == 5 && tok_source_byte(tok_idx, 0) == 102 { return 0 }
    // Check for char literal: 'x' or '\n'
    if len >= 3 && tok_source_byte(tok_idx, 0) == 39 {
        if tok_source_byte(tok_idx, 1) == 92 {
            // Escape sequence
            uint64 esc = tok_source_byte(tok_idx, 2)
            if esc == 110 { return 10 }
            if esc == 116 { return 9 }
            if esc == 114 { return 13 }
            if esc == 48 { return 0 }
            if esc == 92 { return 92 }
            if esc == 39 { return 39 }
            return esc
        }
        return tok_source_byte(tok_idx, 1)
    }
    uint64 result = 0
    uint64 i = 0
    // Check for 0x prefix
    if len > 2 && tok_source_byte(tok_idx, 0) == 48 && tok_source_byte(tok_idx, 1) == 120 {
        i = 2
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 16
            if ch >= 48 && ch <= 57 { result = result + ch - 48 }
            if ch >= 97 && ch <= 102 { result = result + ch - 87 }
            if ch >= 65 && ch <= 70 { result = result + ch - 55 }
            i = i + 1
        }
    } else {
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 10 + ch - 48
            i = i + 1
        }
    }
    return result
}

// Compare two token texts for equality
fn tok_text_eq(uint64 tok_a, uint64 tok_b) -> uint64 {
    uint64 la = tok_text_len(tok_a)
    uint64 lb = tok_text_len(tok_b)
    if la != lb { return 0 }
    uint64 i = 0
    while i < la {
        if tok_source_byte(tok_a, i) != tok_source_byte(tok_b, i) { return 0 }
        i = i + 1
    }
    return 1
}

// Check if token text matches a string
fn tok_matches(uint64 tok_idx, uint64 str_ptr, uint64 str_len) -> uint64 {
    uint64 tlen = tok_text_len(tok_idx)
    if tlen != str_len { return 0 }
    uint64 start = tok_text_start(tok_idx)
    uint64 i = 0
    while i < tlen {
        uint64 sp = cg_source + start + i
        uint64 sc = 0
        unsafe { *(sp as uint8) -> sc }
        uint64 kp = str_ptr + i
        uint64 kc = 0
        unsafe { *(kp as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

// ---------------------------------------------------------------------------
// Variable table
// ---------------------------------------------------------------------------

static uint64 var_table_size = 0

fn var_reset() {
    var_count = 0
    var_frame_size = 0
    var_table_size = 0
    arr_elem_count = 0
}

fn var_declare(uint64 name_tok) -> uint64 {
    // Check if variable already declared in this function (handles shadowing)
    uint64 existing = var_lookup(name_tok)
    if existing != 0xFFFFFFFF {
        return existing
    }
    uint64 offset = var_count * 8
    uint64 entry = var_table + var_table_size * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    var_table_size = var_table_size + 1
    var_count = var_count + 1
    var_frame_size = var_count * 8
    // Align frame to 16 bytes
    uint64 rem = var_frame_size & 15
    if rem != 0 {
        var_frame_size = var_frame_size + 16 - rem
    }
    return offset
}

fn var_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < var_table_size {
        uint64 entry = var_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Struct metadata
// ---------------------------------------------------------------------------

// Each struct entry is 16 bytes header + 16 bytes per field = 16 + 16*16 = 272 max
@export
fn struct_register(uint64 name_tok) -> uint64 {
    uint64 base = struct_table + struct_count * 272
    uint32 nt = name_tok
    unsafe { *(base as uint32) = nt }
    // field_count = 0 initially
    uint64 fc_addr = base + 4
    uint32 zero = 0
    unsafe { *(fc_addr as uint32) = zero }
    uint64 idx = struct_count
    struct_count = struct_count + 1
    return idx
}

@export
fn struct_add_field(uint64 struct_idx, uint64 field_tok, uint64 field_size) {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    // Compute field offset = current total_size
    uint64 ts_addr = base + 8
    uint32 ts = 0
    unsafe { *(ts_addr as uint32) -> ts }
    uint64 wts = ts
    // Write field entry at header(16) + field_idx * 16
    uint64 fentry = base + 16 + wfc * 16
    uint32 ft = field_tok
    unsafe { *(fentry as uint32) = ft }
    uint64 fo_addr = fentry + 4
    uint32 fo = wts
    unsafe { *(fo_addr as uint32) = fo }
    uint64 fs_addr = fentry + 8
    uint32 fs = field_size
    unsafe { *(fs_addr as uint32) = fs }
    // Update field_count and total_size
    uint32 new_fc = wfc + 1
    unsafe { *(fc_addr as uint32) = new_fc }
    uint32 new_ts = wts + field_size
    unsafe { *(ts_addr as uint32) = new_ts }
}

fn struct_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < struct_count {
        uint64 base = struct_table + i * 272
        uint32 stored = 0
        unsafe { *(base as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            return i
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn struct_total_size(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 8
    uint32 ts = 0
    unsafe { *(base as uint32) -> ts }
    return ts
}

fn struct_field_offset(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fo_addr = fentry + 4
            uint32 fo = 0
            unsafe { *(fo_addr as uint32) -> fo }
            return fo
        }
        fi = fi + 1
    }
    return 0xFFFFFFFF
}

fn struct_field_size(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fs_addr = fentry + 8
            uint32 fs = 0
            unsafe { *(fs_addr as uint32) -> fs }
            return fs
        }
        fi = fi + 1
    }
    return 0
}

// Track which variables are struct-typed
fn struct_var_register(uint64 var_tok, uint64 struct_idx) {
    uint64 entry = struct_var_table + struct_var_count * 8
    uint32 vt = var_tok
    unsafe { *(entry as uint32) = vt }
    uint64 e4 = entry + 4
    uint32 si = struct_idx
    unsafe { *(e4 as uint32) = si }
    struct_var_count = struct_var_count + 1
}

fn struct_var_lookup(uint64 var_tok) -> uint64 {
    uint64 i = 0
    while i < struct_var_count {
        uint64 entry = struct_var_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, var_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 si = 0
            unsafe { *(e4 as uint32) -> si }
            return si
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Enum value table
// ---------------------------------------------------------------------------

@export
fn enum_register(uint64 enum_tok, uint64 field_tok, uint64 value) {
    uint64 entry = enum_table + enum_count * 16
    uint32 et = enum_tok
    unsafe { *(entry as uint32) = et }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = value }
    enum_count = enum_count + 1
}

fn enum_lookup(uint64 enum_tok, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < enum_count {
        uint64 entry = enum_table + i * 16
        uint32 stored_enum = 0
        unsafe { *(entry as uint32) -> stored_enum }
        uint64 we = stored_enum
        if tok_text_eq(we, enum_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wf = stored_field
            if tok_text_eq(wf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint64 val = 0
                unsafe { *(e8 as uint64) -> val }
                return val
            }
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Static variable table
// ---------------------------------------------------------------------------

@export
fn static_declare(uint64 name_tok) -> uint64 {
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as scalar (0 in array_sizes)
    uint64 ae = static_array_sizes + static_count * 4
    uint32 zero32 = 0
    unsafe { *(ae as uint32) = zero32 }
    // Default initial value = 0
    uint64 iv = static_init_values + static_count * 8
    unsafe { *(iv as uint64) = 0 }
    static_count = static_count + 1
    static_data_size = static_data_size + 8
    return offset
}

// Set the initial 8-byte value for the most recently declared scalar static.
// Called by the parser for `const TYPE name = LITERAL` and `static TYPE name = LITERAL`.
@export
fn static_set_init_last(uint64 value) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 iv = static_init_values + idx * 8
    unsafe { *(iv as uint64) = value }
}

// Device table helpers: device_register returns the new device index.
@export
fn device_register(uint64 name_tok, uint64 base_addr) -> uint64 {
    uint64 entry = device_table + device_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = base_addr }
    uint64 idx = device_count
    device_count = device_count + 1
    return idx
}

@export
fn device_add_field(uint64 dev_idx, uint64 field_tok, uint64 offset, uint64 size) {
    uint64 entry = device_field_table + device_field_count * 16
    uint32 di = dev_idx
    unsafe { *(entry as uint32) = di }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    uint32 off32 = offset
    unsafe { *(e8 as uint32) = off32 }
    uint64 ec = entry + 12
    uint32 sz32 = size
    unsafe { *(ec as uint32) = sz32 }
    device_field_count = device_field_count + 1
}

// Look up device by name_tok. Returns 0xFFFFFFFF if not found.
fn device_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < device_count {
        uint64 entry = device_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Get base address of a device
fn device_base(uint64 dev_idx) -> uint64 {
    uint64 entry = device_table + dev_idx * 16
    uint64 e8 = entry + 8
    uint64 base = 0
    unsafe { *(e8 as uint64) -> base }
    return base
}

// Look up a device field. Returns offset OR 0xFFFFFFFF if not found.
fn device_field_offset_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint32 off = 0
                unsafe { *(e8 as uint32) -> off }
                return off
            }
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn device_field_size_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 ec = entry + 12
                uint32 sz = 0
                unsafe { *(ec as uint32) -> sz }
                return sz
            }
        }
        i = i + 1
    }
    return 0
}

// Record a slice parameter's length slot. Per-function, cleared on function entry.
fn slice_len_register(uint64 ptr_off, uint64 len_off) {
    uint64 entry = slice_len_table + slice_len_count * 8
    uint32 po = ptr_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 lo = len_off
    unsafe { *(e4 as uint32) = lo }
    slice_len_count = slice_len_count + 1
}

// Look up a slice's length slot offset by its ptr slot offset. Returns 0xFFFFFFFF if not a slice.
fn slice_len_lookup(uint64 ptr_off) -> uint64 {
    uint64 i = 0
    while i < slice_len_count {
        uint64 entry = slice_len_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if ws == ptr_off {
            uint64 e4 = entry + 4
            uint32 lo = 0
            unsafe { *(e4 as uint32) -> lo }
            return lo
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

@export
fn static_declare_array(uint64 name_tok, uint64 byte_size) -> uint64 {
    // Align static_data_size up to 8 for clean placement
    uint64 rem = static_data_size & 7
    if rem != 0 { static_data_size = static_data_size + 8 - rem }
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as array by storing byte_size in parallel table
    uint64 ae = static_array_sizes + static_count * 4
    uint32 bs32 = byte_size
    unsafe { *(ae as uint32) = bs32 }
    static_count = static_count + 1
    // Allocate byte_size bytes, padded to 8-byte boundary
    uint64 padded = byte_size
    uint64 brem = byte_size & 7
    if brem != 0 { padded = byte_size + 8 - brem }
    static_data_size = static_data_size + padded
    return offset
}

// Return byte size if name_tok refers to a static array, 0 if scalar, 0xFFFFFFFF if not found
fn static_array_size_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 ae = static_array_sizes + i * 4
            uint32 sz = 0
            unsafe { *(ae as uint32) -> sz }
            return sz
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn static_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Look up a static by literal name (for generated code, not user code)
fn static_lookup_by_name(uint64 name_str, uint64 name_len) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_matches(ws, name_str, name_len) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Type alias table
// ---------------------------------------------------------------------------

@export
fn type_alias_register(uint64 name_tok, uint64 target_size) {
    uint64 entry = type_alias_table + type_alias_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ts = target_size
    unsafe { *(e4 as uint32) = ts }
    type_alias_count = type_alias_count + 1
}

@export
fn type_alias_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < type_alias_count {
        uint64 entry = type_alias_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ts = 0
            unsafe { *(e4 as uint32) -> ts }
            return ts
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Map a type keyword token (u8..u64 / i8..i64 / uint8..uint64) to its byte size.
// Default 1 (byte) for anything else, so legacy u8 arrays keep working.
fn type_tok_elem_size(uint64 type_tok) -> uint64 {
    uint64 p = cg_tokens + type_tok * 16
    uint32 k = 0
    unsafe { *(p as uint32) -> k }
    uint64 wk = k
    if wk == 80 { return 1 }
    if wk == 81 { return 2 }
    if wk == 82 { return 4 }
    if wk == 83 { return 8 }
    if wk == 84 { return 1 }
    if wk == 85 { return 2 }
    if wk == 86 { return 4 }
    if wk == 87 { return 8 }
    return 1
}

// Register a local array's element size so that index ops can scale correctly.
fn arr_elem_register(uint64 name_tok, uint64 elem_size) {
    uint64 entry = arr_elem_table + arr_elem_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 es = elem_size
    unsafe { *(e4 as uint32) = es }
    arr_elem_count = arr_elem_count + 1
}

// Look up a local array's element size. Returns 1 (byte) if not registered,
// which keeps byte-indexed code paths (raw alloc, static byte arrays) unchanged.
fn arr_elem_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < arr_elem_count {
        uint64 entry = arr_elem_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 es = 0
            unsafe { *(e4 as uint32) -> es }
            return es
        }
        i = i + 1
    }
    return 1
}

// Emit: load static at data_offset into rax (RIP-relative, placeholder)
fn emit_static_load(uint64 data_offset) {
    // mov disp32(%rip), %rax → 48 8B 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8B)
    emit_byte(0x05)
    // Record fixup: patch this disp32 later
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Emit: lea rax, [rip + disp32] — RIP-relative address of a static
// Used for static arrays to put the address of the data in rax.
fn emit_static_lea(uint64 data_offset) {
    // lea rax, [rip + disp32] → 48 8D 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8D)
    emit_byte(0x05)
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
    // Invalidate the rax cache: rax now holds a static address, not [rsp+*]
    rax_cache = 0
}

// Emit: store rax to static at data_offset (RIP-relative, placeholder)
fn emit_static_store(uint64 data_offset) {
    // mov %rax, disp32(%rip) → 48 89 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    // Record fixup
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Resolve all static RIP-relative fixups. Call after all code is emitted.
// data_start = out_len at the time statics are placed.
@export
fn resolve_static_fixups(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        // RIP = code_off + 4 (past the disp32 bytes)
        // target = data_start + data_off
        // disp = target - RIP
        uint64 rip = code_off + 4
        uint64 wdo = data_off
        uint64 target = data_start + wdo
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit string literal data
@export
fn emit_string_data() {
    uint64 i = 0
    while i < str_len {
        uint64 sp = str_buf + i
        uint8 b = 0
        unsafe { *(sp as uint8) -> b }
        emit_byte(b)
        i = i + 1
    }
}

// Resolve string literal RIP-relative fixups
@export
fn resolve_string_fixups(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 rip = code_off + 4
        uint64 wso = str_off
        uint64 target = str_data_start + wso
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit zero-initialized data for all statics
@export
fn emit_static_data() {
    // Walk the static table in declaration order. Scalar slots (array_size==0)
    // get their recorded init value; array slots stay zero.
    uint64 emitted = 0
    uint64 si = 0
    while si < static_count {
        // offset of this slot within the static data segment
        uint64 entry = static_table + si * 8
        uint64 e4 = entry + 4
        uint32 slot_off = 0
        unsafe { *(e4 as uint32) -> slot_off }
        // Pad with zeros up to this slot's offset
        while emitted < slot_off {
            emit_byte(0)
            emitted = emitted + 1
        }
        uint64 asp = static_array_sizes + si * 4
        uint32 asz = 0
        unsafe { *(asp as uint32) -> asz }
        if asz == 0 {
            // Scalar: 8 bytes of init value
            uint64 ivp = static_init_values + si * 8
            uint64 val = 0
            unsafe { *(ivp as uint64) -> val }
            uint64 bi = 0
            while bi < 8 {
                uint8 b = (val >> (bi * 8)) & 0xFF
                emit_byte(b)
                bi = bi + 1
            }
            emitted = emitted + 8
        } else {
            // Array: emit `asz` zero bytes
            uint64 ai = 0
            while ai < asz {
                emit_byte(0)
                ai = ai + 1
            }
            emitted = emitted + asz
        }
        si = si + 1
    }
    // Final tail of zeros (alignment/padding)
    while emitted < static_data_size {
        emit_byte(0)
        emitted = emitted + 1
    }
}

// ---------------------------------------------------------------------------
// Function table
// ---------------------------------------------------------------------------

fn fn_register(uint64 name_tok, uint64 code_offset) {
    uint64 entry = fn_table + fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 co = code_offset
    unsafe { *(e4 as uint32) = co }
    fn_count = fn_count + 1
}

fn fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_count {
        uint64 entry = fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Register an extern function. Returns its extern index for later use.
@export
fn extern_fn_register(uint64 name_tok) -> uint64 {
    uint64 idx = extern_fn_count
    uint64 entry = extern_fn_table + extern_fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    extern_fn_count = extern_fn_count + 1
    return idx
}

// Return the extern index for a given name_tok, or 0xFFFFFFFF if not extern.
@export
fn extern_fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < extern_fn_count {
        uint64 entry = extern_fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Record an extern call site for later relocation emission.
// code_off is the byte offset inside the .text section:
//   x86_64: the start of the 4-byte disp32 (call site + 1)
//   ARM64:  the start of the BL instruction
fn extern_call_record(uint64 code_off, uint64 extern_idx) {
    uint64 entry = extern_call_sites + extern_call_count * 16
    uint32 co = code_off
    unsafe { *(entry as uint32) = co }
    uint64 e4 = entry + 4
    uint32 xi = extern_idx
    unsafe { *(e4 as uint32) = xi }
    extern_call_count = extern_call_count + 1
}

// ---------------------------------------------------------------------------
// x86_64 code emission
// ---------------------------------------------------------------------------

// emit: mov rax, imm64
fn emit_mov_rax_imm(uint64 val) {
    rax_invalidate()
    if val == 0 {
        // xor eax, eax (2 bytes, zero-extends to rax)
        emit_byte(0x31)
        emit_byte(0xC0)
        return
    }
    if val <= 0x7FFFFFFF {
        // mov eax, imm32 (5 bytes, zero-extends)
        emit_byte(0xB8)
        emit_u32_le(val)
    } else {
        // movabs rax, imm64 (10 bytes)
        emit_byte(0x48)
        emit_byte(0xB8)
        emit_u64_le(val)
    }
}

// emit: mov [rsp+off], rax
// Register cache: tracks if rax already holds a stack slot value
// rax_cache = 0 means not cached, rax_cache = offset+1 means rax holds [rsp+offset]
static uint64 rax_cache = 0

fn rax_invalidate() {
    rax_cache = 0
}

fn emit_store_rax_to_stack(uint64 offset) {
    emit_byte(0x48)
    emit_byte(0x89)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    // After store, rax still holds the value for this offset
    rax_cache = offset + 1
}

// emit: mov rax, [rsp+off] — skipped if rax already holds this value
fn emit_load_rax_from_stack(uint64 offset) {
    // Pinned param0: use rbx instead of stack
    if offset == pin_param0_offset && pin_param0_offset != 0xFFFFFFFF {
        if rax_cache == offset + 1 { return }
        // mov rax, rbx (48 89 D8)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xD8)
        rax_cache = offset + 1
        return
    }
    // Check cache: if rax already holds [rsp+offset], skip the load
    if rax_cache == offset + 1 { return }
    emit_byte(0x48)
    emit_byte(0x8B)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    rax_cache = offset + 1
}

// emit: push rax
fn emit_push_rax() {
    rax_invalidate()
    emit_byte(0x50)
}

// emit: pop rcx
fn emit_pop_rcx() {
    emit_byte(0x59)
}

// emit: add rax, rcx
fn emit_add_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x01)
    emit_byte(0xC8)
}

// emit: sub rax, rcx  (rax = rax - rcx)
fn emit_sub_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x29)
    emit_byte(0xC8)
}

// emit: imul rax, rcx
fn emit_mul_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x0F)
    emit_byte(0xAF)
    emit_byte(0xC1)
}

// emit: mov rdi, rax (first arg)
fn emit_mov_rdi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC7)
}

// emit: mov rsi, rax (second arg)
fn emit_mov_rsi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC6)
}

// emit: mov rdx, rax (third arg)
fn emit_mov_rdx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC2)
}

// ---------------------------------------------------------------------------
// Windows x64 ABI helpers
// ---------------------------------------------------------------------------

fn win_fixup_add(uint64 patch_off, uint64 slot) {
    uint64 entry = win_iat_fixups + win_iat_fixup_count * 8
    uint32 po = patch_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 sl = slot
    unsafe { *(e4 as uint32) = sl }
    win_iat_fixup_count = win_iat_fixup_count + 1
}

// sub rsp, N for Windows API calls (N must keep RSP 16-byte aligned)
// After prologue (push rbx + sub rsp, frame), RSP is 16-aligned
// So we need N divisible by 16 for alignment
// Use 0x20 (32) for <=4 args, 0x30 (48) for 5 args, 0x40 (64) for 7 args
fn emit_win_alloc_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xEC)
    uint8 nb = nbytes
    emit_byte(nb)
}

fn emit_win_free_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xC4)
    uint8 nb = nbytes
    emit_byte(nb)
}

// mov rcx, rax (Windows 1st arg)
fn emit_mov_rcx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC1)
}

// mov r8, rax (Windows 3rd arg)
fn emit_mov_r8_rax() {
    emit_byte(0x49)
    emit_byte(0x89)
    emit_byte(0xC0)
}

// mov r9, imm32 (sign-extended, Windows 4th arg)
fn emit_mov_r9_imm(uint64 val) {
    emit_byte(0x49)
    emit_byte(0xC7)
    emit_byte(0xC1)
    emit_u32_le(val)
}

// call qword [rip + disp32] — IAT indirect call
// All 13 entries are loader-resolved; slot 0-12 maps directly to IAT[0..12]
fn emit_win_call_iat(uint64 slot) {
    rax_invalidate()
    emit_byte(0xFF)
    emit_byte(0x15)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// mov [rip + disp32], rax — store resolved fn ptr to IAT slot
fn emit_win_store_iat(uint64 slot) {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// Helper: add a null-terminated string to str_buf, return its offset
fn resolver_add_str(uint64 s) -> uint64 {
    uint64 soff = str_len
    uint64 i = 0
    uint64 p = s + i
    uint64 ch = 0
    unsafe { *(p as uint8) -> ch }
    while ch != 0 {
        uint8 cb = ch
        uint64 dp = str_buf + str_len
        unsafe { *(dp as uint8) = cb }
        str_len = str_len + 1
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> ch }
    }
    uint64 dp = str_buf + str_len
    uint8 nz = 0
    unsafe { *(dp as uint8) = nz }
    str_len = str_len + 1
    return soff
}

// Helper: emit lea rdx, [rip+disp32] with string fixup
fn emit_lea_rdx_str(uint64 str_offset) {
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x15)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// Helper: emit lea rcx, [rip+disp32] with string fixup
fn emit_lea_rcx_str(uint64 str_offset) {
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x0D)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// neg rax
fn emit_neg_rax() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0xF7)
    emit_byte(0xD8)
}

// sub rax, imm8
fn emit_sub_rax_imm8(uint64 val) {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xE8)
    uint8 b = val
    emit_byte(b)
}

// mov [rsp+32], imm32 (5th arg on stack for Windows calls)
fn emit_win_stack_arg5(uint64 val) {
    emit_byte(0x48)
    emit_byte(0xC7)
    emit_byte(0x44)
    emit_byte(0x24)
    emit_byte(0x20)
    emit_u32_le(val)
}

// Resolve Windows IAT fixups: patch call [rip+disp32] with correct displacement
// text_start: offset of code within file, iat_rva: RVA of IAT in .idata section
@export
fn resolve_win_iat_fixups(uint64 text_start, uint64 iat_rva) {
    // PE image base = 0x140000000, text section RVA = 0x1000
    // Code at file offset text_start corresponds to RVA 0x1000
    // So code at file offset X has RVA = 0x1000 + (X - text_start)
    // RIP at end of call instruction = RVA of byte after the disp32
    // Target = iat_rva + slot * 8
    // disp32 = target_rva - rip_rva
    uint64 i = 0
    while i < win_iat_fixup_count {
        uint64 entry = win_iat_fixups + i * 8
        uint32 patch_off = 0
        unsafe { *(entry as uint32) -> patch_off }
        uint64 e4 = entry + 4
        uint32 slot = 0
        unsafe { *(e4 as uint32) -> slot }
        uint64 wpatch = patch_off
        uint64 wslot = slot
        // RIP at end of this instruction = RVA of (patch_off + 4)
        uint64 rip_rva = 0x1000 + (wpatch + 4 - text_start)
        uint64 target_rva = iat_rva + wslot * 8
        // disp32 = target_rva - rip_rva (signed 32-bit)
        uint64 disp = target_rva - rip_rva
        patch_u32(wpatch, disp & 0xFFFFFFFF)
        i = i + 1
    }
}

// emit: setCC al + movzx eax, al (flags already set by caller)
fn emit_setcc(uint64 op_tok_kind) {
    emit_byte(0x0F)
    if op_tok_kind == 35 { emit_byte(0x94) }
    else if op_tok_kind == 36 { emit_byte(0x95) }
    else if op_tok_kind == 37 { emit_byte(0x92) }
    else if op_tok_kind == 38 { emit_byte(0x96) }
    else if op_tok_kind == 39 { emit_byte(0x97) }
    else if op_tok_kind == 40 { emit_byte(0x93) }
    else { emit_byte(0x94) }
    emit_byte(0xC0)
    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0) // movzx eax, al
}

// emit: cmp rax, rcx + setCC al + movzx eax, al
fn emit_compare(uint64 op_tok_kind) {
    rax_invalidate()
    // cmp rax, rcx
    emit_byte(0x48)
    emit_byte(0x39)
    emit_byte(0xC8)

    emit_setcc(op_tok_kind)
}


// ---------------------------------------------------------------------------
// AST code generation (recursive)
// ---------------------------------------------------------------------------

// Generate code for an expression. Result is in %rax.
@export
fn gen_expr(uint64 node) {
    // Invalidate rax cache — gen_expr will put a new value in rax
    rax_invalidate()
    uint32 kind = ast_kind(node)

    // Unary operator: !, -, ~
    if kind == 34 {
        uint32 operand_idx = ast_child(node)
        uint64 wop = operand_idx
        gen_expr(wop)
        // Determine op from token kind
        uint32 op_tok = ast_data1(node)
        uint64 wot = op_tok
        uint64 p = cg_tokens + wot * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }
        uint64 wok = op_kind
        if wok == 27 {
            // ! logical NOT: test rax, rax; sete al; movzbl al, eax
            emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        } else if wok == 31 {
            // - negate: neg rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD8)
        } else if wok == 26 {
            // ~ bitwise NOT: not rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD0)
        }
        return
    }

    // Integer literal → mov rax, value
    if kind == 30 {
        uint32 tok = ast_data1(node)
        uint64 val = parse_int_token(tok)
        emit_mov_rax_imm(val)
        return
    }

    // String literal → store bytes in str_buf, emit LEA rip-relative
    if kind == 31 {
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tstart = tok_text_start(wtok)
        uint64 tlen = tok_text_len(wtok)
        // String data offset in str_buf
        uint64 str_offset = str_len
        // Copy string bytes (skip opening quote, process escapes, skip closing quote)
        uint64 si = 1
        while si < tlen - 1 {
            uint64 ch = tok_source_byte(wtok, si)
            if ch == 92 {
                si = si + 1
                uint64 esc = tok_source_byte(wtok, si)
                if esc == 110 { ch = 10 }
                else if esc == 116 { ch = 9 }
                else if esc == 114 { ch = 13 }
                else if esc == 48 { ch = 0 }
                else if esc == 92 { ch = 92 }
                else if esc == 34 { ch = 34 }
                else { ch = esc }
            }
            uint64 sp = str_buf + str_len
            uint8 cb = ch
            unsafe { *(sp as uint8) = cb }
            str_len = str_len + 1
            si = si + 1
        }
        // Null-terminate
        uint64 sp = str_buf + str_len
        uint8 zero = 0
        unsafe { *(sp as uint8) = zero }
        str_len = str_len + 1
        // Emit: lea disp32(%rip), %rax → 48 8D 05 [disp32]
        emit_byte(0x48)
        emit_byte(0x8D)
        emit_byte(0x05)
        // Record fixup
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        emit_u32_le(0)
        return
    }

    // Array indexing: arr[i] → load elem_size bytes from base + i*elem_size
    if kind == 37 {
        uint32 arr_tok = ast_data1(node)
        uint64 warrt = arr_tok
        uint64 arr_offset = var_lookup(arr_tok)
        uint64 elem_sz = arr_elem_lookup(arr_tok)
        // Evaluate index expression
        uint32 idx_child = ast_child(node)
        uint64 wi = idx_child
        gen_expr(wi)
        // mov rcx, rax (save index)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
        if arr_offset != 0xFFFFFFFF {
            emit_load_rax_from_stack(arr_offset)
        } else {
            uint64 sas = static_array_size_of(warrt)
            if sas != 0xFFFFFFFF && sas != 0 {
                uint64 soff_a = static_lookup(warrt)
                emit_static_lea(soff_a)
            } else {
                arr_offset = 0
                emit_load_rax_from_stack(arr_offset)
            }
        }
        // rax = base, rcx = index. Load with scaled SIB addressing.
        // SIB byte = (log2(scale) << 6) | (1 << 3) | 0  where index=rcx, base=rax
        //   scale 1 → 0x08, scale 2 → 0x48, scale 4 → 0x88, scale 8 → 0xC8
        uint8 sib = 0x08
        if elem_sz == 2 { sib = 0x48 }
        if elem_sz == 4 { sib = 0x88 }
        if elem_sz == 8 { sib = 0xC8 }
        if elem_sz == 1 {
            // movzbl (%rax,%rcx,1), %eax
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 2 {
            // movzwl (%rax,%rcx,2), %eax
            emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 4 {
            // movl (%rax,%rcx,4), %eax  (zero-extends to rax)
            emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        } else {
            // movq (%rax,%rcx,8), %rax
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        }
        return
    }

    // Field access: EnumName.Field (enum constant) or var.field (struct field read)
    // Also: arr[i].field for struct arrays.
    if kind == 36 {
        uint32 child_idx = ast_child(node)
        uint64 wchild = child_idx
        uint32 field_tok = ast_data2(node)
        // Struct array element field read: child is an Index node
        if wchild != 0 {
            uint32 cfk = ast_kind(wchild)
            uint64 wcfk = cfk
            if wcfk == 37 {
                uint32 ai_tok = ast_data1(wchild)
                uint64 wait = ai_tok
                uint64 sia = struct_var_lookup(ai_tok)
                if sia != 0xFFFFFFFF {
                    // Compute struct stride and field offset
                    uint64 stride = struct_total_size(sia)
                    uint64 foff_i = struct_field_offset(sia, field_tok)
                    uint64 fsz_i = struct_field_size(sia, field_tok)
                    // Evaluate index into rax
                    uint32 idx_ch = ast_child(wchild)
                    uint64 widx = idx_ch
                    gen_expr(widx)
                    // rax = index. Multiply by stride: mov rcx, stride; mul rcx → rax*rcx
                    emit_mov_rcx_rax()
                    // Load stride imm into rax
                    emit_mov_rax_imm(stride)
                    // imul rax, rcx (48 0F AF C1)
                    emit_byte(0x48); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xC1)
                    // Save offset-into-array to rcx
                    emit_mov_rcx_rax()
                    // Load base address of the array
                    uint64 aoff = var_lookup(wait)
                    if aoff != 0xFFFFFFFF {
                        emit_load_rax_from_stack(aoff)
                    }
                    // rax = base, rcx = i*stride. addr = base + rcx + foff_i
                    emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8) // add rax, rcx
                    if foff_i != 0 {
                        emit_byte(0x48); emit_byte(0x05)
                        emit_u32_le(foff_i)
                    }
                    // Load field value based on size
                    if fsz_i == 1 {
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if fsz_i == 2 {
                        emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if fsz_i == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    return
                }
            }
        }
        // Extract object token from child Ident node
        uint32 obj_tok = 0
        if wchild != 0 {
            uint32 child_kind = ast_kind(wchild)
            uint64 wck = child_kind
            if wck == 32 {
                obj_tok = ast_data1(wchild)
            }
        }
        // Slice length access: slice_var.len → load from the slice's length slot
        if obj_tok != 0 {
            uint64 wot_sl = obj_tok
            uint64 ptr_off_sl = var_lookup(wot_sl)
            if ptr_off_sl != 0xFFFFFFFF {
                uint64 len_off_sl = slice_len_lookup(ptr_off_sl)
                if len_off_sl != 0xFFFFFFFF {
                    // Confirm the field name is "len"
                    uint64 wft_sl = field_tok
                    if tok_matches(wft_sl, "len", 3) != 0 {
                        emit_load_rax_from_stack(len_off_sl)
                        return
                    }
                }
            }
        }
        // Device field read: UART0.Data → vloadN(base + offset)
        if obj_tok != 0 {
            uint64 wdt = obj_tok
            uint64 dev_idx = device_lookup(wdt)
            if dev_idx != 0xFFFFFFFF {
                uint64 wft_d = field_tok
                uint64 dev_off = device_field_offset_of(dev_idx, wft_d)
                if dev_off != 0xFFFFFFFF {
                    uint64 dev_sz = device_field_size_of(dev_idx, wft_d)
                    uint64 dev_addr = device_base(dev_idx) + dev_off
                    // rax = address
                    emit_mov_rax_imm(dev_addr)
                    // volatile load width-aware + mfence
                    if dev_sz == 1 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if dev_sz == 2 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if dev_sz == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    // mfence (barrier after load)
                    emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
                    rax_cache = 0
                    return
                }
            }
        }
        // Check if obj_tok is a struct variable
        uint64 si = struct_var_lookup(obj_tok)
        if si != 0xFFFFFFFF {
            // Struct field read: load base + field_offset
            uint64 var_off = var_lookup(obj_tok)
            if var_off == 0xFFFFFFFF { var_off = 0 }
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 fsz = struct_field_size(si, field_tok)
            // Load struct base address
            emit_load_rax_from_stack(var_off)
            // Add field offset
            if foff != 0 {
                emit_byte(0x48); emit_byte(0x05)
                emit_u32_le(foff)
            }
            // Load field value based on size
            if fsz == 1 {
                emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
            } else if fsz == 4 {
                emit_byte(0x8B); emit_byte(0x00)
            } else {
                emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
            }
            return
        }
        // Enum constant
        uint64 val = enum_lookup(obj_tok, field_tok)
        emit_mov_rax_imm(val)
        return
    }

    // Identifier → load from stack variable or static
    if kind == 32 {
        uint32 tok = ast_data1(node)
        uint64 wident_tok = tok
        uint64 offset = var_lookup(tok)
        if offset != 0xFFFFFFFF {
            emit_load_rax_from_stack(offset)
        } else {
            uint64 soff = static_lookup(tok)
            if soff != 0xFFFFFFFF {
                // Static array: emit LEA (address). Scalar: emit MOV (value).
                uint64 sas_i = static_array_size_of(wident_tok)
                if sas_i != 0xFFFFFFFF && sas_i != 0 {
                    emit_static_lea(soff)
                } else {
                    emit_static_load(soff)
                }
            } else {
                uint64 id_len = tok_text_len(tok)
                if id_len != 0 {
                    write(2, "error: use of undeclared identifier '", 37)
                    write(2, cg_source + tok_text_start(tok), id_len)
                    write(2, "'\n", 2)
                    exit(1)
                }
            }
        }
        return
    }

    // Binary operation: lhs OP rhs
    // Evaluate lhs first into rax, save to a fresh temp slot,
    // then evaluate rhs into rax, move to rcx, restore lhs.
    if kind == 33 {
        // Constant folding: if both operands are IntLit, compute at compile time
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cf = ast_data2(node)
        uint64 wrhs_cf = rhs_idx_cf
        uint32 lhs_kind = ast_kind(wlhs)
        uint32 rhs_kind = ast_kind(wrhs_cf)
        if lhs_kind == 30 && rhs_kind == 30 {
            uint32 l_tok = ast_data1(wlhs)
            uint32 r_tok = ast_data1(wrhs_cf)
            uint64 lv = parse_int_token(l_tok)
            uint64 rv = parse_int_token(r_tok)
            uint32 op_tok_cf = ast_data1(node)
            uint64 wop_cf = op_tok_cf
            uint64 pcf = cg_tokens + wop_cf * 16
            uint32 op_cf = 0
            unsafe { *(pcf as uint32) -> op_cf }
            uint64 result = 0
            if op_cf == 30 { result = lv + rv }
            else if op_cf == 31 { result = lv - rv }
            else if op_cf == 22 { result = lv * rv }
            else if op_cf == 32 { if rv != 0 { result = lv / rv } }
            else if op_cf == 33 { if rv != 0 { result = lv - lv / rv * rv } }
            else if op_cf == 23 { result = lv & rv }
            else if op_cf == 24 { result = lv | rv }
            else if op_cf == 25 { result = lv ^ rv }
            else if op_cf == 43 { result = lv << rv }
            else if op_cf == 44 { result = lv >> rv }
            emit_mov_rax_imm(result)
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_check = ast_kind(wrhs)
        uint64 wrk = rhs_kind_check
        uint32 lhs_kind_check = ast_kind(wlhs)
        uint64 wlk = lhs_kind_check

        // Fast path: pinned_param ± IntLit → lea rax, [rbx ± imm]
        // Eliminates 5 instructions (mov+mov+mov+xchg+op → lea)
        uint64 used_lea = 0
        if wlk == 32 && wrk == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok = ast_data1(wlhs)
            uint64 loff = var_lookup(lhs_tok)
            if loff == pin_param0_offset {
                uint32 op_tok_lea = ast_data1(node)
                uint64 opl = cg_tokens + op_tok_lea * 16
                uint32 opk_lea = 0
                unsafe { *(opl as uint32) -> opk_lea }
                if opk_lea == 30 || opk_lea == 31 {
                    // Parse the integer literal
                    uint32 rhs_tok = ast_data1(wrhs)
                    uint64 imm_val = parse_int_token(rhs_tok)
                    uint64 disp = imm_val
                    if opk_lea == 31 { disp = 0 - imm_val }
                    // lea rax, [rbx + disp8]: 48 8D 43 <disp8>
                    uint8 d8 = disp
                    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x43); emit_byte(d8)
                    rax_cache = 0
                    used_lea = 1
                }
            }
        }

        if used_lea != 0 {
            // LEA already computed the result — skip all expression evaluation
        } else if wrk == 30 || wrk == 32 {
            // Simple RHS: skip stack temp
            gen_expr(wlhs)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            rax_cache = 0
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x87); emit_byte(0xC1)
            rax_cache = 0
        } else if r12_in_use == 0 {
            // Complex RHS: hold lhs in r12 (callee-saved, survives calls)
            gen_expr(wlhs)
            r12_in_use = 1
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC4) // mov r12, rax
            rax_cache = 0
            gen_expr(wrhs)
            r12_in_use = 0
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1) // mov rcx, rax
            emit_byte(0x4C); emit_byte(0x89); emit_byte(0xE0) // mov rax, r12
            rax_cache = 0
        } else {
            // r12 in use (nested): fall back to stack
            gen_expr(wlhs)
            uint64 binop_temp = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 brem = var_frame_size & 15
            if brem != 0 { var_frame_size = var_frame_size + 16 - brem }
            emit_store_rax_to_stack(binop_temp)
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_load_rax_from_stack(binop_temp)
        }

        // Determine operation from token kind (skip if LEA already computed)
        if used_lea == 0 {
        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        if op_kind == 30 { emit_add_rax_rcx() }         // +
        else if op_kind == 31 { emit_sub_rax_rcx() }    // -
        else if op_kind == 22 { emit_mul_rax_rcx() }    // *
        else if op_kind == 32 {
            // / division: rax / rcx
            // xor rdx, rdx; div rcx → quotient in rax
            emit_byte(0x48)
            emit_byte(0x31)
            emit_byte(0xD2)
            emit_byte(0x48)
            emit_byte(0xF7)
            emit_byte(0xF1)
        }
        else if op_kind == 33 {
            // % modulo: rax % rcx
            // xor rdx, rdx; div rcx → remainder in rdx; mov rax, rdx
            emit_byte(0x48)
            emit_byte(0x31)
            emit_byte(0xD2)
            emit_byte(0x48)
            emit_byte(0xF7)
            emit_byte(0xF1)
            emit_byte(0x48)
            emit_byte(0x89)
            emit_byte(0xD0)
        }
        else if op_kind == 23 {
            // & bitwise AND: and rcx, rax
            emit_byte(0x48)
            emit_byte(0x21)
            emit_byte(0xC8)
        }
        else if op_kind == 24 {
            // | bitwise OR: or rcx, rax
            emit_byte(0x48)
            emit_byte(0x09)
            emit_byte(0xC8)
        }
        else if op_kind == 25 {
            // ^ bitwise XOR: xor rcx, rax
            emit_byte(0x48)
            emit_byte(0x31)
            emit_byte(0xC8)
        }
        else if op_kind == 43 {
            // << shift left: shl cl, rax (cl = low byte of rcx)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE0)
        }
        else if op_kind == 44 {
            // >> shift right: shr cl, rax
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE8)
        }
        // Compound assignment ops (desugared by parser: x += y → x = x + y)
        else if op_kind == 45 { emit_add_rax_rcx() }         // +=
        else if op_kind == 46 { emit_sub_rax_rcx() }         // -=
        else if op_kind == 47 { emit_mul_rax_rcx() }         // *=
        else if op_kind == 50 {
            emit_byte(0x48); emit_byte(0x21); emit_byte(0xC8) // &=
        }
        else if op_kind == 51 {
            emit_byte(0x48); emit_byte(0x09); emit_byte(0xC8) // |=
        }
        else if op_kind == 52 {
            emit_byte(0x48); emit_byte(0x31); emit_byte(0xC8) // ^=
        }
        } // end if used_lea == 0
        return
    }

    // Comparison: lhs CMP rhs → 0 or 1 in rax
    if kind == 38 {
        // Constant comparison folding
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cc = ast_data2(node)
        uint64 wrhs_cc = rhs_idx_cc
        uint32 lk_cc = ast_kind(wlhs)
        uint32 rk_cc = ast_kind(wrhs_cc)
        if lk_cc == 30 && rk_cc == 30 {
            uint32 lt_cc = ast_data1(wlhs)
            uint32 rt_cc = ast_data1(wrhs_cc)
            uint64 lvc = parse_int_token(lt_cc)
            uint64 rvc = parse_int_token(rt_cc)
            uint32 op_cc = ast_data1(node)
            uint64 pcc = cg_tokens + op_cc * 16
            uint32 okcc = 0
            unsafe { *(pcc as uint32) -> okcc }
            uint64 res = 0
            if okcc == 35 { if lvc == rvc { res = 1 } }
            else if okcc == 36 { if lvc != rvc { res = 1 } }
            else if okcc == 37 { if lvc < rvc { res = 1 } }
            else if okcc == 38 { if lvc <= rvc { res = 1 } }
            else if okcc == 39 { if lvc > rvc { res = 1 } }
            else if okcc == 40 { if lvc >= rvc { res = 1 } }
            emit_mov_rax_imm(res)
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_cmp = ast_kind(wrhs)
        uint64 wrk_cmp = rhs_kind_cmp
        uint32 lhs_kind_cmp2 = ast_kind(wlhs)
        uint64 wlk_cmp = lhs_kind_cmp2

        // Fast path: cmp pinned_param, imm → cmp rbx, imm8
        uint64 used_direct_cmp = 0
        if wlk_cmp == 32 && wrk_cmp == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok_c = ast_data1(wlhs)
            uint64 loff_c = var_lookup(lhs_tok_c)
            if loff_c == pin_param0_offset {
                uint32 rhs_tok_c = ast_data1(wrhs)
                uint64 cmp_imm = parse_int_token(rhs_tok_c)
                // cmp rbx, imm8: 48 83 FB <imm8>
                if cmp_imm < 128 {
                    uint8 ci8 = cmp_imm
                    emit_byte(0x48); emit_byte(0x83); emit_byte(0xFB); emit_byte(ci8)
                    used_direct_cmp = 1
                }
            }
        }

        if used_direct_cmp != 0 {
            // Direct cmp already emitted — skip expression evaluation
