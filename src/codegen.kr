            emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
            // inc rdx
            emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC2)
            // jmp loop (near backward)
            emit_byte(0xE9)
            uint64 se_back = se_loop - out_len - 4
            emit_u32_le(se_back)
            // not_equal: xor eax, eax (return 0)
            uint64 se_ne = out_len
            uint64 se_ne_disp = se_ne - se_jne_patch - 4
            patch_u32(se_jne_patch, se_ne_disp)
            emit_byte(0x31); emit_byte(0xC0)
            // jmp end (near, 4-byte displacement)
            emit_byte(0xE9)
            uint64 se_jmp_end = out_len
            emit_u32_le(0)
            // equal: mov eax, 1 (return 1)
            uint64 se_eq = out_len
            uint64 se_eq_disp = se_eq - se_jz_patch - 4
