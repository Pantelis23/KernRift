            return
        }

        // Built-in: syscall_raw(nr, a0, a1, a2, a3, a4, a5) → raw syscall
        if is_extern_call == 0 && tok_matches(wct, "syscall_raw", 11) != 0 {
            rax_invalidate()
            // Evaluate all 7 args into temp slots
            uint32 sc_arg = ast_child(node)
            uint64 sc_warg = sc_arg
            uint64 sc_base = var_count * 8
            uint64 sc_i = 0
            while sc_i < 7 {
                var_count = var_count + 1
                sc_i = sc_i + 1
            }
            var_frame_size = var_count * 8
            uint64 sc_rem = var_frame_size & 15
            if sc_rem != 0 { var_frame_size = var_frame_size + 16 - sc_rem }
            sc_i = 0
            while sc_warg != 0 {
                gen_expr(sc_warg)
                emit_store_rax_to_stack(sc_base + sc_i * 8)
                sc_i = sc_i + 1
                uint32 sc_nxt = ast_next(sc_warg)
                sc_warg = sc_nxt
            }
            // Load: a5->r9, a4->r8, a3->r10, a2->rdx, a1->rsi, a0->rdi, nr->rax
            emit_load_rax_from_stack(sc_base + 48)
            // mov r9, rax (49 89 C1)
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC1)
            emit_load_rax_from_stack(sc_base + 40)
            // mov r8, rax (49 89 C0)
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC0)
            emit_load_rax_from_stack(sc_base + 32)
            // mov r10, rax (49 89 C2)
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC2)
            emit_load_rax_from_stack(sc_base + 24)
            emit_mov_rdx_rax()
            emit_load_rax_from_stack(sc_base + 16)
            emit_mov_rsi_rax()
            emit_load_rax_from_stack(sc_base + 8)
            emit_mov_rdi_rax()
            // nr -> rax
            emit_load_rax_from_stack(sc_base)
            // syscall (0F 05)
            emit_byte(0x0F); emit_byte(0x05)
            // Result is in rax
            return
        }

        // Built-in: get_arch_id() → compile-time arch ID
        if is_extern_call == 0 && tok_matches(wct, "get_arch_id", 11) != 0 {
            if target_os == 2 {
                emit_mov_rax_imm(3)
            } else if target_os == 1 {
                emit_mov_rax_imm(5)
            } else {
                emit_mov_rax_imm(1)
            }
            return
        }

        // Built-in: time_ms() → monotonic millisecond counter.
        // Linux x86_64: clock_gettime(CLOCK_MONOTONIC, &ts) via syscall 228.
        // Other targets: return 0 (no portable timer yet).
        if is_extern_call == 0 && tok_matches(wct, "time_ms", 7) != 0 {
            if target_os == 0 {
                // Reserve a 16-byte timespec on the stack and pass rsp as &ts.
                // sub rsp, 16
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(16)
                // mov edi, 1   (CLOCK_MONOTONIC)
                emit_byte(0xBF); emit_byte(1); emit_byte(0); emit_byte(0); emit_byte(0)
                // mov rsi, rsp (&ts)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xE6)
                // mov eax, 228 (SYS_clock_gettime)
                emit_mov_rax_imm(228)
                // syscall
                emit_byte(0x0F); emit_byte(0x05)
                // mov rax, [rsp]           (sec)
                emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)
                // imul rax, rax, 1000      (sec * 1000 = ms contribution from seconds)
                emit_byte(0x48); emit_byte(0x69); emit_byte(0xC0)
                emit_u32_le(1000)
                // Stash sec*1000 in rbx (preserved across div)
                emit_byte(0x53)                                           // push rbx
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC3)         // mov rbx, rax
                // rax = nsec = [rsp+16]  (rsp shifted by 8 after push rbx)
                emit_byte(0x48); emit_byte(0x8B); emit_byte(0x44); emit_byte(0x24); emit_byte(16)
                // rcx = 1_000_000
                emit_byte(0x48); emit_byte(0xC7); emit_byte(0xC1)
                emit_u32_le(1000000)
                // xor edx, edx             (clear high dividend)
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
                // div rcx                  (rax = nsec / 1_000_000)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)
                // add rax, rbx             (total_ms = sec*1000 + nsec/1_000_000)
                emit_byte(0x48); emit_byte(0x01); emit_byte(0xD8)
                emit_byte(0x5B)                                           // pop rbx
                // add rsp, 16              (drop timespec)
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(16)
            } else {
                emit_mov_rax_imm(0)
            }
            return
        }

        // User-defined function call
        // Evaluate args directly into registers (avoids push/pop clobbering [rsp-8])
        uint32 arg = ast_child(node)
        uint64 warg = arg
        uint64 arg_count = 0

        // Count args
        uint64 wtmp = arg
        while wtmp != 0 {
            arg_count = arg_count + 1
            uint32 nt2 = ast_next(wtmp)
            wtmp = nt2
        }

        // Allocate temp slots for each arg
        uint64 arg_slots_base = var_count * 8
        uint64 ac = 0
        while ac < arg_count {
            var_count = var_count + 1
            ac = ac + 1
        }
        var_frame_size = var_count * 8
        uint64 acrem = var_frame_size & 15
        if acrem != 0 { var_frame_size = var_frame_size + 16 - acrem }

        // Evaluate all args and store to temp slots
        uint64 weval = warg
        uint64 ai = 0
        while weval != 0 {
            gen_expr(weval)
            uint64 aslot = arg_slots_base + ai * 8
            emit_store_rax_to_stack(aslot)
            ai = ai + 1
            uint32 anxt = ast_next(weval)
            weval = anxt
        }

        // Load args into registers from temp slots
        // SysV: rdi, rsi, rdx, rcx, r8, r9
        // Windows: rcx, rdx, r8, r9, stack, stack
        if target_os == 2 {
            // Windows x64 calling convention
            if arg_count >= 4 {
                emit_load_rax_from_stack(arg_slots_base + 24)
                // mov r9, rax
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xC1)
            }
            if arg_count >= 3 {
                emit_load_rax_from_stack(arg_slots_base + 16)
                emit_mov_r8_rax()
            }
        } else {
            // SysV calling convention (Linux/macOS)
            if arg_count >= 6 {
                emit_load_rax_from_stack(arg_slots_base + 40)
                // mov r9, rax (49 89 C1)
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xC1)
            }
            if arg_count >= 5 {
                emit_load_rax_from_stack(arg_slots_base + 32)
                // mov r8, rax (49 89 C0)
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xC0)
            }
            if arg_count >= 4 {
                emit_load_rax_from_stack(arg_slots_base + 24)
                // mov rcx, rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            }
            if arg_count >= 3 {
                emit_load_rax_from_stack(arg_slots_base + 16)
                emit_mov_rdx_rax()
            }
        }
        if arg_count >= 2 {
            emit_load_rax_from_stack(arg_slots_base + 8)
            if target_os == 2 { emit_mov_rdx_rax() } else { emit_mov_rsi_rax() }
        }
        if arg_count >= 1 {
            emit_load_rax_from_stack(arg_slots_base)
            if target_os == 2 { emit_mov_rcx_rax() } else { emit_mov_rdi_rax() }
        }

        // Push overflow args (7+) onto stack AFTER register loads (SysV x86_64)
        // Done below, after register arg loading, to avoid rsp shift issues
        uint64 stack_args = 0
        if arg_count > 6 && target_os != 2 {
            stack_args = arg_count - 6
            if (stack_args & 1) != 0 { stack_args = stack_args + 1 }
        }

        // emit: call rel32 (placeholder)
        // First, push overflow args (using saved register values would clobber,
        // so we use rax to load from temp slots and push)
        if stack_args > 0 {
            // Allocate stack space for overflow args + alignment
            uint64 stack_bytes = stack_args * 8
            // sub rsp, stack_bytes
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC)
            uint8 sb8 = stack_bytes
            emit_byte(sb8)
            // Store overflow args at [rsp+0], [rsp+8], ...
            // After sub rsp, original data is now at +stack_bytes higher offset
            uint64 real_overflow = arg_count - 6
            uint64 oi = 0
            while oi < real_overflow {
                emit_load_rax_from_stack(arg_slots_base + (6 + oi) * 8 + stack_bytes)
                emit_store_rax_to_stack(oi * 8)
                oi = oi + 1
            }
        }

        emit_byte(0xE8)
        uint64 fixup_off = out_len
        emit_u32_le(0)

        // Clean up overflow args from stack
        if stack_args > 0 {
            uint64 cleanup = stack_args * 8
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4)
            uint8 cl8 = cleanup
            emit_byte(cl8) // add rsp, N
        }

        // If the callee is an extern fn, record a call site for the linker
        // relocation and skip the internal fixup table — the linker fills the
        // disp32 at .o emit time with R_X86_64_PLT32.
        uint64 wct_ext = callee_tok
        uint64 ext_idx = extern_fn_lookup(wct_ext)
        if ext_idx != 0xFFFFFFFF {
            extern_call_record(fixup_off, ext_idx)
            return
        }

        // Record fixup
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = fixup_off
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = callee_tok
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1

        return
    }
}

// Match asm instruction text: compare src bytes at offset against a keyword
fn asm_match(uint64 src, uint64 off, uint64 kw, uint64 kwlen) -> uint64 {
    uint64 i = 0
    while i < kwlen {
        uint64 sa = src + off + i
        uint64 sc = 0
        unsafe { *(sa as uint8) -> sc }
        uint64 ka = kw + i
        uint64 kc = 0
        unsafe { *(ka as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

// Parse a hex byte from two ASCII chars at src+off. Returns byte value.
fn asm_parse_hex_byte(uint64 src, uint64 off) -> uint64 {
    uint64 a1 = src + off
    uint64 c1 = 0
    unsafe { *(a1 as uint8) -> c1 }
    uint64 a2 = src + off + 1
    uint64 c2 = 0
    unsafe { *(a2 as uint8) -> c2 }
    uint64 hi = 0
    if c1 >= 48 && c1 <= 57 { hi = c1 - 48 }
    if c1 >= 97 && c1 <= 102 { hi = c1 - 87 }
    if c1 >= 65 && c1 <= 70 { hi = c1 - 55 }
    uint64 lo = 0
    if c2 >= 48 && c2 <= 57 { lo = c2 - 48 }
    if c2 >= 97 && c2 <= 102 { lo = c2 - 87 }
    if c2 >= 65 && c2 <= 70 { lo = c2 - 55 }
    return hi * 16 + lo
}

// Emit x86_64 assembly from a string literal token
fn asm_emit_x86(uint64 str_tok) {
    // Get string content (skip opening quote)
    uint64 tstart = tok_text_start(str_tok)
    uint64 tlen = tok_text_len(str_tok)
    // String token includes quotes: "content"
    uint64 sptr = cg_source + tstart + 1
    uint64 slen = tlen - 2
    if slen == 0 { return }

    // Check for raw hex bytes: "0x0F 0x01 ..."
    uint64 fc = 0
    unsafe { *(sptr as uint8) -> fc }
    if fc == 48 && slen >= 4 {
        uint64 sc = 0
        uint64 sptr1 = sptr + 1
        unsafe { *(sptr1 as uint8) -> sc }
        if sc == 120 {
            // Parse hex bytes
            uint64 hp = 0
            while hp < slen {
                uint64 hc = 0
                uint64 haddr = sptr + hp
                unsafe { *(haddr as uint8) -> hc }
                if hc == 48 {
                    uint64 haddr2 = sptr + hp + 1
                    uint64 hc2 = 0
                    unsafe { *(haddr2 as uint8) -> hc2 }
                    if hc2 == 120 {
                        uint64 bv = asm_parse_hex_byte(sptr, hp + 2)
                        uint8 bv8 = bv
                        emit_byte(bv8)
                        hp = hp + 4
                    } else {
                        hp = hp + 1
                    }
                } else {
                    hp = hp + 1
                }
            }
            return
        }
    }

    // Simple x86_64 instructions
    if asm_match(sptr, 0, "nop", 3) != 0 && slen == 3 { emit_byte(0x90); return }
    if asm_match(sptr, 0, "ret", 3) != 0 && slen == 3 { emit_byte(0xC3); return }
    if asm_match(sptr, 0, "hlt", 3) != 0 && slen == 3 { emit_byte(0xF4); return }
    if asm_match(sptr, 0, "cli", 3) != 0 && slen == 3 { emit_byte(0xFA); return }
    if asm_match(sptr, 0, "sti", 3) != 0 && slen == 3 { emit_byte(0xFB); return }
    if asm_match(sptr, 0, "int3", 4) != 0 && slen == 4 { emit_byte(0xCC); return }
    if asm_match(sptr, 0, "cpuid", 5) != 0 && slen == 5 { emit_byte(0x0F); emit_byte(0xA2); return }
    if asm_match(sptr, 0, "rdmsr", 5) != 0 && slen == 5 { emit_byte(0x0F); emit_byte(0x32); return }
    if asm_match(sptr, 0, "wrmsr", 5) != 0 && slen == 5 { emit_byte(0x0F); emit_byte(0x30); return }
    if asm_match(sptr, 0, "iretq", 5) != 0 && slen == 5 { emit_byte(0x48); emit_byte(0xCF); return }
    if asm_match(sptr, 0, "syscall", 7) != 0 && slen == 7 { emit_byte(0x0F); emit_byte(0x05); return }
    if asm_match(sptr, 0, "pushfq", 6) != 0 && slen == 6 { emit_byte(0x9C); return }
    if asm_match(sptr, 0, "popfq", 5) != 0 && slen == 5 { emit_byte(0x9D); return }
    if asm_match(sptr, 0, "cld", 3) != 0 && slen == 3 { emit_byte(0xFC); return }
    if asm_match(sptr, 0, "std", 3) != 0 && slen == 3 { emit_byte(0xFD); return }
    // I/O instructions
    if asm_match(sptr, 0, "in al, dx", 9) != 0 { emit_byte(0xEC); return }
    if asm_match(sptr, 0, "in ax, dx", 9) != 0 { emit_byte(0x66); emit_byte(0xED); return }
    if asm_match(sptr, 0, "in eax, dx", 10) != 0 { emit_byte(0xED); return }
    if asm_match(sptr, 0, "out dx, al", 10) != 0 { emit_byte(0xEE); return }
    if asm_match(sptr, 0, "out dx, ax", 10) != 0 { emit_byte(0x66); emit_byte(0xEF); return }
    if asm_match(sptr, 0, "out dx, eax", 11) != 0 { emit_byte(0xEF); return }
    if asm_match(sptr, 0, "inb", 3) != 0 && slen == 3 { emit_byte(0xEC); return }
    if asm_match(sptr, 0, "outb", 4) != 0 && slen == 4 { emit_byte(0xEE); return }
    if asm_match(sptr, 0, "inw", 3) != 0 && slen == 3 { emit_byte(0x66); emit_byte(0xED); return }
    if asm_match(sptr, 0, "outw", 4) != 0 && slen == 4 { emit_byte(0x66); emit_byte(0xEF); return }
    if asm_match(sptr, 0, "ind", 3) != 0 && slen == 3 { emit_byte(0xED); return }
    if asm_match(sptr, 0, "outd", 4) != 0 && slen == 4 { emit_byte(0xEF); return }
    // Control register moves
    if asm_match(sptr, 0, "mov cr0, rax", 12) != 0 { emit_byte(0x0F); emit_byte(0x22); emit_byte(0xC0); return }
    if asm_match(sptr, 0, "mov cr3, rax", 12) != 0 { emit_byte(0x0F); emit_byte(0x22); emit_byte(0xD8); return }
    if asm_match(sptr, 0, "mov cr4, rax", 12) != 0 { emit_byte(0x0F); emit_byte(0x22); emit_byte(0xE0); return }
    if asm_match(sptr, 0, "mov rax, cr0", 12) != 0 { emit_byte(0x0F); emit_byte(0x20); emit_byte(0xC0); return }
    if asm_match(sptr, 0, "mov rax, cr3", 12) != 0 { emit_byte(0x0F); emit_byte(0x20); emit_byte(0xD8); return }
    if asm_match(sptr, 0, "mov rax, cr4", 12) != 0 { emit_byte(0x0F); emit_byte(0x20); emit_byte(0xE0); return }
    // Privileged instructions
    if asm_match(sptr, 0, "lgdt [rax]", 10) != 0 { emit_byte(0x0F); emit_byte(0x01); emit_byte(0x10); return }
    if asm_match(sptr, 0, "lidt [rax]", 10) != 0 { emit_byte(0x0F); emit_byte(0x01); emit_byte(0x18); return }
    if asm_match(sptr, 0, "invlpg [rax]", 12) != 0 { emit_byte(0x0F); emit_byte(0x01); emit_byte(0x38); return }
    if asm_match(sptr, 0, "ltr ax", 6) != 0 { emit_byte(0x0F); emit_byte(0x00); emit_byte(0xD8); return }
    if asm_match(sptr, 0, "swapgs", 6) != 0 && slen == 6 { emit_byte(0x0F); emit_byte(0x01); emit_byte(0xF8); return }
    // Unrecognized — skip silently (no error to allow forward compat)
}

// Emit ARM64 assembly from a string literal token
fn asm_emit_a64(uint64 str_tok) {
    uint64 tstart = tok_text_start(str_tok)
    uint64 tlen = tok_text_len(str_tok)
    uint64 sptr = cg_source + tstart + 1
    uint64 slen = tlen - 2
    if slen == 0 { return }

    // Check for raw hex word: "0xXXXXXXXX"
    uint64 fc = 0
    unsafe { *(sptr as uint8) -> fc }
    if fc == 48 && slen >= 4 {
        uint64 sc = 0
        uint64 sptr1 = sptr + 1
        unsafe { *(sptr1 as uint8) -> sc }
        if sc == 120 {
            // Parse hex word (4 bytes LE)
            uint64 val = 0
            uint64 hi = 2
            while hi < slen {
                uint64 haddr = sptr + hi
                uint64 hc = 0
                unsafe { *(haddr as uint8) -> hc }
                if hc == 32 { hi = hi + 1; continue }
                uint64 d = 0
                if hc >= 48 && hc <= 57 { d = hc - 48 }
                if hc >= 97 && hc <= 102 { d = hc - 87 }
                if hc >= 65 && hc <= 70 { d = hc - 55 }
                val = val * 16 + d
                hi = hi + 1
            }
            emit_a64(val)
            return
        }
    }

    // Simple ARM64 instructions
    if asm_match(sptr, 0, "nop", 3) != 0 && slen == 3 { emit_a64(0xD503201F); return }
    if asm_match(sptr, 0, "wfi", 3) != 0 && slen == 3 { emit_a64(0xD503207F); return }
    if asm_match(sptr, 0, "wfe", 3) != 0 && slen == 3 { emit_a64(0xD503205F); return }
    if asm_match(sptr, 0, "sev", 3) != 0 && slen == 3 { emit_a64(0xD503209F); return }
    if asm_match(sptr, 0, "isb", 3) != 0 && slen == 3 { emit_a64(0xD5033FDF); return }
    if asm_match(sptr, 0, "dsb sy", 6) != 0 { emit_a64(0xD5033F9F); return }
    if asm_match(sptr, 0, "dmb sy", 6) != 0 { emit_a64(0xD5033FBF); return }
    if asm_match(sptr, 0, "dsb ish", 7) != 0 { emit_a64(0xD5033B9F); return }
    if asm_match(sptr, 0, "dmb ish", 7) != 0 { emit_a64(0xD5033BBF); return }
    if asm_match(sptr, 0, "ret", 3) != 0 && slen == 3 { emit_a64(0xD65F03C0); return }
    if asm_match(sptr, 0, "eret", 4) != 0 && slen == 4 { emit_a64(0xD69F03E0); return }
    // Supervisor call: svc #N (16-bit imm)
    if asm_match(sptr, 0, "svc #", 5) != 0 {
        uint64 imm = 0
        uint64 si = 5
        while si < slen {
            uint64 saddr = sptr + si
            uint64 sch = 0
            unsafe { *(saddr as uint8) -> sch }
            if sch >= 48 && sch <= 57 { imm = imm * 10 + sch - 48 }
            si = si + 1
        }
        emit_a64(0xD4000001 | (imm << 5))
        return
    }
    // MSR sysreg, xN
    if asm_match(sptr, 0, "msr ", 4) != 0 {
        uint64 sreg = 0
        uint64 rt = 0
        // Find comma position
        uint64 ci = 4
        while ci < slen {
            uint64 ca = sptr + ci
            uint64 cc = 0
            unsafe { *(ca as uint8) -> cc }
            if cc == 44 { break }
            ci = ci + 1
        }
        // Parse sysreg name (offset 4 to ci)
        if asm_match(sptr, 4, "sctlr_el1", 9) != 0 { sreg = 0x81000 }
        if asm_match(sptr, 4, "tcr_el1", 7) != 0 { sreg = 0x82040 }
        if asm_match(sptr, 4, "ttbr0_el1", 9) != 0 { sreg = 0x82000 }
        if asm_match(sptr, 4, "ttbr1_el1", 9) != 0 { sreg = 0x82020 }
        if asm_match(sptr, 4, "mair_el1", 8) != 0 { sreg = 0x8A200 }
        if asm_match(sptr, 4, "vbar_el1", 8) != 0 { sreg = 0x8C000 }
        if asm_match(sptr, 4, "elr_el1", 7) != 0 { sreg = 0x84020 }
        if asm_match(sptr, 4, "spsr_el1", 8) != 0 { sreg = 0x84000 }
        if asm_match(sptr, 4, "esr_el1", 7) != 0 { sreg = 0x85200 }
        if asm_match(sptr, 4, "far_el1", 7) != 0 { sreg = 0x86000 }
        if asm_match(sptr, 4, "daif", 4) != 0 { sreg = 0xB4220 }
        if asm_match(sptr, 4, "sp_el0", 6) != 0 { sreg = 0x84100 }
        if asm_match(sptr, 4, "tpidr_el0", 9) != 0 { sreg = 0xBD040 }
        if asm_match(sptr, 4, "tpidr_el1", 9) != 0 { sreg = 0x8D080 }
        if asm_match(sptr, 4, "cntp_ctl_el0", 12) != 0 { sreg = 0xBE220 }
        if asm_match(sptr, 4, "cntp_tval_el0", 13) != 0 { sreg = 0xBE200 }
        if asm_match(sptr, 4, "cntfrq_el0", 10) != 0 { sreg = 0xBE000 }
        if asm_match(sptr, 4, "csselr_el1", 10) != 0 { sreg = 0xA0000 }
        // Parse xN after comma+space
        uint64 ri = ci + 1
        uint64 ra = sptr + ri
        uint64 rc = 0
        unsafe { *(ra as uint8) -> rc }
        if rc == 32 { ri = ri + 1 }
        // Skip 'x'
        ri = ri + 1
        uint64 rnum = 0
        while ri < slen {
            uint64 rra = sptr + ri
            uint64 rrc = 0
            unsafe { *(rra as uint8) -> rrc }
            if rrc >= 48 && rrc <= 57 { rnum = rnum * 10 + rrc - 48 }
            ri = ri + 1
        }
        rt = rnum
        emit_a64(0xD5100000 | sreg | rt)
        return
    }
    // MRS xN, sysreg
    if asm_match(sptr, 0, "mrs ", 4) != 0 {
        uint64 sreg = 0
        uint64 rt = 0
        // Parse xN (starts at offset 4, skip 'x')
        uint64 ri = 5
        uint64 rnum = 0
        while ri < slen {
            uint64 rra = sptr + ri
            uint64 rrc = 0
            unsafe { *(rra as uint8) -> rrc }
            if rrc == 44 { break }
            if rrc >= 48 && rrc <= 57 { rnum = rnum * 10 + rrc - 48 }
            ri = ri + 1
        }
        rt = rnum
        // Parse sysreg name after ", "
        uint64 si = ri + 1
        uint64 sa = sptr + si
        uint64 sc = 0
        unsafe { *(sa as uint8) -> sc }
        if sc == 32 { si = si + 1 }
        if asm_match(sptr, si, "sctlr_el1", 9) != 0 { sreg = 0x81000 }
        if asm_match(sptr, si, "tcr_el1", 7) != 0 { sreg = 0x82040 }
        if asm_match(sptr, si, "ttbr0_el1", 9) != 0 { sreg = 0x82000 }
        if asm_match(sptr, si, "ttbr1_el1", 9) != 0 { sreg = 0x82020 }
        if asm_match(sptr, si, "mair_el1", 8) != 0 { sreg = 0x8A200 }
        if asm_match(sptr, si, "vbar_el1", 8) != 0 { sreg = 0x8C000 }
        if asm_match(sptr, si, "elr_el1", 7) != 0 { sreg = 0x84020 }
        if asm_match(sptr, si, "spsr_el1", 8) != 0 { sreg = 0x84000 }
        if asm_match(sptr, si, "esr_el1", 7) != 0 { sreg = 0x85200 }
        if asm_match(sptr, si, "far_el1", 7) != 0 { sreg = 0x86000 }
        if asm_match(sptr, si, "daif", 4) != 0 { sreg = 0xB4220 }
        if asm_match(sptr, si, "currentel", 9) != 0 { sreg = 0x84240 }
        if asm_match(sptr, si, "mpidr_el1", 9) != 0 { sreg = 0x800A0 }
        if asm_match(sptr, si, "sp_el0", 6) != 0 { sreg = 0x84100 }
        if asm_match(sptr, si, "tpidr_el0", 9) != 0 { sreg = 0xBD040 }
        if asm_match(sptr, si, "tpidr_el1", 9) != 0 { sreg = 0x8D080 }
        if asm_match(sptr, si, "cntfrq_el0", 10) != 0 { sreg = 0xBE000 }
        if asm_match(sptr, si, "cntp_ctl_el0", 12) != 0 { sreg = 0xBE220 }
        if asm_match(sptr, si, "cntp_tval_el0", 13) != 0 { sreg = 0xBE200 }
        if asm_match(sptr, si, "clidr_el1", 9) != 0 { sreg = 0x90020 }
        if asm_match(sptr, si, "ccsidr_el1", 10) != 0 { sreg = 0x90000 }
        if asm_match(sptr, si, "csselr_el1", 10) != 0 { sreg = 0xA0000 }
        emit_a64(0xD5300000 | sreg | rt)
        return
    }
    // Unrecognized — skip silently
}

// Generate code for a statement
@export
fn gen_stmt(uint64 node) {
    uint32 kind = ast_kind(node)

    // Variable declaration: TYPE name = expr  OR  TYPE[SIZE] name (array)
    if kind == 10 {
        uint32 name_tok = ast_data2(node)
        uint32 arr_size_tok = ast_data3(node)
        uint64 was = arr_size_tok

        // Check for struct variable declaration FIRST (may also be an array of structs)
        uint32 struct_marker = ast_data4(node)
        uint64 wsm = struct_marker

        if was != 0 && wsm == 0 {
            // Plain byte/word array declaration: allocate N*elem_size bytes on stack
            uint64 arr_size = parse_int_token(was)
            uint32 type_tok_v = ast_data1(node)
            uint64 elem_size_v = type_tok_elem_size(type_tok_v)
            uint64 total_bytes = arr_size * elem_size_v
            // Round up to 8-byte slots
            uint64 n_slots = (total_bytes + 7) / 8
            // Allocate slots
            uint64 arr_offset = var_count * 8
            uint64 si = 0
            while si < n_slots {
                var_count = var_count + 1
                si = si + 1
            }
            var_frame_size = var_count * 8
            uint64 arem2 = var_frame_size & 15
            if arem2 != 0 { var_frame_size = var_frame_size + 16 - arem2 }
            // The variable stores a pointer to the array on the stack
            // Declare the name variable and store the address
            uint64 ptr_offset = var_declare(name_tok)
            // Record per-element size for correct index scaling later
            arr_elem_register(name_tok, elem_size_v)
            // lea rax, [rsp + arr_offset]
            emit_byte(0x48)
            emit_byte(0x8D)
            if arr_offset == 0 {
                emit_byte(0x04)
                emit_byte(0x24)
            } else if arr_offset < 128 {
                emit_byte(0x44)
                emit_byte(0x24)
                uint8 ao8 = arr_offset
                emit_byte(ao8)
            } else {
                emit_byte(0x84)
                emit_byte(0x24)
                emit_u32_le(arr_offset)
            }
            emit_store_rax_to_stack(ptr_offset)
            return
        }

        if wsm != 0 {
            uint64 sidx = wsm - 1
            uint64 ssize = struct_total_size(sidx)
            // Struct array: data3 = array size token
            uint32 sarr_size_tok = ast_data3(node)
            uint64 wsast = sarr_size_tok
            uint64 count = 1
            if wsast != 0 {
                count = parse_int_token(wsast)
            }
            uint64 total_bytes = ssize * count
            uint64 n_slots = (total_bytes + 7) / 8
            uint64 struct_off = var_count * 8
            uint64 ssi = 0
            while ssi < n_slots {
                var_count = var_count + 1
                ssi = ssi + 1
            }
            var_frame_size = var_count * 8
            uint64 srem = var_frame_size & 15
            if srem != 0 { var_frame_size = var_frame_size + 16 - srem }
            // Variable holds pointer to struct space
            uint64 ptr_off = var_declare(name_tok)
            // lea rax, [rsp + struct_off]
            emit_byte(0x48); emit_byte(0x8D)
            if struct_off < 128 {
                emit_byte(0x44); emit_byte(0x24)
                uint8 so8 = struct_off
                emit_byte(so8)
            } else {
                emit_byte(0x84); emit_byte(0x24)
                emit_u32_le(struct_off)
            }
            emit_store_rax_to_stack(ptr_off)
            // Register as struct variable (tracks struct type for field access)
            struct_var_register(name_tok, sidx)
            return
        }

        uint64 offset = var_declare(name_tok)
        uint32 init_child = ast_child(node)
        uint64 wic = init_child
        if wic != 0 {
            gen_expr(wic)
            emit_store_rax_to_stack(offset)
        }
        return
    }

    // Field assignment: var.field = value (kind 36 with data4 = 1)
    if kind == 36 {
        uint32 fa_d4 = ast_data4(node)
        uint64 wfad4 = fa_d4
        if wfad4 == 1 {
            uint32 fa_child = ast_child(node)
            uint64 wfachild = fa_child
            uint32 field_tok = ast_data2(node)
            uint32 val_node = ast_data3(node)
            uint64 wval = val_node

            // Struct array element field write: arr[i].field = val
            if wfachild != 0 {
                uint32 cfk_w = ast_kind(wfachild)
                uint64 wcfk_w = cfk_w
                if wcfk_w == 37 {
                    uint32 ai_tok_w = ast_data1(wfachild)
                    uint64 wait_w = ai_tok_w
                    uint64 sia_w = struct_var_lookup(ai_tok_w)
                    if sia_w != 0xFFFFFFFF {
                        uint64 stride_w = struct_total_size(sia_w)
                        uint64 foff_w = struct_field_offset(sia_w, field_tok)
                        uint64 fsz_w = struct_field_size(sia_w, field_tok)
                        // Evaluate value → save to temp_slot_0
                        gen_expr(wval)
                        emit_store_rax_to_stack(temp_slot_0)
                        // Evaluate index → rax
                        uint32 idx_ch_w = ast_child(wfachild)
                        uint64 widx_w = idx_ch_w
                        gen_expr(widx_w)
                        // rax = i. multiply by stride
                        emit_mov_rcx_rax()
                        emit_mov_rax_imm(stride_w)
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xC1)
                        emit_mov_rcx_rax()
                        // Load base address
                        uint64 aoff_w = var_lookup(wait_w)
                        if aoff_w != 0xFFFFFFFF {
                            emit_load_rax_from_stack(aoff_w)
                        }
                        // addr = base + rcx + foff_w
                        emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8)
                        if foff_w != 0 {
                            emit_byte(0x48); emit_byte(0x05)
                            emit_u32_le(foff_w)
                        }
                        // mov rcx, rax (addr), load value, store
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                        emit_load_rax_from_stack(temp_slot_0)
                        if fsz_w == 1 {
                            emit_byte(0x88); emit_byte(0x01)
                        } else if fsz_w == 2 {
                            emit_byte(0x66); emit_byte(0x89); emit_byte(0x01)
                        } else if fsz_w == 4 {
                            emit_byte(0x89); emit_byte(0x01)
                        } else {
                            emit_byte(0x48); emit_byte(0x89); emit_byte(0x01)
                        }
                        return
                    }
                }
            }

            uint32 obj_tok = 0
            if wfachild != 0 {
                uint32 fack = ast_kind(wfachild)
                uint64 wfack = fack
                if wfack == 32 {
                    obj_tok = ast_data1(wfachild)
                }
            }
            // Device field write: UART0.Data = val → vstoreN
            if obj_tok != 0 {
                uint64 wdtw = obj_tok
                uint64 dev_idx_w = device_lookup(wdtw)
                if dev_idx_w != 0xFFFFFFFF {
                    uint64 wftw_d = field_tok
                    uint64 dev_off_w = device_field_offset_of(dev_idx_w, wftw_d)
                    if dev_off_w != 0xFFFFFFFF {
                        uint64 dev_sz_w = device_field_size_of(dev_idx_w, wftw_d)
                        uint64 dev_addr_w = device_base(dev_idx_w) + dev_off_w
                        // Evaluate value → rax, save
                        gen_expr(wval)
                        emit_mov_rcx_rax()
                        // rcx = value. Load address into rax.
                        emit_mov_rax_imm(dev_addr_w)
                        // mfence (barrier before store)
                        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
                        if dev_sz_w == 1 {
                            emit_byte(0x88); emit_byte(0x08)
                        } else if dev_sz_w == 2 {
                            emit_byte(0x66); emit_byte(0x89); emit_byte(0x08)
                        } else if dev_sz_w == 4 {
                            emit_byte(0x89); emit_byte(0x08)
                        } else {
                            emit_byte(0x48); emit_byte(0x89); emit_byte(0x08)
                        }
                        return
                    }
                }
            }
            // Evaluate value
            gen_expr(wval)
            emit_store_rax_to_stack(temp_slot_0)
            // Compute address: base + field_offset
            uint64 si = struct_var_lookup(obj_tok)
            if si != 0xFFFFFFFF {
                uint64 var_off = var_lookup(obj_tok)
                if var_off == 0xFFFFFFFF { var_off = 0 }
                uint64 foff = struct_field_offset(si, field_tok)
                uint64 fsz = struct_field_size(si, field_tok)
                emit_load_rax_from_stack(var_off)
                if foff != 0 {
                    emit_byte(0x48); emit_byte(0x05)
                    emit_u32_le(foff)
                }
                // rax = address. Load value from temp, store
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1) // mov rcx, rax (addr)
                emit_load_rax_from_stack(temp_slot_0)
                // Store based on field size
                if fsz == 1 {
                    emit_byte(0x88); emit_byte(0x01) // mov %al, (%rcx)
                } else if fsz == 4 {
                    emit_byte(0x89); emit_byte(0x01) // mov %eax, (%rcx)
                } else {
                    emit_byte(0x48); emit_byte(0x89); emit_byte(0x01) // mov %rax, (%rcx)
                }
            }
            return
        }
    }

    // Assignment: name = expr
    if kind == 11 {
        uint32 name_tok = ast_data1(node)
        uint32 val_child = ast_child(node)
        uint64 wvc = val_child
        gen_expr(wvc)
        uint64 offset = var_lookup(name_tok)
        if offset != 0xFFFFFFFF {
            emit_store_rax_to_stack(offset)
        } else {
            uint64 soff = static_lookup(name_tok)
            if soff != 0xFFFFFFFF {
                emit_static_store(soff)
            }
        }
        return
    }

    // Return: return expr
    if kind == 12 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        if wec != 0 {
            gen_expr(wec)
        }
        // Jump to epilogue (placeholder — patched after function body)
        emit_byte(0xE9)
        uint64 ret_patch = out_len
        emit_u32_le(0)
        // Record fixup
        uint64 rentry = ret_fixups + ret_fixup_count * 4
        uint32 rp32 = ret_patch
        unsafe { *(rentry as uint32) = rp32 }
        ret_fixup_count = ret_fixup_count + 1
        return
    }

    // If: if (cond) { body } else { body }
    if kind == 13 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr(wcond)

        // test eax, eax
        emit_byte(0x85)
        emit_byte(0xC0)

        // jz else (placeholder)
        emit_byte(0x0F)
        emit_byte(0x84)
        uint64 jz_patch = out_len
        emit_u32_le(0)

        // Then body
        uint32 then_idx = ast_data1(node)
        uint64 wthen = then_idx
        gen_block(wthen)

        // jmp endif (placeholder)
        emit_byte(0xE9)
        uint64 jmp_patch = out_len
        emit_u32_le(0)

        // Patch jz to here (else)
        uint64 else_target = out_len
        uint64 jz_disp = else_target - jz_patch - 4
        patch_u32(jz_patch, jz_disp)

        // Else body (could be a Block or an If node from else-if)
        uint32 else_idx = ast_data2(node)
        uint64 welse = else_idx
        if welse != 0 {
            uint32 else_kind = ast_kind(welse)
            if else_kind == 13 {
                gen_stmt(welse)
            } else {
                gen_block(welse)
            }
        }

        // Patch jmp to here (endif)
        uint64 endif_target = out_len
        uint64 jmp_disp = endif_target - jmp_patch - 4
        patch_u32(jmp_patch, jmp_disp)
        return
    }

    // Block: nested block of statements (used by for-loop desugaring)
    if kind == 15 {
        gen_block(node)
        return
    }

    // While: while (cond) { body }
    if kind == 14 {
        uint64 loop_start = out_len

        // Push loop context
        uint64 lentry = loop_stack + loop_depth * 16
        unsafe { *(lentry as uint64) = loop_start }
        uint64 lentry8 = lentry + 8
        unsafe { *(lentry8 as uint64) = break_fixup_count }
        loop_depth = loop_depth + 1

        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr(wcond)

        // test eax, eax
        emit_byte(0x85)
        emit_byte(0xC0)

        // jz loop_end (placeholder)
        emit_byte(0x0F)
        emit_byte(0x84)
        uint64 jz_patch = out_len
        emit_u32_le(0)

        // Body
        uint32 body_idx = ast_data1(node)
        uint64 wbody = body_idx
        gen_block(wbody)

        // jmp loop_start
        emit_byte(0xE9)
        uint64 back_disp = loop_start - out_len - 4
        emit_u32_le(back_disp)

        // Patch jz to here (loop_end)
        uint64 loop_end = out_len
        uint64 fwd_disp = loop_end - jz_patch - 4
        patch_u32(jz_patch, fwd_disp)

        // Pop loop context and patch break fixups to loop_end
        loop_depth = loop_depth - 1
        uint64 lentry2 = loop_stack + loop_depth * 16 + 8
        uint64 saved_break_start = 0
        unsafe { *(lentry2 as uint64) -> saved_break_start }
        uint64 bi = saved_break_start
        while bi < break_fixup_count {
            uint64 bentry = break_fixups + bi * 4
            uint32 bpatch = 0
            unsafe { *(bentry as uint32) -> bpatch }
            uint64 wbp = bpatch
            uint64 bdisp = loop_end - wbp - 4
            patch_u32(wbp, bdisp)
            bi = bi + 1
        }
        break_fixup_count = saved_break_start
        return
    }

    // Break
    if kind == 17 {
        emit_byte(0xE9)
        uint64 brk_off = out_len
        emit_u32_le(0)
        uint64 brk_entry = break_fixups + break_fixup_count * 4
        uint32 brk32 = brk_off
        unsafe { *(brk_entry as uint32) = brk32 }
        break_fixup_count = break_fixup_count + 1
        return
    }

    // Continue
    if kind == 18 {
        // Jump back to loop_start
        uint64 lentry3 = loop_stack + (loop_depth - 1) * 16
        uint64 cont_target = 0
        unsafe { *(lentry3 as uint64) -> cont_target }
        emit_byte(0xE9)
        uint64 cont_disp = cont_target - out_len - 4
        emit_u32_le(cont_disp)
        return
    }

    // Match statement: evaluate scrutinee, compare to each arm, execute matching body
    if kind == 19 {
        uint32 scrutinee = ast_child(node)
        uint64 wscr = scrutinee
        gen_expr(wscr)
        // Allocate temp for scrutinee
        uint64 match_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 mrem = var_frame_size & 15
        if mrem != 0 { var_frame_size = var_frame_size + 16 - mrem }
        emit_store_rax_to_stack(match_temp)
        // Track end-of-match jumps using break_fixups
        uint64 saved_break = break_fixup_count
        uint32 arm_idx = ast_data1(node)
        uint64 warm = arm_idx
        while warm != 0 {
            // Evaluate arm value
            uint32 val_idx = ast_data1(warm)
            uint64 wval = val_idx
            gen_expr(wval)
            // cmp scrutinee (in temp), arm_value (in rax)
            // mov rcx, rax
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_load_rax_from_stack(match_temp)
            // cmp rax, rcx
            emit_byte(0x48); emit_byte(0x39); emit_byte(0xC8)
            // jne skip_arm
            emit_byte(0x0F); emit_byte(0x85)
            uint64 jne_patch = out_len
            emit_u32_le(0)
            // Execute arm body
            uint32 body_idx = ast_data2(warm)
            uint64 wbody = body_idx
            gen_block(wbody)
            // jmp end_match (stored in break_fixups)
            emit_byte(0xE9)
            uint64 end_patch = out_len
            emit_u32_le(0)
            uint64 bf = break_fixups + break_fixup_count * 4
            uint32 ep32 = end_patch
            unsafe { *(bf as uint32) = ep32 }
            break_fixup_count = break_fixup_count + 1
            // Patch jne to here (skip this arm)
            uint64 skip_target = out_len
            patch_u32(jne_patch, (skip_target - jne_patch - 4) & 0xFFFFFFFF)
            uint32 next_arm = ast_next(warm)
            warm = next_arm
        }
        // Patch all end-match jumps to here
        uint64 end_addr = out_len
        uint64 bi = saved_break
        while bi < break_fixup_count {
            uint64 bfe = break_fixups + bi * 4
            uint32 bp32 = 0
            unsafe { *(bfe as uint32) -> bp32 }
            uint64 wbp = bp32
            patch_u32(wbp, (end_addr - wbp - 4) & 0xFFFFFFFF)
            bi = bi + 1
        }
        break_fixup_count = saved_break
        return
    }

    // Indexed assignment: arr[i] = val (kind 37 with data3=1)
    if kind == 37 {
        uint32 idx_d3 = ast_data3(node)
        uint64 wd3 = idx_d3
        if wd3 == 1 {
            // Evaluate value first → save to temp
            uint32 rhs_child = ast_data2(node)
            uint64 wrhs = rhs_child
            gen_expr(wrhs)
            emit_store_rax_to_stack(temp_slot_0)
            // Evaluate index
            uint32 idx_child = ast_child(node)
            uint64 wi = idx_child
            gen_expr(wi)
            emit_store_rax_to_stack(temp_slot_1)
            // Load array base
            uint32 arr_tok = ast_data1(node)
            uint64 warrt2 = arr_tok
            uint64 arr_offset = var_lookup(arr_tok)
            uint64 elem_sz_w = arr_elem_lookup(arr_tok)
            if arr_offset != 0xFFFFFFFF {
                emit_load_rax_from_stack(arr_offset)
            } else {
                uint64 sas2 = static_array_size_of(warrt2)
                if sas2 != 0xFFFFFFFF && sas2 != 0 {
                    uint64 soff2 = static_lookup(warrt2)
                    emit_static_lea(soff2)
                } else {
                    arr_offset = 0
                    emit_load_rax_from_stack(arr_offset)
                }
            }
            // rax = base. Save to rcx, then load index, scale it, add to base.
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1) // mov rcx, rax (base)
            emit_load_rax_from_stack(temp_slot_1)              // rax = index
            // Scale rax by elem_sz_w: shl rax, log2(elem_sz_w)
            if elem_sz_w == 2 {
                emit_byte(0x48); emit_byte(0xD1); emit_byte(0xE0) // shl rax, 1
            } else if elem_sz_w == 4 {
                emit_byte(0x48); emit_byte(0xC1); emit_byte(0xE0); emit_byte(2) // shl rax, 2
            } else if elem_sz_w == 8 {
                emit_byte(0x48); emit_byte(0xC1); emit_byte(0xE0); emit_byte(3) // shl rax, 3
            }
            emit_byte(0x48); emit_byte(0x01); emit_byte(0xC1)    // add rcx, rax → rcx = base+idx*elem
            // Load value from temp_slot_0 → rax
            emit_load_rax_from_stack(temp_slot_0)
            // Store elem_sz_w bytes at [rcx]
            if elem_sz_w == 1 {
                emit_byte(0x88); emit_byte(0x01)                  // mov byte [rcx], al
            } else if elem_sz_w == 2 {
                emit_byte(0x66); emit_byte(0x89); emit_byte(0x01) // mov word [rcx], ax
            } else if elem_sz_w == 4 {
                emit_byte(0x89); emit_byte(0x01)                  // mov dword [rcx], eax
            } else {
                emit_byte(0x48); emit_byte(0x89); emit_byte(0x01) // mov qword [rcx], rax
            }
            return
        }
    }

    // PtrLoad: *(addr as TYPE) -> dest
    // kind 41: data1=type_size, child=addr_expr, data2=dest_name_tok
    if kind == 41 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr(wa)
        // rax = address. Do indirect load based on type_size.
        if wts == 1 {
            // movzbl (%rax), %eax
            emit_byte(0x0F)
            emit_byte(0xB6)
            emit_byte(0x00)
        } else if wts == 2 {
            // movzwl (%rax), %eax
            emit_byte(0x0F)
            emit_byte(0xB7)
            emit_byte(0x00)
        } else if wts == 4 {
            // movl (%rax), %eax
            emit_byte(0x8B)
            emit_byte(0x00)
        } else {
            // movq (%rax), %rax
            emit_byte(0x48)
            emit_byte(0x8B)
            emit_byte(0x00)
        }
        // Volatile barrier after load (prevent reordering)
        uint32 vol_flag = ast_data3(node)
        uint64 wvf = vol_flag
        if wvf == 1 {
            // mfence
            emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        }
        // Store to destination variable
        uint32 dest_tok = ast_data2(node)
        uint64 doff = var_lookup(dest_tok)
        if doff != 0xFFFFFFFF {
            emit_store_rax_to_stack(doff)
        } else {
            uint64 soff = static_lookup(dest_tok)
            if soff != 0xFFFFFFFF {
                emit_static_store(soff)
            }
        }
        return
    }

    // PtrStore: *(addr as TYPE) = value
    // kind 42: data1=type_size, child=addr_expr, data2=value_expr
    if kind == 42 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        // Evaluate value first → save to temp
        uint32 val_child = ast_data2(node)
        uint64 wv = val_child
        gen_expr(wv)
        // Save value to temp_slot_0
        emit_store_rax_to_stack(temp_slot_0)
        // Evaluate address
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr(wa)
        // rax = address, load value from temp → rcx
        // mov rcx, [rsp + temp_slot_0]
        emit_byte(0x48)
        emit_byte(0x8B)
        if temp_slot_0 == 0 {
            emit_byte(0x0C)
            emit_byte(0x24)
        } else if temp_slot_0 < 128 {
            emit_byte(0x4C)
            emit_byte(0x24)
            uint8 ts8 = temp_slot_0
            emit_byte(ts8)
        } else {
            emit_byte(0x8C)
            emit_byte(0x24)
            emit_u32_le(temp_slot_0)
        }
        // Volatile barrier before store (prevent reordering)
        uint32 vol_flag2 = ast_data3(node)
        uint64 wvf2 = vol_flag2
        if wvf2 == 1 {
            // mfence
            emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        }
        // Store rcx to (%rax) based on type_size
        if wts == 1 {
            // movb %cl, (%rax)
            emit_byte(0x88)
            emit_byte(0x08)
        } else if wts == 2 {
            // mov word [rax], cx
            emit_byte(0x66)
            emit_byte(0x89)
            emit_byte(0x08)
        } else if wts == 4 {
            // movl %ecx, (%rax)
            emit_byte(0x89)
            emit_byte(0x08)
        } else {
            // movq %rcx, (%rax)
            emit_byte(0x48)
            emit_byte(0x89)
            emit_byte(0x08)
        }
        return
    }

    // Inline assembly: asm("instruction") or asm { "instr1"; "instr2"; }
    if kind == 43 {
        uint32 single_tok = ast_data1(node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_x86(ws)
        }
        uint32 child_str = ast_child(node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_x86(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }
        return
    }

    // Expression statement (e.g. function call)
    if kind == 16 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        gen_expr(wec)
        return
    }
}

// Generate code for a block (linked list of statements)
@export
fn gen_block(uint64 block_node) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        gen_stmt(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// Scan AST subtree for assignments to a variable at target_offset.
// Returns 1 if any assignment/write targets that offset, 0 otherwise.
fn scan_assigns(uint64 node, uint64 target_offset) -> uint64 {
    if node == 0 { return 0 }
    uint32 kind = ast_kind(node)
    uint64 wk = kind
    // Assignment kind 11: target is data1 (a token index)
    if wk == 11 {
        uint32 t = ast_data1(node)
        uint64 off = var_lookup(t)
        if off == target_offset { return 1 }
    }
    // PtrLoad kind 41: dest is data2
    if wk == 41 {
        uint32 d = ast_data2(node)
        uint64 off = var_lookup(d)
        if off == target_offset { return 1 }
    }
    // VarDecl kind 10: name is data2 — re-declaration shadows the param
    if wk == 10 {
        uint32 vn = ast_data2(node)
        uint64 off = var_lookup(vn)
        if off == target_offset { return 1 }
    }
    // Recurse into child chain
    uint32 ch = ast_child(node)
    uint64 wch = ch
    while wch != 0 {
        if scan_assigns(wch, target_offset) != 0 { return 1 }
        uint32 nxt = ast_next(wch)
        wch = nxt
    }
    // If/While/For/Switch bodies stored in data1/data2
    if wk == 13 || wk == 14 || wk == 15 || wk == 19 || wk == 20 {
        uint32 d1 = ast_data1(node)
        uint64 wd1 = d1
        if scan_assigns(wd1, target_offset) != 0 { return 1 }
        uint32 d2 = ast_data2(node)
        uint64 wd2 = d2
        if scan_assigns(wd2, target_offset) != 0 { return 1 }
    }
    return 0
}

// Generate code for a function declaration
@export
fn gen_function(uint64 fn_node) {
    uint32 name_tok = ast_data1(fn_node)

    // Check annotation flags: bit 0 = noreturn, bit 1 = naked, bit 3 = extern
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2
    uint64 is_noreturn = ann_flags & 1
    uint64 is_extern = ann_flags & 8

    // Extern declarations have no body — skip codegen entirely. The linker
    // will resolve the symbol in the final binary.
    if is_extern != 0 { return }
    uint32 body_check = ast_data3(fn_node)
    if body_check == 0 { return }

    // Overflow arg patch tracking (for functions with >6 params)
    uint64[16] overflow_patches
    uint64 overflow_patch_count = 0

    // Reset variable table for this function
    var_reset()

    // Reserve temp slots + r12 save slot
    temp_slot_0 = var_count * 8
    var_count = var_count + 1
    temp_slot_1 = var_count * 8
    var_count = var_count + 1
    r12_save_slot = var_count * 8
    var_count = var_count + 1
    r12_in_use = 0
    var_frame_size = var_count * 8
    uint64 rem0 = var_frame_size & 15
    if rem0 != 0 { var_frame_size = var_frame_size + 16 - rem0 }

    // Register function at current offset
    fn_register(name_tok, out_len)

    // For main function: emit _start trampoline that stores argc/argv to statics
    // Skip in freestanding mode
    uint64 wnt = name_tok
    if tok_matches(wnt, "main", 4) != 0 && target_os == 2 && freestanding == 0 {
        // All 13 IAT entries are loader-resolved. Call GetCommandLineA directly.
        // PE entry: the loader calls us, so RSP ≡ 8 mod 16.
        // Use 0x28 shadow space (0x20 + 8 alignment) so RSP is 16-aligned before CALL.
        emit_win_alloc_stack(0x28)
        emit_win_call_iat(7)          // GetCommandLineA → rax = cmdline ptr
        emit_win_free_stack(0x28)
        // Store raw cmdline pointer as cli_argv (will be parsed by win_init_args)
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_static_store(argv_off_w)
        }
        // Set cli_argc = 0xFFFFFFFF as "needs parsing" sentinel
        emit_mov_rax_imm(0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_static_store(argc_off_w)
        }
        // RSP is still ≡ 8 mod 16 (same as after a CALL), so the normal
        // function prologue (push rbx + sub rsp,frame) works correctly.
    }
    if tok_matches(wnt, "main", 4) != 0 && target_os != 2 && freestanding == 0 {
        // Linux + macOS: argc/argv on stack. [RSP]=argc, [RSP+8]=&argv[0]
        // mov rax, [rsp]       ; rax = argc
        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)
        // Store to cli_argc static
        uint64 argc_off = static_lookup_by_name("cli_argc", 8)
        if argc_off != 0xFFFFFFFF {
            emit_static_store(argc_off)
        }
        // lea rax, [rsp+8]    ; rax = &argv[0]
        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24); emit_byte(0x08)
        uint64 argv_off = static_lookup_by_name("cli_argv", 8)
        if argv_off != 0xFFFFFFFF {
            emit_static_store(argv_off)
        }
        // Compute envp = rsp + 8 + (argc+1)*8
        uint64 envp_off = static_lookup_by_name("cli_envp", 8)
        if envp_off != 0xFFFFFFFF {
            // mov rcx, [rsp]  ; rcx = argc
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x0C); emit_byte(0x24)
            // inc rcx
            emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
            // lea rax, [rsp + rcx*8 + 8]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0xCC); emit_byte(0x08)
            emit_static_store(envp_off)
        }
    }

    // Clear per-function slice table
    slice_len_count = 0

    // Parse params (declare as variables)
    uint32 first_param = ast_child(fn_node)
    uint64 wparam = first_param
    while wparam != 0 {
        uint32 pk = ast_kind(wparam)
        if pk == 3 {
            uint32 param_name = ast_data2(wparam)
            uint64 ptr_off_x = var_declare(param_name)
            // Slice parameter: also reserve a length slot (no name)
            uint32 pflag = ast_data4(wparam)
            uint64 wpflag = pflag
            if wpflag == 1 {
                uint64 len_off_x = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 srem_sp = var_frame_size & 15
                if srem_sp != 0 { var_frame_size = var_frame_size + 16 - srem_sp }
                slice_len_register(ptr_off_x, len_off_x)
            }
            // If the param's type is a struct name, register it as a struct var
            // so that field access on it works inside the function body.
            uint32 param_type = ast_data1(wparam)
            uint64 wpt = param_type
            uint64 psi = struct_lookup(wpt)
            if psi != 0xFFFFFFFF {
                struct_var_register(param_name, psi)
            }
        }
        uint32 pnxt = ast_next(wparam)
        wparam = pnxt
    }

    // Parameter pinning: pin read-only params to callee-saved registers
    pin_param0_offset = 0xFFFFFFFF
    pin_param1_offset = 0xFFFFFFFF
    pin_param0_tok = 0
    pin_param1_tok = 0

    // Collect first two param offsets
    uint64 p0_off = 0xFFFFFFFF
    uint64 p1_off = 0xFFFFFFFF
    uint64 pidx_scan = 0
    uint64 wp_scan = first_param
    while wp_scan != 0 {
        uint32 pks = ast_kind(wp_scan)
        if pks == 3 {
            uint32 pns = ast_data2(wp_scan)
            uint64 poffs = var_lookup(pns)
            if pidx_scan == 0 { p0_off = poffs }
            if pidx_scan == 1 { p1_off = poffs }
            pidx_scan = pidx_scan + 1
        }
        uint32 pnxts = ast_next(wp_scan)
        wp_scan = pnxts
    }

    // Use the body block (data3) for scanning assignments
    uint32 body_scan = ast_data3(fn_node)
    uint64 wbs = body_scan

    // Check if params are read-only AND function is not naked/Windows/overflow
    if is_naked == 0 && pidx_scan <= 6 && target_os != 2 {
        if p0_off != 0xFFFFFFFF && wbs != 0 {
            if scan_assigns(wbs, p0_off) == 0 {
                pin_param0_offset = p0_off
            }
        }
    }

    // Pre-scan body to count local variables
    // (For simplicity, emit a placeholder frame setup and patch later)
    uint64 prologue_start = out_len
    uint64 frame_patch = out_len

    if is_naked == 0 {
        // push rbx
        emit_byte(0x53)
        // sub rsp, FRAME_SIZE (placeholder)
        emit_byte(0x48)
        emit_byte(0x81)
        emit_byte(0xEC)
        frame_patch = out_len
        emit_u32_le(0)
        // Save r12 to frame slot (callee-saved, for binop register spill)
        if r12_save_slot < 128 {
            emit_byte(0x4C); emit_byte(0x89); emit_byte(0x64)
            emit_byte(0x24); uint8 r12s = r12_save_slot; emit_byte(r12s)
        } else {
            emit_byte(0x4C); emit_byte(0x89); emit_byte(0xA4)
            emit_byte(0x24); emit_u32_le(r12_save_slot)
        }
    }

    // Spill params to stack
    // SysV:    param 0=rdi, 1=rsi, 2=rdx, 3=rcx, 4=r8, 5=r9
    // Windows: param 0=rcx, 1=rdx, 2=r8,  3=r9
    uint64 pidx = 0
    uint64 wp2 = first_param
    while wp2 != 0 {
        uint32 pk2 = ast_kind(wp2)
        if pk2 == 3 {
            uint32 pn2 = ast_data2(wp2)
            uint64 poff = var_lookup(pn2)
            // Track slice flag for this param
            uint32 pflag_s = ast_data4(wp2)
            uint64 wpflag_s = pflag_s
            if poff != 0xFFFFFFFF {
                uint8 po8 = poff
                if target_os == 2 {
                    // Windows calling convention
                    if pidx == 0 {
                        // mov [rsp+off], rcx
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x4C)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 1 {
                        // mov [rsp+off], rdx
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x54)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 2 {
                        // mov [rsp+off], r8
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0x44)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 3 {
                        // mov [rsp+off], r9
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0x4C)
                        emit_byte(0x24); emit_byte(po8)
                    }
                } else {
                    // SysV calling convention
                    if pidx == 0 {
                        if pin_param0_offset != 0xFFFFFFFF {
                            // mov rbx, rdi (48 89 FB)
                            emit_byte(0x48); emit_byte(0x89); emit_byte(0xFB)
                        } else {
                            // mov [rsp+off], rdi
                            emit_byte(0x48); emit_byte(0x89); emit_byte(0x7C)
                            emit_byte(0x24); emit_byte(po8)
                        }
                    }
                    if pidx == 1 {
                        // mov [rsp+off], rsi
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x74)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 2 {
                        // mov [rsp+off], rdx
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x54)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 3 {
                        // mov [rsp+off], rcx
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x4C)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 4 {
                        // mov [rsp+off], r8
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0x44)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx == 5 {
                        // mov [rsp+off], r9
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0x4C)
                        emit_byte(0x24); emit_byte(po8)
                    }
                    if pidx >= 6 {
                        // Stack-passed arg: emit mov rax, [rsp+PLACEHOLDER]
                        // Offset will be patched when frame_size is known
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x84)
                        emit_byte(0x24)
                        uint64 patch_loc = out_len
                        emit_u32_le(0) // placeholder — patched later
                        // Save patch location for this overflow arg
                        // Store: [overflow_patches + (pidx-6)*16] = {patch_loc, pidx-6}
                        uint64 opi = pidx - 6
                        uint64 op_entry = overflow_patches + opi * 8
                        uint32 pl32 = patch_loc
                        unsafe { *(op_entry as uint32) = pl32 }
                        overflow_patch_count = opi + 1
                        // mov [rsp+off], rax
                        emit_byte(0x48); emit_byte(0x89); emit_byte(0x44)
                        emit_byte(0x24); emit_byte(po8)
                    }
                }
                pidx = pidx + 1
                // Slice param: also spill the length register to the len slot
                if wpflag_s == 1 {
                    uint64 len_off = slice_len_lookup(poff)
                    if len_off != 0xFFFFFFFF {
                        uint8 lo8 = len_off
                        if target_os == 2 {
                            if pidx == 1 {
                                emit_byte(0x48); emit_byte(0x89); emit_byte(0x54)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 2 {
                                emit_byte(0x4C); emit_byte(0x89); emit_byte(0x44)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 3 {
                                emit_byte(0x4C); emit_byte(0x89); emit_byte(0x4C)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                        } else {
                            if pidx == 1 {
                                emit_byte(0x48); emit_byte(0x89); emit_byte(0x74)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 2 {
                                emit_byte(0x48); emit_byte(0x89); emit_byte(0x54)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 3 {
                                emit_byte(0x48); emit_byte(0x89); emit_byte(0x4C)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 4 {
                                emit_byte(0x4C); emit_byte(0x89); emit_byte(0x44)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                            if pidx == 5 {
                                emit_byte(0x4C); emit_byte(0x89); emit_byte(0x4C)
                                emit_byte(0x24); emit_byte(lo8)
                            }
                        }
                    }
                    pidx = pidx + 1
                }
            }
        }
        uint32 pn3 = ast_next(wp2)
        wp2 = pn3
    }

    // Reset return fixups for this function
    ret_fixup_count = 0

    // Generate body
    uint32 body_idx = ast_data3(fn_node)
    uint64 wbody = body_idx
    if wbody != 0 {
        gen_block(wbody)
    }

    // Epilogue label — patch all return jumps to here
    uint64 epilogue_start = out_len
    uint64 ri = 0
    while ri < ret_fixup_count {
        uint64 rentry = ret_fixups + ri * 4
        uint32 rpatch = 0
        unsafe { *(rentry as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 disp = epilogue_start - wrp - 4
        patch_u32(wrp, disp)
        ri = ri + 1
    }

    // For @naked functions, skip epilogue entirely
    if is_naked != 0 {
        return
    }

    // Stack size warning — fires on genuinely pathological frames
    // (huge inline buffers, accidentally unbounded locals). The compiler's
    // own dispatch functions legitimately allocate ~20KB across mutually
    // exclusive branches, so the threshold is set high enough to let them
    // pass while still catching user mistakes.
    if var_frame_size > 32768 {
        write(2, "warning: large stack frame (", 28)
        uint8[32] fsb
        uint64 fsl = fmt_uint(fsb, var_frame_size)
        write(2, fsb, fsl)
        write(2, " bytes) in function '", 21)
        uint64 fns = tok_text_start(name_tok)
        uint64 fnl = tok_text_len(name_tok)
        write(2, cg_source + fns, fnl)
        write(2, "'\n", 2)
    }

    // For main: auto-insert exit(0) so programs don't segfault on return
    // Skip when in freestanding mode
    uint64 wnt_ep = name_tok
    if tok_matches(wnt_ep, "main", 4) != 0 && freestanding == 0 {
        // mov edi, 0 (exit code)
        emit_mov_rax_imm(0)
        if target_os == 2 {
            emit_mov_rcx_rax()
            emit_win_alloc_stack(0x20)
            emit_win_call_iat(0)
        } else {
            emit_mov_rdi_rax()
            if target_os == 1 { emit_mov_rax_imm(0x2000001) } else { emit_mov_rax_imm(231) }
            emit_byte(0x0F); emit_byte(0x05)
        }
    }

    // Restore r12 from frame slot (doesn't clobber rax = return value)
    if is_naked == 0 {
        if r12_save_slot < 128 {
            emit_byte(0x4C); emit_byte(0x8B); emit_byte(0x64)
            emit_byte(0x24); uint8 r12r = r12_save_slot; emit_byte(r12r)
        } else {
            emit_byte(0x4C); emit_byte(0x8B); emit_byte(0xA4)
            emit_byte(0x24); emit_u32_le(r12_save_slot)
        }
    }

    // add rsp, FRAME_SIZE
    emit_byte(0x48)
    emit_byte(0x81)
    emit_byte(0xC4)
    emit_u32_le(var_frame_size)
    // pop rbx
    emit_byte(0x5B)
    // ret
    emit_byte(0xC3)

    // Patch prologue frame size
    patch_u32(frame_patch, var_frame_size)

    // Patch overflow arg offsets (7+ params)
    // After push rbx + push r12 + sub rsp, frame_size:
    // [rsp + frame_size + 0..7] = saved r12
    // [rsp + frame_size + 8..15] = saved rbx
    // [rsp + frame_size + 16] = return address
    // [rsp + frame_size + 24] = overflow arg 0 (or padding)
    if overflow_patch_count > 0 {
        // Overflow args are at [rsp + frame_size + 16 + i*8]
        // (frame_size = saved rbx(8) + frame; +16 = push rbx + return addr)
        // Padding (if present) is above the args, not between them
        uint64 oi = 0
        while oi < overflow_patch_count {
            uint64 op_e = overflow_patches + oi * 8
            uint32 ploc = 0
            unsafe { *(op_e as uint32) -> ploc }
            uint64 wploc = ploc
            uint64 soff = var_frame_size + 16 + oi * 8
            patch_u32(wploc, soff)
            oi = oi + 1
        }
    }
}

// Find the code offset for "main" function
@export
fn find_main_offset() -> uint64 {
    uint64 i = 0
    while i < fn_count {
        uint64 entry = fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_matches(ws, "main", 4) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Resolve call fixups
@export
fn resolve_fixups() {
    uint64 i = 0
    while i < fixup_count {
        uint64 fentry = fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 target_tok = 0
        unsafe { *(fe4 as uint32) -> target_tok }

        uint64 wtt = target_tok
        uint64 target_off = fn_lookup(wtt)
        if target_off != 0xFFFFFFFF {
            uint64 wpo = patch_off
            uint64 disp = target_off - wpo - 4
            patch_u32(wpo, disp)
        } else {
            write(2, "error: undefined function '", 27)
            uint64 ts = tok_text_start(wtt)
            uint64 tl = tok_text_len(wtt)
            write(2, cg_source + ts, tl)
            write(2, "'\n", 2)
            exit(1)
        }
        i = i + 1
    }
}

// Resolve fn_addr fixups: LEA rax, [rip + disp32] → patch disp to function address
fn resolve_fnaddr_fixups() {
    uint64 i = 0
    while i < fnaddr_fixup_count {
        uint64 fentry = fnaddr_fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 str_tok = 0
        unsafe { *(fe4 as uint32) -> str_tok }

        // The str_tok is a string literal token — content is between quotes
        uint64 wst = str_tok
        uint64 sstart = tok_text_start(wst)
        uint64 slen = tok_text_len(wst)
        // Skip quotes: "name" → name
        uint64 name_start = sstart + 1
        uint64 name_len = slen - 2

        // Search function table for matching name
        uint64 found = 0
        uint64 target_off = 0
        uint64 fi = 0
        while fi < fn_count {
            uint64 fentry2 = fn_table + fi * 8
            uint32 fn_name_tok = 0
            unsafe { *(fentry2 as uint32) -> fn_name_tok }
            uint64 wfn = fn_name_tok
            uint64 fn_start = tok_text_start(wfn)
            uint64 fn_len = tok_text_len(wfn)
            if fn_len == name_len {
                // Compare bytes
                uint64 eq = 1
                uint64 ci = 0
                while ci < name_len {
                    uint64 ca = cg_source + name_start + ci
                    uint64 cb = cg_source + fn_start + ci
                    uint64 va = 0
                    uint64 vb = 0
                    unsafe { *(ca as uint8) -> va }
                    unsafe { *(cb as uint8) -> vb }
                    if va != vb { eq = 0 }
                    ci = ci + 1
                }
                if eq != 0 {
                    uint64 fe4_2 = fentry2 + 4
                    uint32 foff = 0
                    unsafe { *(fe4_2 as uint32) -> foff }
                    target_off = foff
                    found = 1
                }
            }
            fi = fi + 1
        }

        if found != 0 {
            uint64 wpo = patch_off
            // LEA uses RIP-relative: disp = target - (patch_off + 4)
            uint64 disp = target_off - wpo - 4
            patch_u32(wpo, disp)
        } else {
            write(2, "error: fn_addr: undefined function '", 36)
            write(2, cg_source + name_start, name_len)
            write(2, "'\n", 2)
            exit(1)
        }
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// Dead Code Elimination (DCE) — AST-level
// ---------------------------------------------------------------------------

// DCE live set: token indices of functions that are reachable
// [name_tok(4)] × 2048
static uint64 dce_table = 0
static uint64 dce_count = 0

// DCE function map: maps function name tok → function AST node index
// [name_tok(4), fn_node(4)] × 1024
static uint64 dce_fn_map = 0
static uint64 dce_fn_map_count = 0

// DCE enabled flag (0 = disabled, 1 = enabled)
static uint64 dce_enabled = 0

@export
fn dce_init() {
    dce_table = alloc(2048 * 4)
    dce_count = 0
    dce_fn_map = alloc(1024 * 8)
    dce_fn_map_count = 0
    dce_enabled = 1
}

// Check if a function name token is already in the live set
fn dce_has(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < dce_count {
        uint64 entry = dce_table + i * 4
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 { return 1 }
        i = i + 1
    }
    return 0
}

// Add a function name token to the live set (if not already present)
// Returns 1 if newly added, 0 if already present
fn dce_add(uint64 name_tok) -> uint64 {
    if dce_has(name_tok) != 0 { return 0 }
    uint64 entry = dce_table + dce_count * 4
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    dce_count = dce_count + 1
    return 1
}

// Add a function name by string (for fn_addr string literals)
// str_tok is a string literal token — content is between quotes
fn dce_add_by_str(uint64 str_tok) {
    uint64 sstart = tok_text_start(str_tok)
    uint64 slen = tok_text_len(str_tok)
    // Skip quotes: "name" -> name
    uint64 name_start = sstart + 1
    uint64 name_len = slen - 2
    // Search function map for matching name
    uint64 i = 0
    while i < dce_fn_map_count {
        uint64 fentry = dce_fn_map + i * 8
        uint32 fn_name_tok = 0
        unsafe { *(fentry as uint32) -> fn_name_tok }
        uint64 wfn = fn_name_tok
        uint64 fn_start = tok_text_start(wfn)
        uint64 fn_len = tok_text_len(wfn)
        if fn_len == name_len {
            uint64 eq = 1
            uint64 ci = 0
            while ci < name_len {
                uint64 ca = cg_source + name_start + ci
                uint64 cb = cg_source + fn_start + ci
                uint64 va = 0
                uint64 vb = 0
                unsafe { *(ca as uint8) -> va }
                unsafe { *(cb as uint8) -> vb }
                if va != vb { eq = 0 }
                ci = ci + 1
            }
            if eq != 0 {
                dce_add(wfn)
                return
            }
        }
        i = i + 1
    }
    // Not found in function map — might be a builtin, ignore
}

// Register a function in the DCE function map
fn dce_register_fn(uint64 name_tok, uint64 fn_node) {
    uint64 entry = dce_fn_map + dce_fn_map_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 nd = fn_node
    unsafe { *(e4 as uint32) = nd }
    dce_fn_map_count = dce_fn_map_count + 1
}

// Look up function AST node by name token
fn dce_lookup_fn(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < dce_fn_map_count {
        uint64 entry = dce_fn_map + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 nd = 0
            unsafe { *(e4 as uint32) -> nd }
            return nd
        }
        i = i + 1
    }
    return 0
}

// Recursively scan an AST node for Call and fn_addr references
fn dce_scan_node(uint64 node) {
    if node == 0 { return }
    uint32 kind = ast_kind(node)

    // Call node: add callee to live set
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)
        uint64 wct = callee_tok
        // Check if this is fn_addr("name")
        if tok_matches(wct, "fn_addr", 7) != 0 {
            // First argument is a string literal with the target function name
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            if wfa != 0 {
                uint32 str_tok = ast_data1(wfa)
                dce_add_by_str(str_tok)
            }
        } else {
            // Regular call — add callee name to live set
            dce_add(wct)
        }
    }

    // Recurse into children
    uint32 ch = ast_child(node)
    uint64 wch = ch
    while wch != 0 {
        dce_scan_node(wch)
        uint32 nxt = ast_next(wch)
        wch = nxt
    }

    // FnDecl: data3=body block
    if kind == 2 {
        uint32 body = ast_data3(node)
        uint64 wb = body
        if wb != 0 { dce_scan_node(wb) }
    }

    // For nodes that store sub-node indices in data1/data2
    // If: data1=then_body, data2=else_body
    if kind == 13 {
        uint32 then_body = ast_data1(node)
        uint64 wtb = then_body
        if wtb != 0 { dce_scan_node(wtb) }
        uint32 else_body = ast_data2(node)
        uint64 web = else_body
        if web != 0 { dce_scan_node(web) }
    }
    // While: data1=body
    if kind == 14 {
        uint32 body = ast_data1(node)
        uint64 wb = body
        if wb != 0 { dce_scan_node(wb) }
    }
    // Match: data1=first_arm
    if kind == 19 {
        uint32 arm = ast_data1(node)
        uint64 wa = arm
        while wa != 0 {
            dce_scan_node(wa)
            uint32 nxt = ast_next(wa)
            wa = nxt
        }
    }
    // MatchArm: data1=value_expr, data2=body_block
    if kind == 20 {
        uint32 val_expr = ast_data1(node)
        uint64 wve = val_expr
        if wve != 0 { dce_scan_node(wve) }
        uint32 body_block = ast_data2(node)
        uint64 wbb = body_block
        if wbb != 0 { dce_scan_node(wbb) }
    }
    // BinOp: data2=rhs_idx
    if kind == 33 {
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        if wr != 0 { dce_scan_node(wr) }
    }
    // Compare: data2=rhs_idx
    if kind == 38 {
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        if wr != 0 { dce_scan_node(wr) }
    }
    // LogicalAnd: data1=op_tok, child=lhs, data2=rhs_idx
    if kind == 39 {
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        if wr != 0 { dce_scan_node(wr) }
    }
    // LogicalOr: data1=op_tok, child=lhs, data2=rhs_idx
    if kind == 40 {
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        if wr != 0 { dce_scan_node(wr) }
    }
    // Index: data1=array_name_tok (NOT a node), child=index_expr (handled above),
    //        data2=rhs_value (when used as assignment, 0 otherwise)
    if kind == 37 {
        uint32 idx_rhs = ast_data2(node)
        uint64 wir = idx_rhs
        if wir != 0 { dce_scan_node(wir) }
    }
    // FieldAccess: data3=value_expr (when used as assignment)
    if kind == 36 {
        uint32 fa_val = ast_data3(node)
        uint64 wfv = fa_val
        if wfv != 0 { dce_scan_node(wfv) }
    }
    // PtrStore: data2=val_expr (a node)
    if kind == 42 {
        uint32 ps_val = ast_data2(node)
        uint64 wpv = ps_val
        if wpv != 0 { dce_scan_node(wpv) }
    }
}

// Main DCE entry point: scan module, build live set with transitive closure
@export
fn dce_scan(uint64 mod_node) {
    // Phase 1: Build function map from module children
    uint32 child = ast_child(mod_node)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 name_tok = ast_data1(wchild)
            dce_register_fn(name_tok, wchild)
            // Seed with main and @export functions
            uint64 wnt = name_tok
            if tok_matches(wnt, "main", 4) != 0 {
                dce_add(wnt)
            }
            // Check if @export (data4 bit 2)
            uint32 ann = ast_data4(wchild)
            uint64 is_exp = ann & 4
            if is_exp != 0 {
                dce_add(wnt)
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }

    // Phase 2: Transitive closure — scan bodies of live functions
    // Keep iterating until no new functions are added
    uint64 prev_count = 0
    while prev_count != dce_count {
        prev_count = dce_count
        uint64 i = 0
        // Scan from the beginning each time (simple but correct)
        while i < dce_count {
            uint64 entry = dce_table + i * 4
            uint32 live_tok = 0
            unsafe { *(entry as uint32) -> live_tok }
            uint64 wlt = live_tok
            // Find the function body
            uint64 fn_node = dce_lookup_fn(wlt)
            if fn_node != 0 {
                // Scan the function body (children after params)
                dce_scan_node(fn_node)
            }
            i = i + 1
        }
    }
}

// Check if a function should be kept (is in the live set)
@export
fn dce_is_live(uint64 name_tok) -> uint64 {
    if dce_enabled == 0 { return 1 }
    if dce_count == 0 { return 1 }
    return dce_has(name_tok)
}

// ---------------------------------------------------------------------------
// ELF emission
// ---------------------------------------------------------------------------

@export
fn emit_elf_header() {
    emit_byte(0x7F)
    emit_byte(69)
    emit_byte(76)
    emit_byte(70)
    emit_byte(2)
    emit_byte(1)
    emit_byte(1)
    emit_byte(0)
    uint64 i = 0
    while i < 8 { emit_byte(0); i = i + 1 }
    emit_u16_le(2)
    emit_u16_le(0x3E)
    emit_u32_le(1)
    emit_u64_le(0)
    emit_u64_le(64)
    emit_u64_le(0)
    emit_u32_le(0)
    emit_u16_le(64)
    emit_u16_le(56)
    emit_u16_le(1)
    emit_u16_le(64)
    emit_u16_le(0)
    emit_u16_le(0)
}

@export
fn emit_program_header(uint64 text_size) {
    uint64 total = 120 + text_size
    emit_u32_le(1)
    emit_u32_le(7)
    emit_u64_le(0)
    emit_u64_le(0x400000)
    emit_u64_le(0x400000)
    emit_u64_le(total)
    emit_u64_le(total)
    emit_u64_le(0x200000)
}

// Emit an ELF relocatable object file (.o) wrapping the code already in out_buf.
// text_len = size of executable code (from offset 0)
// data_len = size of static data (immediately after code)
// arch: 0=x86_64, 1=aarch64
// The function copies the existing output, resets the buffer, and emits a proper
// ELF .o file with: ELF header, .text, .data, .symtab, .strtab, .shstrtab, section headers.
@export
fn emit_elf_relocatable(uint64 text_len, uint64 data_len, uint64 arch) {
    // Save the generated code+data blob
    uint64 blob_len = out_len
    uint64 blob = alloc(blob_len + 16)
    uint64 ci = 0
    while ci < blob_len {
        uint64 sp = out_buf + ci
        uint64 dp = blob + ci
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        ci = ci + 1
    }

    // Reset output buffer
    out_len = 0

    // Build section name string table (.shstrtab) content:
    // idx 0: \0
    // idx 1: .text\0       (6 bytes)
    // idx 7: .data\0       (6 bytes)
    // idx 13: .symtab\0    (8 bytes)
    // idx 21: .strtab\0    (8 bytes)
    // idx 29: .shstrtab\0  (10 bytes)
    // idx 39: .rela.text\0 (11 bytes) — only if extern_call_count > 0
    // Total: 39 or 50 bytes
    uint64 has_relocs = 0
    if extern_call_count > 0 { has_relocs = 1 }
    uint64 shstrtab_size = 39
    if has_relocs != 0 { shstrtab_size = 50 }

    // Build string table (.strtab) for symbol names:
    // idx 0: \0 (null symbol name)
    // idx 1: function names from fn_table, each null-terminated
    // We'll also compute symtab entries count.
    // Allocate temp buffer for strtab content
    uint64 strtab_buf = alloc(8192)
    uint64 strtab_len = 1  // start at 1 (index 0 = null byte)
    uint64 sb0 = strtab_buf
    uint8 nul = 0
    unsafe { *(sb0 as uint8) = nul }

    // Symtab: first entry is null (STN_UNDEF), then one per function,
    // then one per extern function.
    // Elf64_Sym = 24 bytes each
    uint64 sym_count = 1 + fn_count + extern_fn_count
    uint64 symtab_size = sym_count * 24

    // Build strtab: copy each function name from source
    // Also track name offsets for symtab
    uint64 name_offsets = alloc(fn_count * 8)
    uint64 fi = 0
    // Track which function index is "main" for making it GLOBAL
    uint64 main_fn_idx = 0xFFFFFFFF
    while fi < fn_count {
        uint64 fentry = fn_table + fi * 8
        uint32 stored_tok = 0
        unsafe { *(fentry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        // Store name offset
        uint64 no_ptr = name_offsets + fi * 8
        unsafe { *(no_ptr as uint64) = strtab_len }
        // Copy name bytes
        uint64 nstart = tok_text_start(ws)
        uint64 nlen = tok_text_len(ws)
        uint64 ni = 0
        while ni < nlen {
            uint64 src_p = cg_source + nstart + ni
            uint64 dst_p = strtab_buf + strtab_len
            uint64 ch = 0
            unsafe { *(src_p as uint8) -> ch }
            uint8 cb = ch
            unsafe { *(dst_p as uint8) = cb }
            strtab_len = strtab_len + 1
            ni = ni + 1
        }
        // Null terminate
        uint64 ntp = strtab_buf + strtab_len
        unsafe { *(ntp as uint8) = nul }
        strtab_len = strtab_len + 1
        // Check if this is "main"
        if tok_matches(ws, "main", 4) != 0 {
            main_fn_idx = fi
        }
        fi = fi + 1
    }

    // Append extern function names to strtab and record their offsets
    uint64 extern_name_offsets = 0
    if extern_fn_count > 0 {
        extern_name_offsets = alloc(extern_fn_count * 8)
        uint64 ei = 0
        while ei < extern_fn_count {
            uint64 xe = extern_fn_table + ei * 8
            uint32 xtok = 0
            unsafe { *(xe as uint32) -> xtok }
            uint64 wxt = xtok
            uint64 xno_ptr = extern_name_offsets + ei * 8
            unsafe { *(xno_ptr as uint64) = strtab_len }
            uint64 xnstart = tok_text_start(wxt)
            uint64 xnlen = tok_text_len(wxt)
            uint64 xni = 0
            while xni < xnlen {
                uint64 xsp = cg_source + xnstart + xni
                uint64 xdp = strtab_buf + strtab_len
                uint64 xc = 0
                unsafe { *(xsp as uint8) -> xc }
                uint8 xcb = xc
                unsafe { *(xdp as uint8) = xcb }
                strtab_len = strtab_len + 1
                xni = xni + 1
            }
            uint64 xntp = strtab_buf + strtab_len
            unsafe { *(xntp as uint8) = nul }
            strtab_len = strtab_len + 1
            ei = ei + 1
        }
    }

    // Layout:
    // 0x00: ELF header (64 bytes)
    // 0x40: .text section content (text_len bytes)
    // 0x40 + text_len: .data section content (data_len bytes)
    // then: .symtab (symtab_size bytes)
    // then: .strtab (strtab_len bytes)
    // then: .shstrtab (shstrtab_size bytes)
    // then: .rela.text (optional, only if externs exist)
    // then: section headers (6 or 7 * 64 bytes)

    uint64 rela_count = extern_call_count
    uint64 rela_size = rela_count * 24   // Elf64_Rela = 24 bytes

    uint64 elf_hdr_size = 64
    uint64 text_off = elf_hdr_size
    uint64 data_off = text_off + text_len
    uint64 symtab_off = data_off + data_len
    uint64 strtab_off = symtab_off + symtab_size
    uint64 shstrtab_off = strtab_off + strtab_len
    // Align .rela.text to 8 bytes
    uint64 rela_off = shstrtab_off + shstrtab_size
    uint64 rela_align_pad = (8 - (rela_off & 7)) & 7
    rela_off = rela_off + rela_align_pad
    // Align section headers to 8 bytes
    uint64 shdr_off = rela_off + rela_size
    uint64 shdr_align_pad = (8 - (shdr_off & 7)) & 7
    shdr_off = shdr_off + shdr_align_pad
    uint64 num_sections = 6  // null, .text, .data, .symtab, .strtab, .shstrtab
    if has_relocs != 0 { num_sections = 7 }  // + .rela.text

    // --- Emit ELF header (64 bytes) ---
    // e_ident[0..3]: magic
    emit_byte(0x7F); emit_byte(69); emit_byte(76); emit_byte(70)
    // e_ident[4]: class = ELFCLASS64
    emit_byte(2)
    // e_ident[5]: data = ELFDATA2LSB
    emit_byte(1)
    // e_ident[6]: version = EV_CURRENT
    emit_byte(1)
    // e_ident[7]: OS/ABI = ELFOSABI_NONE
    emit_byte(0)
    // e_ident[8..15]: padding
    uint64 pi = 0
    while pi < 8 { emit_byte(0); pi = pi + 1 }
    // e_type = ET_REL (1)
    emit_u16_le(1)
    // e_machine
    if arch == 0 {
        emit_u16_le(0x3E)  // EM_X86_64
    } else {
        emit_u16_le(0xB7)  // EM_AARCH64
    }
    // e_version = 1
    emit_u32_le(1)
    // e_entry = 0 (no entry point for .o)
    emit_u64_le(0)
    // e_phoff = 0 (no program headers)
    emit_u64_le(0)
    // e_shoff = offset to section headers
    emit_u64_le(shdr_off)
    // e_flags = 0
    emit_u32_le(0)
    // e_ehsize = 64
    emit_u16_le(64)
    // e_phentsize = 0 (no program headers)
    emit_u16_le(0)
    // e_phnum = 0
    emit_u16_le(0)
    // e_shentsize = 64
    emit_u16_le(64)
    // e_shnum = number of sections
    emit_u16_le(num_sections)
    // e_shstrndx = 5 (.shstrtab is section 5)
    emit_u16_le(5)

    // --- Emit .text section content ---
    ci = 0
    while ci < text_len {
        uint64 p = blob + ci
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        ci = ci + 1
    }

    // --- Emit .data section content ---
    ci = 0
    while ci < data_len {
        uint64 p = blob + text_len + ci
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        ci = ci + 1
    }

    // --- Emit .symtab ---
    // Entry 0: STN_UNDEF (24 zero bytes)
    uint64 si = 0
    while si < 24 { emit_byte(0); si = si + 1 }

    // Entries for each function
    fi = 0
    // Count local symbols: everything except main (which is GLOBAL)
    // STB_LOCAL symbols must come before STB_GLOBAL in symtab
    // info field = (binding << 4) | type
    // We emit locals first, then globals.
    // First pass: emit LOCAL functions (not main)
    uint64 local_count = 1  // include null symbol
    fi = 0
    while fi < fn_count {
        if fi != main_fn_idx {
            uint64 no_ptr = name_offsets + fi * 8
            uint64 name_off = 0
            unsafe { *(no_ptr as uint64) -> name_off }
            // st_name
            emit_u32_le(name_off)
            // st_info = STB_LOCAL(0) << 4 | STT_FUNC(2) = 0x02
            emit_byte(0x02)
            // st_other = 0
            emit_byte(0)
            // st_shndx = 1 (.text section)
            emit_u16_le(1)
            // st_value = offset within .text section
            uint64 fentry = fn_table + fi * 8
            uint64 fe4 = fentry + 4
            uint32 code_off = 0
            unsafe { *(fe4 as uint32) -> code_off }
            emit_u64_le(code_off)
            // st_size = 0
            emit_u64_le(0)
            local_count = local_count + 1
        }
        fi = fi + 1
    }

    // Second pass: emit GLOBAL functions (main)
    if main_fn_idx != 0xFFFFFFFF {
        uint64 no_ptr = name_offsets + main_fn_idx * 8
        uint64 name_off = 0
        unsafe { *(no_ptr as uint64) -> name_off }
        // st_name
        emit_u32_le(name_off)
        // st_info = STB_GLOBAL(1) << 4 | STT_FUNC(2) = 0x12
        emit_byte(0x12)
        // st_other = 0
        emit_byte(0)
        // st_shndx = 1 (.text section)
        emit_u16_le(1)
        // st_value = offset within .text
        uint64 fentry = fn_table + main_fn_idx * 8
        uint64 fe4 = fentry + 4
        uint32 code_off = 0
        unsafe { *(fe4 as uint32) -> code_off }
        emit_u64_le(code_off)
        // st_size = 0
        emit_u64_le(0)
    }

    // Third pass: emit extern function symbols (GLOBAL, STT_NOTYPE, SHN_UNDEF).
    // The linker resolves these when producing the final executable.
    uint64 extern_sym_base = local_count
    if main_fn_idx != 0xFFFFFFFF { extern_sym_base = extern_sym_base + 1 }
    uint64 ei2 = 0
    while ei2 < extern_fn_count {
        uint64 xno_ptr2 = extern_name_offsets + ei2 * 8
        uint64 xname_off = 0
        unsafe { *(xno_ptr2 as uint64) -> xname_off }
        // st_name
        emit_u32_le(xname_off)
        // st_info = STB_GLOBAL(1) << 4 | STT_NOTYPE(0) = 0x10
        emit_byte(0x10)
        // st_other = 0
        emit_byte(0)
        // st_shndx = 0 (SHN_UNDEF — linker resolves)
        emit_u16_le(0)
        // st_value = 0
        emit_u64_le(0)
        // st_size = 0
        emit_u64_le(0)
        ei2 = ei2 + 1
    }

    // --- Emit .strtab ---
    ci = 0
    while ci < strtab_len {
        uint64 p = strtab_buf + ci
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        ci = ci + 1
    }

    // --- Emit .shstrtab ---
    // \0
    emit_byte(0)
    // .text\0
    emit_byte(46); emit_byte(116); emit_byte(101); emit_byte(120); emit_byte(116); emit_byte(0)
    // .data\0
    emit_byte(46); emit_byte(100); emit_byte(97); emit_byte(116); emit_byte(97); emit_byte(0)
    // .symtab\0
    emit_byte(46); emit_byte(115); emit_byte(121); emit_byte(109); emit_byte(116); emit_byte(97); emit_byte(98); emit_byte(0)
    // .strtab\0
    emit_byte(46); emit_byte(115); emit_byte(116); emit_byte(114); emit_byte(116); emit_byte(97); emit_byte(98); emit_byte(0)
    // .shstrtab\0
    emit_byte(46); emit_byte(115); emit_byte(104); emit_byte(115); emit_byte(116); emit_byte(114); emit_byte(116); emit_byte(97); emit_byte(98); emit_byte(0)
    if has_relocs != 0 {
        // .rela.text\0
        emit_byte(46); emit_byte(114); emit_byte(101); emit_byte(108); emit_byte(97)
        emit_byte(46); emit_byte(116); emit_byte(101); emit_byte(120); emit_byte(116); emit_byte(0)
    }

    // --- Emit .rela.text section content ---
    if has_relocs != 0 {
        // Align to 8
        pi = 0
        while pi < rela_align_pad { emit_byte(0); pi = pi + 1 }
        uint64 ri = 0
        while ri < rela_count {
            uint64 re = extern_call_sites + ri * 16
            uint32 rco = 0
            unsafe { *(re as uint32) -> rco }
            uint64 re4 = re + 4
            uint32 xidx = 0
            unsafe { *(re4 as uint32) -> xidx }
            uint64 wxi = xidx
            uint64 sym_idx = extern_sym_base + wxi
            // r_offset: code offset inside .text
            emit_u64_le(rco)
            // r_info: (sym_idx << 32) | type
            // x86_64: R_X86_64_PLT32 = 4;  ARM64: R_AARCH64_CALL26 = 283
            uint64 rtype = 4
            if arch == 1 { rtype = 283 }
            uint64 r_info = (sym_idx << 32) | rtype
            emit_u64_le(r_info)
            // r_addend: x86_64 wants -4, ARM64 wants 0
            if arch == 1 {
                emit_u64_le(0)
            } else {
                // -4 as 64-bit two's complement
                emit_u64_le(0xFFFFFFFFFFFFFFFC)
            }
            ri = ri + 1
        }
    }

    // --- Alignment padding before section headers ---
    pi = 0
    while pi < shdr_align_pad { emit_byte(0); pi = pi + 1 }

    // --- Section Headers (6 entries, 64 bytes each) ---

    // Section 0: SHN_UNDEF (64 zero bytes)
    si = 0
    while si < 64 { emit_byte(0); si = si + 1 }

    // Section 1: .text
    emit_u32_le(1)          // sh_name (offset 1 in .shstrtab)
    emit_u32_le(1)          // sh_type = SHT_PROGBITS
    emit_u64_le(6)          // sh_flags = SHF_ALLOC | SHF_EXECINSTR
    emit_u64_le(0)          // sh_addr = 0 (relocatable)
    emit_u64_le(text_off)   // sh_offset
    emit_u64_le(text_len)   // sh_size
    emit_u32_le(0)          // sh_link
    emit_u32_le(0)          // sh_info
    emit_u64_le(16)         // sh_addralign
    emit_u64_le(0)          // sh_entsize

    // Section 2: .data
    emit_u32_le(7)          // sh_name (offset 7 in .shstrtab)
    emit_u32_le(1)          // sh_type = SHT_PROGBITS
    emit_u64_le(3)          // sh_flags = SHF_ALLOC | SHF_WRITE
    emit_u64_le(0)          // sh_addr = 0
    emit_u64_le(data_off)   // sh_offset
    emit_u64_le(data_len)   // sh_size
    emit_u32_le(0)          // sh_link
    emit_u32_le(0)          // sh_info
    emit_u64_le(8)          // sh_addralign
    emit_u64_le(0)          // sh_entsize

    // Section 3: .symtab
    emit_u32_le(13)         // sh_name (offset 13 in .shstrtab)
    emit_u32_le(2)          // sh_type = SHT_SYMTAB
    emit_u64_le(0)          // sh_flags = 0
    emit_u64_le(0)          // sh_addr = 0
    emit_u64_le(symtab_off) // sh_offset
    emit_u64_le(symtab_size) // sh_size
    emit_u32_le(4)          // sh_link = index of .strtab (section 4)
    emit_u32_le(local_count) // sh_info = one past last local symbol
    emit_u64_le(8)          // sh_addralign
    emit_u64_le(24)         // sh_entsize = sizeof(Elf64_Sym)

    // Section 4: .strtab
    emit_u32_le(21)         // sh_name (offset 21 in .shstrtab)
    emit_u32_le(3)          // sh_type = SHT_STRTAB
    emit_u64_le(0)          // sh_flags = 0
    emit_u64_le(0)          // sh_addr = 0
    emit_u64_le(strtab_off) // sh_offset
    emit_u64_le(strtab_len) // sh_size
    emit_u32_le(0)          // sh_link
    emit_u32_le(0)          // sh_info
    emit_u64_le(1)          // sh_addralign
    emit_u64_le(0)          // sh_entsize

    // Section 5: .shstrtab
    emit_u32_le(29)         // sh_name (offset 29 in .shstrtab)
    emit_u32_le(3)          // sh_type = SHT_STRTAB
    emit_u64_le(0)          // sh_flags = 0
    emit_u64_le(0)          // sh_addr = 0
    emit_u64_le(shstrtab_off) // sh_offset
    emit_u64_le(shstrtab_size) // sh_size
    emit_u32_le(0)          // sh_link
    emit_u32_le(0)          // sh_info
    emit_u64_le(1)          // sh_addralign
    emit_u64_le(0)          // sh_entsize

    // Section 6: .rela.text (only if we have extern call sites)
    if has_relocs != 0 {
        emit_u32_le(39)         // sh_name (offset 39 in .shstrtab)
        emit_u32_le(4)          // sh_type = SHT_RELA
        emit_u64_le(0x40)       // sh_flags = SHF_INFO_LINK
        emit_u64_le(0)          // sh_addr = 0
        emit_u64_le(rela_off)   // sh_offset
        emit_u64_le(rela_size)  // sh_size
        emit_u32_le(3)          // sh_link = index of .symtab (section 3)
        emit_u32_le(1)          // sh_info = index of .text (section 1)
        emit_u64_le(8)          // sh_addralign
        emit_u64_le(24)         // sh_entsize = sizeof(Elf64_Rela)
    }
}

// ---------------------------------------------------------------------------
// Mach-O relocatable (MH_OBJECT) emission — macOS .o files
// Layout:
//   [0]   Mach header (32 bytes)
//   [32]  LC_SEGMENT_64 + __text section (152 bytes)
//   [184] LC_SYMTAB (24 bytes)
//   [208] LC_DYSYMTAB (80 bytes)
//   [288] __text content (text_len bytes, padded to 8)
//   [...]  relocation_info entries (8 * nreloc)
//   [...]  nlist_64 symbol table (16 * nsyms)
//   [...]  string table (strings for symbols)
//
// Mach-O C ABI prepends '_' to symbol names (_main, _write, ...).
// Relocations: X86_64_RELOC_BRANCH(2) on x86_64, ARM64_RELOC_BRANCH26(2) on arm64.
@export
fn emit_macho_relocatable(uint64 text_len, uint64 data_len, uint64 arch) {
    // Save the generated code blob (text + data are already in out_buf).
    uint64 blob_len = out_len
    uint64 blob = alloc(blob_len + 16)
    uint64 mi = 0
    while mi < blob_len {
        uint64 sp = out_buf + mi
        uint64 dp = blob + mi
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        mi = mi + 1
    }
    out_len = 0

    // Merge text+data into one section (we use the same trick as ELF).
    uint64 section_size = text_len + data_len

    // Build string table:
    //   idx 0: \0 (null)
    //   idx 1: _<fn_name>\0 for each local/main
    //   idx N: _<extern_name>\0 for each extern
    uint64 strtab_buf = alloc(8192)
    uint64 strtab_len = 1
    uint64 sb0 = strtab_buf
    uint8 nul = 0
    unsafe { *(sb0 as uint8) = nul }

    // Track main fn index; track strtab offsets for each symbol
    uint64 fn_str_offs = alloc(fn_count * 8)
    uint64 main_fn_idx = 0xFFFFFFFF
    uint64 mfi = 0
    while mfi < fn_count {
        uint64 fentry = fn_table + mfi * 8
        uint32 stored_tok = 0
        unsafe { *(fentry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        uint64 fop = fn_str_offs + mfi * 8
        unsafe { *(fop as uint64) = strtab_len }
        // underscore prefix
        uint64 dstp = strtab_buf + strtab_len
        uint8 usb = 95
        unsafe { *(dstp as uint8) = usb }
        strtab_len = strtab_len + 1
        uint64 nstart = tok_text_start(ws)
        uint64 nlen = tok_text_len(ws)
        uint64 ni = 0
        while ni < nlen {
            uint64 src_p = cg_source + nstart + ni
            uint64 dst_p = strtab_buf + strtab_len
            uint64 ch = 0
            unsafe { *(src_p as uint8) -> ch }
            uint8 cb = ch
            unsafe { *(dst_p as uint8) = cb }
            strtab_len = strtab_len + 1
            ni = ni + 1
        }
        uint64 ntp = strtab_buf + strtab_len
        unsafe { *(ntp as uint8) = nul }
        strtab_len = strtab_len + 1
        if tok_matches(ws, "main", 4) != 0 { main_fn_idx = mfi }
        mfi = mfi + 1
    }

    // Extern names
    uint64 ext_str_offs = 0
    if extern_fn_count > 0 {
        ext_str_offs = alloc(extern_fn_count * 8)
        uint64 mei = 0
        while mei < extern_fn_count {
            uint64 xe = extern_fn_table + mei * 8
            uint32 xtok = 0
            unsafe { *(xe as uint32) -> xtok }
            uint64 wxt = xtok
            uint64 xop = ext_str_offs + mei * 8
            unsafe { *(xop as uint64) = strtab_len }
            uint64 mdstp = strtab_buf + strtab_len
            uint8 musb = 95
            unsafe { *(mdstp as uint8) = musb }
            strtab_len = strtab_len + 1
            uint64 xnstart = tok_text_start(wxt)
            uint64 xnlen = tok_text_len(wxt)
            uint64 xni = 0
            while xni < xnlen {
                uint64 xsp = cg_source + xnstart + xni
                uint64 xdp = strtab_buf + strtab_len
                uint64 xc = 0
                unsafe { *(xsp as uint8) -> xc }
                uint8 xcb = xc
                unsafe { *(xdp as uint8) = xcb }
                strtab_len = strtab_len + 1
                xni = xni + 1
            }
            uint64 xntp = strtab_buf + strtab_len
            unsafe { *(xntp as uint8) = nul }
            strtab_len = strtab_len + 1
            mei = mei + 1
        }
    }

    // Layout offsets
    uint64 hdr_size = 288  // mach_header + LC_SEGMENT_64 + LC_SYMTAB + LC_DYSYMTAB
    uint64 text_off = hdr_size
    uint64 text_end = text_off + section_size
    // Align to 8
    uint64 pad_text = (8 - (text_end & 7)) & 7
    uint64 reloc_off = text_end + pad_text
    uint64 nreloc = extern_call_count
    uint64 reloc_end = reloc_off + nreloc * 8
    uint64 sym_count = 0
    if main_fn_idx != 0xFFFFFFFF { sym_count = 1 }
    sym_count = sym_count + extern_fn_count
    // Add local (non-main) functions as N_SECT (not strictly needed but keeps parity)
    uint64 local_sym_count = fn_count - sym_count + extern_fn_count
    // Actually, we emit: locals first (non-main fns), then extdef (main), then undef (externs).
    uint64 nlocal = 0
    if main_fn_idx != 0xFFFFFFFF {
        nlocal = fn_count - 1
    } else {
        nlocal = fn_count
    }
    uint64 nextdef = 0
    if main_fn_idx != 0xFFFFFFFF { nextdef = 1 }
    uint64 nundef = extern_fn_count
    uint64 total_syms = nlocal + nextdef + nundef
    uint64 symtab_off = reloc_end
    uint64 symtab_size = total_syms * 16
    uint64 stroff = symtab_off + symtab_size

    // --- Mach header (32 bytes) ---
    emit_u32_le(0xFEEDFACF)          // magic 64
    if arch == 0 {
        emit_u32_le(0x01000007)      // CPU_TYPE_X86_64
        emit_u32_le(3)               // CPU_SUBTYPE_X86_64_ALL
    } else {
        emit_u32_le(0x0100000C)      // CPU_TYPE_ARM64
        emit_u32_le(0)               // CPU_SUBTYPE_ARM64_ALL
    }
    emit_u32_le(1)                   // MH_OBJECT
    emit_u32_le(3)                   // ncmds
    emit_u32_le(152 + 24 + 80)       // sizeofcmds = 256
    emit_u32_le(0x2000)              // MH_SUBSECTIONS_VIA_SYMBOLS
    emit_u32_le(0)                   // reserved

    // --- LC_SEGMENT_64 (72 header + 80 section = 152) ---
    emit_u32_le(0x19)                // LC_SEGMENT_64
    emit_u32_le(152)                 // cmdsize
    // segname: empty (16 bytes of zero)
    uint64 pi = 0
    while pi < 16 { emit_byte(0); pi = pi + 1 }
    emit_u64_le(0)                   // vmaddr
    emit_u64_le(section_size)        // vmsize
    emit_u64_le(text_off)            // fileoff
    emit_u64_le(section_size)        // filesize
    emit_u32_le(7)                   // maxprot
    emit_u32_le(7)                   // initprot
    emit_u32_le(1)                   // nsects
    emit_u32_le(0)                   // flags

    // Section: __text,__TEXT
    // sectname "__text"
    emit_byte(95); emit_byte(95); emit_byte(116); emit_byte(101)
    emit_byte(120); emit_byte(116); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    // segname "__TEXT"
    emit_byte(95); emit_byte(95); emit_byte(84); emit_byte(69)
    emit_byte(88); emit_byte(84); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0)                   // addr
    emit_u64_le(section_size)        // size
    emit_u32_le(text_off)            // offset
    emit_u32_le(4)                   // align = 2^4 = 16
    emit_u32_le(reloc_off)           // reloff
    emit_u32_le(nreloc)              // nreloc
    emit_u32_le(0x80000400)          // S_ATTR_PURE_INSTRUCTIONS | S_ATTR_SOME_INSTRUCTIONS
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)  // reserved

    // --- LC_SYMTAB (24 bytes) ---
    emit_u32_le(2)                   // LC_SYMTAB
    emit_u32_le(24)                  // cmdsize
    emit_u32_le(symtab_off)          // symoff
    emit_u32_le(total_syms)          // nsyms
    emit_u32_le(stroff)              // stroff
    emit_u32_le(strtab_len)          // strsize

    // --- LC_DYSYMTAB (80 bytes) ---
    emit_u32_le(0xB)                 // LC_DYSYMTAB
    emit_u32_le(80)                  // cmdsize
    emit_u32_le(0)                   // ilocalsym
    emit_u32_le(nlocal)              // nlocalsym
    emit_u32_le(nlocal)              // iextdefsym
    emit_u32_le(nextdef)             // nextdefsym
    emit_u32_le(nlocal + nextdef)    // iundefsym
    emit_u32_le(nundef)              // nundefsym
    emit_u32_le(0); emit_u32_le(0)   // tocoff, ntoc
    emit_u32_le(0); emit_u32_le(0)   // modtaboff, nmodtab
    emit_u32_le(0); emit_u32_le(0)   // extrefsymoff, nextrefsyms
    emit_u32_le(0); emit_u32_le(0)   // indirectsymoff, nindirectsyms
    emit_u32_le(0); emit_u32_le(0)   // extreloff, nextrel
    emit_u32_le(0); emit_u32_le(0)   // locreloff, nlocrel

    // --- Section content ---
    mi = 0
    while mi < section_size {
        uint64 p = blob + mi
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        mi = mi + 1
    }
    // Align to 8 before relocations
    pi = 0
    while pi < pad_text { emit_byte(0); pi = pi + 1 }

    // --- Relocations ---
    // Symbol index for externs starts at nlocal + nextdef.
    uint64 undef_base = nlocal + nextdef
    uint64 ri = 0
    while ri < nreloc {
        uint64 re = extern_call_sites + ri * 16
        uint32 rco = 0
        unsafe { *(re as uint32) -> rco }
        uint64 re4 = re + 4
        uint32 xidx = 0
        unsafe { *(re4 as uint32) -> xidx }
        uint64 wxi = xidx
        uint64 sym_idx = undef_base + wxi
        // r_address
        emit_u32_le(rco)
        // r_symbolnum(24) | r_pcrel(1) | r_length(2) | r_extern(1) | r_type(4)
        // Layout (LSB first): symbolnum[0..23], pcrel[24], length[25..26], extern[27], type[28..31]
        uint64 info = sym_idx
        info = info | (1 << 24)            // r_pcrel
        info = info | (2 << 25)            // r_length = 2 (4 bytes)
        info = info | (1 << 27)            // r_extern
        // r_type: X86_64_RELOC_BRANCH(2) or ARM64_RELOC_BRANCH26(2)
        info = info | (2 << 28)
        emit_u32_le(info)
        ri = ri + 1
    }

    // --- nlist_64 symbol table ---
    // 1) Locals: all non-main functions (N_SECT | external=0)
    uint64 sfi = 0
    while sfi < fn_count {
        if sfi != main_fn_idx {
            uint64 fop2 = fn_str_offs + sfi * 8
            uint64 so = 0
            unsafe { *(fop2 as uint64) -> so }
            emit_u32_le(so)             // n_strx
            emit_byte(0x0E)             // n_type = N_SECT
            emit_byte(1)                // n_sect = 1 (__text)
            emit_u16_le(0)              // n_desc
            // n_value = code offset
            uint64 fentry2 = fn_table + sfi * 8
            uint64 fe4b = fentry2 + 4
            uint32 code_off = 0
            unsafe { *(fe4b as uint32) -> code_off }
            emit_u64_le(code_off)
        }
        sfi = sfi + 1
    }
    // 2) Extdef: main
    if main_fn_idx != 0xFFFFFFFF {
        uint64 fop3 = fn_str_offs + main_fn_idx * 8
        uint64 so2 = 0
        unsafe { *(fop3 as uint64) -> so2 }
        emit_u32_le(so2)
        emit_byte(0x0F)             // N_SECT | N_EXT
        emit_byte(1)
        emit_u16_le(0)
        uint64 fentry3 = fn_table + main_fn_idx * 8
        uint64 fe4c = fentry3 + 4
        uint32 mc_off = 0
        unsafe { *(fe4c as uint32) -> mc_off }
        emit_u64_le(mc_off)
    }
    // 3) Undef: externs
    uint64 ei3 = 0
    while ei3 < extern_fn_count {
        uint64 xop3 = ext_str_offs + ei3 * 8
        uint64 so3 = 0
        unsafe { *(xop3 as uint64) -> so3 }
        emit_u32_le(so3)
        emit_byte(0x01)             // N_UNDF | N_EXT
        emit_byte(0)                // no section
        emit_u16_le(0)
        emit_u64_le(0)
        ei3 = ei3 + 1
    }

    // --- String table ---
    mi = 0
    while mi < strtab_len {
        uint64 p = strtab_buf + mi
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        mi = mi + 1
    }
}

// ---------------------------------------------------------------------------
// COFF relocatable (.obj) emission — Windows object files
// Layout:
//   [0]  COFF file header (20 bytes)
//   [20] Section header .text (40 bytes)
//   [60] Section raw data (text_len bytes)
//   [...] Relocations (10 bytes each)
//   [...] Symbol table (18 bytes each)
//   [...] String table
//
// COFF symbols ≤ 8 bytes go in-place; longer names use the string table.
// Windows x64 doesn't prepend '_' (unlike 32-bit).
@export
fn emit_coff_relocatable(uint64 text_len, uint64 data_len, uint64 arch) {
    uint64 blob_len = out_len
    uint64 blob = alloc(blob_len + 16)
    uint64 ci = 0
    while ci < blob_len {
        uint64 sp = out_buf + ci
        uint64 dp = blob + ci
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        ci = ci + 1
    }
    out_len = 0

    uint64 section_size = text_len + data_len

    // Symbol order: non-main fns (STATIC), main (EXTERNAL), externs (EXTERNAL UNDEF)
    uint64 main_fn_idx = 0xFFFFFFFF
    uint64 ci_mf = 0
    while ci_mf < fn_count {
        uint64 fentry = fn_table + ci_mf * 8
        uint32 stored_tok = 0
        unsafe { *(fentry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_matches(ws, "main", 4) != 0 { main_fn_idx = ci_mf }
        ci_mf = ci_mf + 1
    }

    uint64 total_syms = fn_count + extern_fn_count
    uint64 sym_size = total_syms * 18

    // Build string table up front so we know its size.
    // String table starts with a 4-byte length field (inclusive of itself).
    uint64 strtab_buf = alloc(8192)
    uint64 strtab_len = 4  // reserve first 4 bytes for length
    // Store 4 bytes of zeros initially (we'll fill at the end)
    uint64 sb0 = strtab_buf
    uint8 zb = 0
    unsafe { *(sb0 as uint8) = zb }
    uint64 sb1 = strtab_buf + 1
    unsafe { *(sb1 as uint8) = zb }
    uint64 sb2 = strtab_buf + 2
    unsafe { *(sb2 as uint8) = zb }
    uint64 sb3 = strtab_buf + 3
    unsafe { *(sb3 as uint8) = zb }

    // For each symbol, decide: inline (≤8 bytes) or string-table offset
    // We record: inline_flag (u8), 8 inline bytes, or strtab offset (u32).
    uint64 sym_meta = alloc(total_syms * 16)
    uint64 smi = 0
    while smi < fn_count {
        uint64 fentry = fn_table + smi * 8
        uint32 stored_tok = 0
        unsafe { *(fentry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        uint64 nstart = tok_text_start(ws)
        uint64 nlen = tok_text_len(ws)
        uint64 mp = sym_meta + smi * 16
        if nlen <= 8 {
            uint8 one = 1
            unsafe { *(mp as uint8) = one }
            uint64 ki = 0
            while ki < 8 {
                uint64 cp = mp + 1 + ki
                if ki < nlen {
                    uint64 srcp = cg_source + nstart + ki
                    uint64 cv = 0
                    unsafe { *(srcp as uint8) -> cv }
                    uint8 cb = cv
                    unsafe { *(cp as uint8) = cb }
                } else {
                    uint8 zz = 0
                    unsafe { *(cp as uint8) = zz }
                }
                ki = ki + 1
            }
        } else {
            uint8 zero = 0
            unsafe { *(mp as uint8) = zero }
            // store strtab offset at mp+9 (u32)
            uint64 op = mp + 9
            uint32 stoff = strtab_len
            unsafe { *(op as uint32) = stoff }
            // append name + null
            uint64 ci2 = 0
            while ci2 < nlen {
                uint64 srcp = cg_source + nstart + ci2
                uint64 dstp = strtab_buf + strtab_len
                uint64 cv = 0
                unsafe { *(srcp as uint8) -> cv }
                uint8 cb = cv
                unsafe { *(dstp as uint8) = cb }
                strtab_len = strtab_len + 1
                ci2 = ci2 + 1
            }
            uint64 ntp = strtab_buf + strtab_len
            uint8 nul2 = 0
            unsafe { *(ntp as uint8) = nul2 }
            strtab_len = strtab_len + 1
        }
        smi = smi + 1
    }

    // Extern symbols
    uint64 esi = 0
    while esi < extern_fn_count {
        uint64 xe = extern_fn_table + esi * 8
        uint32 xtok = 0
        unsafe { *(xe as uint32) -> xtok }
        uint64 wxt = xtok
        uint64 xnstart = tok_text_start(wxt)
        uint64 xnlen = tok_text_len(wxt)
        uint64 emp = sym_meta + (fn_count + esi) * 16
        if xnlen <= 8 {
            uint8 one = 1
            unsafe { *(emp as uint8) = one }
            uint64 ki = 0
            while ki < 8 {
                uint64 cp = emp + 1 + ki
                if ki < xnlen {
                    uint64 srcp = cg_source + xnstart + ki
                    uint64 cv = 0
                    unsafe { *(srcp as uint8) -> cv }
                    uint8 cb = cv
                    unsafe { *(cp as uint8) = cb }
                } else {
                    uint8 zz = 0
                    unsafe { *(cp as uint8) = zz }
                }
                ki = ki + 1
            }
        } else {
            uint8 zero = 0
            unsafe { *(emp as uint8) = zero }
            uint64 op = emp + 9
            uint32 stoff = strtab_len
            unsafe { *(op as uint32) = stoff }
            uint64 ci3 = 0
            while ci3 < xnlen {
                uint64 srcp = cg_source + xnstart + ci3
                uint64 dstp = strtab_buf + strtab_len
                uint64 cv = 0
                unsafe { *(srcp as uint8) -> cv }
                uint8 cb = cv
                unsafe { *(dstp as uint8) = cb }
                strtab_len = strtab_len + 1
                ci3 = ci3 + 1
            }
            uint64 ntp = strtab_buf + strtab_len
            uint8 nul2 = 0
            unsafe { *(ntp as uint8) = nul2 }
            strtab_len = strtab_len + 1
        }
        esi = esi + 1
    }

    // Now write the 4-byte length into strtab_buf[0..4]
    uint64 sbp0 = strtab_buf
    uint32 stl = strtab_len
    unsafe { *(sbp0 as uint32) = stl }

    // Layout
    uint64 hdr_size = 20
    uint64 sec_hdr_size = 40
    uint64 text_off = hdr_size + sec_hdr_size  // 60
    uint64 nreloc = extern_call_count
    uint64 reloc_off = text_off + section_size
    uint64 reloc_size = nreloc * 10
    uint64 symtab_off = reloc_off + reloc_size
    uint64 stroff = symtab_off + sym_size  // string table comes right after

    // --- COFF file header (20 bytes) ---
    if arch == 0 {
        emit_u16_le(0x8664)          // IMAGE_FILE_MACHINE_AMD64
    } else {
        emit_u16_le(0xAA64)          // IMAGE_FILE_MACHINE_ARM64
    }
    emit_u16_le(1)                   // NumberOfSections
    emit_u32_le(0)                   // TimeDateStamp
    emit_u32_le(symtab_off)          // PointerToSymbolTable
    emit_u32_le(total_syms)          // NumberOfSymbols
    emit_u16_le(0)                   // SizeOfOptionalHeader
    emit_u16_le(0)                   // Characteristics

    // --- Section header: .text (40 bytes) ---
    // Name = ".text\0\0\0"
    emit_byte(46); emit_byte(116); emit_byte(101); emit_byte(120)
    emit_byte(116); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u32_le(0)                   // VirtualSize
    emit_u32_le(0)                   // VirtualAddress
    emit_u32_le(section_size)        // SizeOfRawData
    emit_u32_le(text_off)            // PointerToRawData
    emit_u32_le(reloc_off)           // PointerToRelocations
    emit_u32_le(0)                   // PointerToLineNumbers
    emit_u16_le(nreloc)              // NumberOfRelocations
    emit_u16_le(0)                   // NumberOfLineNumbers
    // Characteristics:
    // 0x00000020 CNT_CODE | 0x00500000 ALIGN_16BYTES | 0x20000000 EXECUTE | 0x40000000 READ
    emit_u32_le(0x60500020)

    // --- Section raw data ---
    ci = 0
    while ci < section_size {
        uint64 p = blob + ci
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        ci = ci + 1
    }

    // --- Relocations ---
    uint64 undef_base = fn_count
    uint64 ri = 0
    while ri < nreloc {
        uint64 re = extern_call_sites + ri * 16
        uint32 rco = 0
        unsafe { *(re as uint32) -> rco }
        uint64 re4 = re + 4
        uint32 xidx = 0
        unsafe { *(re4 as uint32) -> xidx }
        uint64 wxi = xidx
        uint64 sym_idx = undef_base + wxi
        emit_u32_le(rco)             // VirtualAddress
        emit_u32_le(sym_idx)         // SymbolTableIndex
        if arch == 0 {
            emit_u16_le(4)           // IMAGE_REL_AMD64_REL32
        } else {
            emit_u16_le(3)           // IMAGE_REL_ARM64_BRANCH26
        }
        ri = ri + 1
    }

    // --- Symbol table ---
    uint64 wi = 0
    while wi < total_syms {
        uint64 mp = sym_meta + wi * 16
        uint64 inlv = 0
        unsafe { *(mp as uint8) -> inlv }
        if inlv != 0 {
            // Emit 8 inline bytes
            uint64 bi = 0
            while bi < 8 {
                uint64 cp = mp + 1 + bi
                uint64 cv = 0
                unsafe { *(cp as uint8) -> cv }
                uint8 cb = cv
                emit_byte(cb)
                bi = bi + 1
            }
        } else {
            emit_u32_le(0)
            uint64 op = mp + 9
            uint32 stoff2 = 0
            unsafe { *(op as uint32) -> stoff2 }
            emit_u32_le(stoff2)
        }
        // Value, SectionNumber, Type, StorageClass, NumAux
        if wi < fn_count {
            // Function defined in this unit
            uint64 fentry = fn_table + wi * 8
            uint64 fe4 = fentry + 4
            uint32 code_off = 0
            unsafe { *(fe4 as uint32) -> code_off }
            emit_u32_le(code_off)        // Value
            emit_u16_le(1)               // SectionNumber = 1
            emit_u16_le(0x20)            // Type = function
            if wi == main_fn_idx {
                emit_byte(2)             // EXTERNAL
            } else {
                emit_byte(3)             // STATIC (internal)
            }
            emit_byte(0)                 // NumAux
        } else {
            // Extern (undefined)
            emit_u32_le(0)               // Value
            emit_u16_le(0)               // SectionNumber = 0 (undef)
            emit_u16_le(0x20)            // Type = function
            emit_byte(2)                 // EXTERNAL
            emit_byte(0)                 // NumAux
        }
        wi = wi + 1
    }

    // --- String table ---
    ci = 0
    while ci < strtab_len {
        uint64 p = strtab_buf + ci
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        ci = ci + 1
    }
}

@export
fn codegen_write_output(uint64 output_path) {
    uint64 fd = file_open(output_path, 1)
    file_write(fd, out_buf, out_len)
    file_close(fd)
}

@export
fn codegen_output_len() -> uint64 {
    return out_len
}
