{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_verify_report_v1.schema.json",
  "title": "KernRift Verify Report v1",
  "description": "Deterministic report emitted by `kernriftc verify --report`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result",
    "inputs",
    "hash",
    "contracts",
    "signature",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "description": "Report schema identifier.",
      "const": "kernrift_verify_report_v1"
    },
    "result": {
      "description": "Final verify verdict.",
      "type": "string",
      "enum": [
        "pass",
        "deny",
        "invalid_input"
      ]
    },
    "inputs": {
      "description": "Input filenames used by verify (stable/basename form).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contracts",
        "hash"
      ],
      "properties": {
        "contracts": {
          "description": "Contracts JSON input path (basename if absolute).",
          "type": "string"
        },
        "hash": {
          "description": "SHA-256 file input path (basename if absolute).",
          "type": "string"
        },
        "sig": {
          "description": "Signature file input path (if provided).",
          "type": [
            "string",
            "null"
          ]
        },
        "pubkey": {
          "description": "Public key file input path (if provided).",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "hash": {
      "description": "Hash comparison facts observed by verify.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_sha256",
        "computed_sha256",
        "matched"
      ],
      "properties": {
        "expected_sha256": {
          "description": "Hash loaded from --hash file (normalized lower-hex), or null on invalid input before parse.",
          "type": [
            "string",
            "null"
          ]
        },
        "computed_sha256": {
          "description": "Hash computed from contracts bytes, or null on read failure.",
          "type": [
            "string",
            "null"
          ]
        },
        "matched": {
          "description": "True when expected and computed hash match exactly.",
          "type": "boolean"
        }
      }
    },
    "contracts": {
      "description": "Contracts decode/validation facts observed by verify.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "utf8_valid",
        "schema_valid",
        "schema_version"
      ],
      "properties": {
        "utf8_valid": {
          "description": "True when contracts bytes decode as UTF-8.",
          "type": "boolean"
        },
        "schema_valid": {
          "description": "True when contracts JSON validates against contracts_v1 schema.",
          "type": "boolean"
        },
        "schema_version": {
          "description": "Observed contracts schema_version when decode succeeds, else null.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "signature": {
      "description": "Signature-check facts (if --sig/--pubkey were supplied).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked",
        "valid"
      ],
      "properties": {
        "checked": {
          "description": "True if signature verification was requested.",
          "type": "boolean"
        },
        "valid": {
          "description": "True/false when checked, null when not checked.",
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "diagnostics": {
      "description": "Deterministic sorted+deduped diagnostic messages.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    }
  }
}
