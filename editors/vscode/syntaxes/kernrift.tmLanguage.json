{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KernRift",
  "scopeName": "source.kr",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#annotations" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.double-slash.kr",
        "match": "//.*$"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.kr",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.kr",
          "match": "\\\\[nrt0\\\\\"']"
        }]
      }]
    },
    "chars": {
      "patterns": [{
        "name": "string.quoted.single.kr",
        "match": "'(?:\\\\[nrt0\\\\']|[^'])'"
      }]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kr",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.decimal.kr",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kr",
          "match": "\\b(if|else|while|for|in|break|continue|return|match|import)\\b"
        },
        {
          "name": "keyword.declaration.kr",
          "match": "\\b(fn|struct|enum|static|const|type|unsafe)\\b"
        },
        {
          "name": "constant.language.kr",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.other.kr",
          "match": "\\b(extern|export)\\b"
        }
      ]
    },
    "types": {
      "patterns": [{
        "name": "storage.type.kr",
        "match": "\\b(uint8|uint16|uint32|uint64|int8|int16|int32|int64|u8|u16|u32|u64|i8|i16|i32|i64|bool|char|addr|byte)\\b"
      }]
    },
    "annotations": {
      "patterns": [{
        "name": "meta.annotation.kr",
        "match": "@(export|ctx|eff|caps)\\b"
      }]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.kr",
          "match": "\\b(exit|write|alloc|file_open|file_read|file_write|file_close|file_size)\\b"
        },
        {
          "comment": "Function definition",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?)",
          "captures": {
            "1": { "name": "keyword.declaration.kr" },
            "2": { "name": "entity.name.function.definition.kr" }
          }
        },
        {
          "comment": "Function call",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.kr" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.kr",
        "match": "=>|&&|\\|\\||==|!=|<=|>=|<<|>>|\\+=|-=|\\*=|/=|[+\\-*/%&|^~!<>=]"
      }]
    }
  }
}
