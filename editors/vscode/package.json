{
  "name": "kernrift",
  "displayName": "KernRift",
  "description": "Language support for KernRift systems language (.kr files)",
  "version": "0.1.2",
  "publisher": "Pantelis23",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pantelis23/KernRift"
  },
  "icon": "logo.png",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "kernrift",
      "aliases": ["KernRift", "kr"],
      "extensions": [".kr"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "kernrift",
      "scopeName": "source.kr",
      "path": "./syntaxes/kernrift.tmLanguage.json"
    }]
  }
}
