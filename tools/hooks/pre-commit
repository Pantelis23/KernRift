#!/usr/bin/env bash
set -euo pipefail

LIMIT_BYTES=$((25 * 1024 * 1024))

# staged files (added/copied/modified/renamed)
mapfile -d '' FILES < <(git diff --cached --name-only -z --diff-filter=ACMR)

fail=0

# Block dist/
for f in "${FILES[@]}"; do
  if [[ "$f" == dist/* ]]; then
    echo "pre-commit: blocked: staged path under dist/: $f" >&2
    fail=1
  fi
done

# Block large staged blobs
for f in "${FILES[@]}"; do
  [[ -f "$f" ]] || continue
  sz=$(wc -c <"$f" | tr -d ' ')
  if [[ "$sz" -gt "$LIMIT_BYTES" ]]; then
    echo "pre-commit: blocked: $f is ${sz} bytes (> ${LIMIT_BYTES})" >&2
    fail=1
  fi
done

if [[ "$fail" -ne 0 ]]; then
  echo "pre-commit: fix: remove dist/ from staging and/or reduce file size." >&2
  exit 1
fi
