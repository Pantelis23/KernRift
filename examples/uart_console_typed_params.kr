@module_caps(MmioRaw);

mmio UART0 = 0x1000;
mmio_reg UART0.DR = 0x00 : u32 rw;

// Typed parameter: `ch` is received from the external (C) caller via %rdi.
// The param is spilled to the stack frame and loaded into %rbx before use.
@ctx(thread, boot)
fn write_char(ch: u32) {
  mmio_write<u32>(UART0 + 0x00, ch);
}

// Two typed parameters: the function receives `val` in %rdi.
@ctx(thread, boot)
fn write_word(val: u32) {
  mmio_write<u32>(UART0 + 0x00, val);
}
