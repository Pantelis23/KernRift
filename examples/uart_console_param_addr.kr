@module_caps(MmioRaw);

// Read a u32 from an arbitrary address supplied by the caller.
// The address arrives in %rdi (SysV ABI) and is loaded from the stack frame.
@ctx(thread, boot)
fn mmio_read_u32(addr: u64) {
  raw_mmio_read<u32>(addr, value);
  raw_mmio_write<u32>(addr, value);
}

// Write an immediate value to a caller-supplied address.
@ctx(thread, boot)
fn mmio_write_imm(addr: u64) {
  raw_mmio_write<u32>(addr, 0x01);
}
