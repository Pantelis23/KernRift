fn font_set_glyph(uint64 p, uint64 b0, uint64 b1, uint64 b2, uint64 b3, uint64 b4, uint64 b5, uint64 b6, uint64 b7, uint64 b8, uint64 b9, uint64 b10, uint64 b11, uint64 b12, uint64 b13, uint64 b14, uint64 b15) {
    uint8 v0 = b0
    unsafe { *(p as uint8) = v0 }
    uint64 p1 = p + 1
    uint8 v1 = b1
    unsafe { *(p1 as uint8) = v1 }
    uint64 p2 = p + 2
    uint8 v2 = b2
    unsafe { *(p2 as uint8) = v2 }
    uint64 p3 = p + 3
    uint8 v3 = b3
    unsafe { *(p3 as uint8) = v3 }
    uint64 p4 = p + 4
    uint8 v4 = b4
    unsafe { *(p4 as uint8) = v4 }
    uint64 p5 = p + 5
    uint8 v5 = b5
    unsafe { *(p5 as uint8) = v5 }
    uint64 p6 = p + 6
    uint8 v6 = b6
    unsafe { *(p6 as uint8) = v6 }
    uint64 p7 = p + 7
    uint8 v7 = b7
    unsafe { *(p7 as uint8) = v7 }
    uint64 p8 = p + 8
    uint8 v8 = b8
    unsafe { *(p8 as uint8) = v8 }
    uint64 p9 = p + 9
    uint8 v9 = b9
    unsafe { *(p9 as uint8) = v9 }
    uint64 p10 = p + 10
    uint8 va = b10
    unsafe { *(p10 as uint8) = va }
    uint64 p11 = p + 11
    uint8 vb = b11
    unsafe { *(p11 as uint8) = vb }
    uint64 p12 = p + 12
    uint8 vc = b12
    unsafe { *(p12 as uint8) = vc }
    uint64 p13 = p + 13
    uint8 vd = b13
    unsafe { *(p13 as uint8) = vd }
    uint64 p14 = p + 14
    uint8 ve = b14
    unsafe { *(p14 as uint8) = ve }
    uint64 p15 = p + 15
    uint8 vf = b15
    unsafe { *(p15 as uint8) = vf }
}

fn fb_char(uint64 fb, uint64 x, uint64 y, uint64 ch, uint64 color) {
    if ch < 32 || ch > 126 { return }
    uint64 font = font_init()
    uint64 glyph = font + (ch - 32) * 16
    uint64 row = 0
    while row < 16 {
        uint64 rp = glyph + row
        uint64 bits = 0
        unsafe { *(rp as uint8) -> bits }
        if bits != 0 {
            uint64 col = 0
            while col < 8 {
                uint64 mask = 0x80 >> col
                if (bits & mask) != 0 {
                    fb_pixel(fb, x + col, y + row, color)
                }
                col = col + 1
            }
        }
        row = row + 1
    }
}

fn fb_text(uint64 fb, uint64 x, uint64 y, uint64 str, uint64 color) {
    uint64 cx = x
    uint64 cy = y
    uint64 i = 0
    uint64 ch = 0
    uint64 sp = str + i
    unsafe { *(sp as uint8) -> ch }
    while ch != 0 {
        if ch == 10 {
            cy = cy + 16
            cx = x
        } else {
            fb_char(fb, cx, cy, ch, color)
            cx = cx + 8
        }
        i = i + 1
        sp = str + i
        unsafe { *(sp as uint8) -> ch }
    }
}
